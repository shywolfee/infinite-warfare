// ---------------------------------------------------------------------------
// First-run welcome — shown the very first time the game is launched.
// Displays the preliminary notice, then shows the rules and requires
// agreement before proceeding.
// ---------------------------------------------------------------------------
void show_first_run_message()
{
audio_form f;
f.create_window("Welcome", false, true);
f.create_input_box("Notice", "It looks like this is the first time you've run Infinite Warfare. A configuration file will be created for you. If you're new to the game, we suggest you check out the included readme for information on how to play.", "", 0, false, true, false);
int f_continue=f.create_button("&Continue", true);
f.focus(0);
while(true)
{
wait(5);
f.monitor();
if (f.is_pressed(f_continue))
break;
}
}
void first_run_welcome()
{
string notice_text = "Notice: The present iteration of this game has been developed with the assistance of agentic artificial-intelligence (Claude code, utilizing the 4.6 opus model). Additionally, this game utilizes unauthorized source code from Redspot: Blood and peril, by Sam Tupy. Credit goes to Sam Tupy for his original ideas, and to Max Vrenken and Djonan Smid of firegaming for the original Infinite Warfair codebase. This game is in an extensive alpha stage. Many features lack sounds or are effectively unfinished. The current server is a test build designed to stress test new features and mechanics. Your data and progress will not persist upon final release of the game. I provide no guarantees of constant server uptime or stability. The game can and will be taken down for maintenance with little or no notice. There are guaranteed bugs and glitches. The goal of this test period is to iron them out. If you wish to play the game despite this, please check the following box to certify that you have read and understood this notice.";
audio_form f;
f.create_window("Preliminary Notice", false, true);
f.create_input_box("Notice", notice_text, "", 0, false, true, true);
int f_certify = f.create_checkbox("I certify that I have read the preliminary notice in it's entirety.", false);
int f_continue = f.create_button("&Continue", true);
f.focus(0);
while(true)
{
wait(5);
f.monitor();
if (f.is_pressed(f_continue))
{
if (!f.is_checked(f_certify))
{
dlg("You must certify that you have read the preliminary notice to continue.");
continue;
}
break;
}
}
// Load and show rules.
file rf;
string rules_text = "";
if (rf.open("rules.txt", "rb"))
{
rules_text = rf.read();
rf.close();
}
else
rules_text = "Rules file not found. Please check the game folder.";
audio_form f2;
f2.create_window("Please Read the Rules", false, true);
f2.create_input_box("Rules", rules_text, "", 0, false, true, true);
int f2_agree = f2.create_checkbox("I agree to the rules", false);
int f2_continue = f2.create_button("&Continue", true);
f2.focus(0);
while(true)
{
wait(5);
f2.monitor();
if (f2.is_pressed(f2_continue))
{
if (!f2.is_checked(f2_agree))
{
dlg("You must agree to the rules to continue.");
continue;
}
break;
}
}
// Mark first run as done.
sd.add("first_run_done", 1);
sd.save();
}
// ---------------------------------------------------------------------------
// Developer Suite (Shift+D) — only available in dev builds.
// ---------------------------------------------------------------------------
void dev_suite()
{
audio_form f;
f.create_window("Developer Suite", false, true);
int f_giveall=f.create_button("Give &all items");
int f_spawnveh=f.create_button("&Spawn vehicle");
int f_close=f.create_button("&Close", false, true);
f.focus(f_giveall);
while(true)
{
wait(5);
f.monitor();
if (connected==true)
netloop();
if (f.is_pressed(f_giveall))
{
give_all();
speak("All items given.");
}
else if (f.is_pressed(f_spawnveh))
{
dev_spawn_vehicle();
}
else if (f.is_pressed(f_close))
{
break;
}
}
}
void dev_spawn_vehicle()
{
if (vehicle_types.length() == 0) init_vehicle_types();
audio_form f;
f.create_window("Spawn Vehicle", false, true);
int f_list = f.create_list("Select a vehicle type", 0, false);
for (uint i = 0; i < vehicle_types.length(); i++)
{
f.add_list_item(f_list, vehicle_types[i].name);
}
int f_spawn = f.create_button("S&pawn", true);
int f_cancel = f.create_button("&Cancel", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if (connected==true)
netloop();
if (f.is_pressed(f_spawn))
{
int sel = f.get_list_position(f_list);
if (sel >= 0 and sel < int(vehicle_types.length()))
{
double rad = facing * 3.1415926535897932 / 180.0;
int vx = int(round(mr.x + sine(rad) * 2, 0));
int vy = int(round(mr.y + cosine(rad) * 2, 0));
int vz = int(me.z);
map_vehicles.insert_last(vehicle(sel, vx, vy, vz));
speak(vehicle_types[sel].name + " spawned.");
}
break;
}
else if (f.is_pressed(f_cancel))
{
break;
}
}
}

// ---------------------------------------------------------------------------
// Builder menu (Shift+B) — dev only. Edits map files on the server.
// ---------------------------------------------------------------------------
string[] builder_tile_types = {"shallow", "sand", "concrete2", "concrete5", "concrete10", "concrete12", "hardwood", "hardwood2", "carpet1", "tile1", "tile2", "grass", "grass3", "gravel1", "rocks1", "stone", "cement", "metal2", "metal4", "metal5", "tunnel", "bridge", "plank", "ladder1", "blank", "water1", "wallbrick", "wallstone", "wallwood", "wallfence", "wallrock", "glass", "tree"};

string builder_fetch_map_data(string mname)
{
send_reliable(0, "builder_read "+mname, 0);
timer ct;
while(ct.elapsed<5000)
{
wait(5);
e=n.request();
if(e.type==event_receive)
{
string msg=get_event_message();
if(string_contains(msg, "builder_data ", 1)==0)
return string_replace(msg, "builder_data ", "", false);
}
}
return "";
}

string builder_coord_form(string title, bool need_range, bool need_extra, string extra_label)
{
audio_form f;
f.create_window(title, false, true);
string result="";
if(need_range)
{
f.create_input_box("Min X");
f.create_input_box("Max X");
f.create_input_box("Min Y");
f.create_input_box("Max Y");
f.create_input_box("Min Z");
f.create_input_box("Max Z");
}
else
{
f.create_input_box("X");
f.create_input_box("Y");
f.create_input_box("Z");
}
int extra_ctrl=-1;
if(need_extra)
extra_ctrl=f.create_input_box(extra_label);
int ok_btn=f.create_button("OK", true);
int cancel_btn=f.create_button("Cancel", false, true);
f.focus(0);
while(true)
{
wait(5);
f.monitor();
if(f.is_pressed(cancel_btn)) return "";
if(f.is_pressed(ok_btn))
{
if(need_range)
{
result=f.get_text(0)+":"+f.get_text(1)+":"+f.get_text(2)+":"+f.get_text(3)+":"+f.get_text(4)+":"+f.get_text(5);
if(need_extra) result+=":"+f.get_text(6);
}
else
{
result=f.get_text(0)+":"+f.get_text(1)+":"+f.get_text(2);
if(need_extra) result+=":"+f.get_text(3);
}
return result;
}
}
return "";
}

string builder_pick_tile()
{
audio_form f;
f.create_window("Select Tile Type", false, true);
int f_list=f.create_list("Tile types", 0, false);
for(uint i=0; i<builder_tile_types.length(); i++)
f.add_list_item(f_list, builder_tile_types[i]);
int preview_btn=f.create_button("&Preview sound");
int ok_btn=f.create_button("OK", true);
int cancel_btn=f.create_button("Cancel", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if(f.is_pressed(cancel_btn)) return "";
if(f.is_pressed(preview_btn))
{
int sel=f.get_list_position(f_list);
if(sel>=0 and sel<int(builder_tile_types.length()))
{
string sfile=builder_tile_types[sel]+"step1.ogg";
p.play_stationary(sfile, false);
}
}
if(f.is_pressed(ok_btn))
{
int sel=f.get_list_position(f_list);
if(sel>=0 and sel<int(builder_tile_types.length()))
return builder_tile_types[sel];
}
}
return "";
}

void builder_add_element()
{
audio_form f;
f.create_window("Add Map Element", false, true);
int f_list=f.create_list("Element type", 0, false);
f.add_list_item(f_list, "Tile");
f.add_list_item(f_list, "Zone");
f.add_list_item(f_list, "Ambient Sound Source");
f.add_list_item(f_list, "Point of Interest");
f.add_list_item(f_list, "Item Spawn");
f.add_list_item(f_list, "Map Name");
f.add_list_item(f_list, "Map Max X");
f.add_list_item(f_list, "Map Max Y");
f.add_list_item(f_list, "Map Max Z");
int ok_btn=f.create_button("OK", true);
int cancel_btn=f.create_button("Cancel", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if(f.is_pressed(cancel_btn)) return;
if(f.is_pressed(ok_btn))
{
int sel=f.get_list_position(f_list);
string line="";
if(sel==0)
{
string coords=builder_coord_form("Tile Coordinates", true, false, "");
if(coords=="") return;
string tile=builder_pick_tile();
if(tile=="") return;
line="tile:"+coords+":"+tile;
}
else if(sel==1)
{
string coords=builder_coord_form("Zone Coordinates", true, false, "");
if(coords=="") return;
audio_form zf;
zf.create_window("Zone Name", false, true);
zf.create_input_box("Zone name");
int zok=zf.create_button("OK", true);
int zcancel=zf.create_button("Cancel", false, true);
zf.focus(0);
string zname="";
while(true)
{
wait(5);
zf.monitor();
if(zf.is_pressed(zcancel)) return;
if(zf.is_pressed(zok)){zname=zf.get_text(0);break;}
}
if(zname=="") return;
line="zone:"+coords+":"+zname;
}
else if(sel==2)
{
string coords=builder_coord_form("Source Coordinates", true, false, "");
if(coords=="") return;
audio_form sf;
sf.create_window("Sound Source", false, true);
sf.create_input_box("Sound file (e.g. ocean1.ogg)");
sf.create_input_box("Volume in dB (e.g. -8)");
int sok=sf.create_button("OK", true);
int scancel=sf.create_button("Cancel", false, true);
sf.focus(0);
string sfile="";
string svol="";
while(true)
{
wait(5);
sf.monitor();
if(sf.is_pressed(scancel)) return;
if(sf.is_pressed(sok)){sfile=sf.get_text(0);svol=sf.get_text(1);break;}
}
if(sfile=="") return;
line="src:"+coords+":"+sfile+":"+svol;
}
else if(sel==3)
{
string coords=builder_coord_form("POI Coordinates", false, false, "");
if(coords=="") return;
audio_form pf;
pf.create_window("Point of Interest", false, true);
pf.create_input_box("POI name");
int pok=pf.create_button("OK", true);
int pcancel=pf.create_button("Cancel", false, true);
pf.focus(0);
string pname="";
while(true)
{
wait(5);
pf.monitor();
if(pf.is_pressed(pcancel)) return;
if(pf.is_pressed(pok)){pname=pf.get_text(0);break;}
}
if(pname=="") return;
line="poi:"+coords+":"+pname;
}
else if(sel==4)
{
string coords=builder_coord_form("Item Spawn Coordinates", true, false, "");
if(coords=="") return;
audio_form isf;
isf.create_window("Item Spawn", false, true);
isf.create_input_box("Respawn time (ms)");
isf.create_input_box("Max items in area");
isf.create_input_box("Items (comma separated, e.g. frag_grenade,smoke_bomb)");
int isok=isf.create_button("OK", true);
int iscancel=isf.create_button("Cancel", false, true);
isf.focus(0);
string istime="";
string ismax="";
string isitems="";
while(true)
{
wait(5);
isf.monitor();
if(isf.is_pressed(iscancel)) return;
if(isf.is_pressed(isok)){istime=isf.get_text(0);ismax=isf.get_text(1);isitems=isf.get_text(2);break;}
}
if(istime=="" or ismax=="" or isitems=="") return;
string items_colon=string_replace(isitems, ",", ":", true);
line="ispawn:"+coords+":"+istime+":"+ismax+":"+items_colon;
}
else if(sel==5)
{
audio_form nf;
nf.create_window("Map Name", false, true);
nf.create_input_box("Map name");
int nok=nf.create_button("OK", true);
int ncancel=nf.create_button("Cancel", false, true);
nf.focus(0);
while(true)
{
wait(5);
nf.monitor();
if(nf.is_pressed(ncancel)) return;
if(nf.is_pressed(nok)){line="mapname:"+nf.get_text(0);break;}
}
}
else if(sel==6)
{
audio_form vf;
vf.create_window("Map Max X", false, true);
vf.create_input_box("Max X value");
int vok=vf.create_button("OK", true);
int vcancel=vf.create_button("Cancel", false, true);
vf.focus(0);
while(true)
{
wait(5);
vf.monitor();
if(vf.is_pressed(vcancel)) return;
if(vf.is_pressed(vok)){line="maxx:"+vf.get_text(0);break;}
}
}
else if(sel==7)
{
audio_form vf;
vf.create_window("Map Max Y", false, true);
vf.create_input_box("Max Y value");
int vok=vf.create_button("OK", true);
int vcancel=vf.create_button("Cancel", false, true);
vf.focus(0);
while(true)
{
wait(5);
vf.monitor();
if(vf.is_pressed(vcancel)) return;
if(vf.is_pressed(vok)){line="maxy:"+vf.get_text(0);break;}
}
}
else if(sel==8)
{
audio_form vf;
vf.create_window("Map Max Z", false, true);
vf.create_input_box("Max Z value");
int vok=vf.create_button("OK", true);
int vcancel=vf.create_button("Cancel", false, true);
vf.focus(0);
while(true)
{
wait(5);
vf.monitor();
if(vf.is_pressed(vcancel)) return;
if(vf.is_pressed(vok)){line="maxz:"+vf.get_text(0);break;}
}
}
if(line!="")
{
string mname=string_replace(mapname, " ", "_", true);
string[] mfiles={"main", "habitat_alpha", "battleroyale"};
for(uint i=0; i<mfiles.length(); i++)
{
string mdata=builder_fetch_map_data(mfiles[i]);
if(mdata!="" and string_contains(mdata, "mapname:"+mapname, 1)>-1)
{
send_reliable(0, "builder_append "+mfiles[i]+" "+line, 0);
speak("Element added.");
return;
}
}
speak("Could not find map file for "+mapname+".");
}
return;
}
}
}

void builder_delete_line_menu()
{
string[] mfiles={"main", "habitat_alpha", "battleroyale"};
string found_file="";
string mdata="";
for(uint i=0; i<mfiles.length(); i++)
{
string d=builder_fetch_map_data(mfiles[i]);
if(d!="" and string_contains(d, "mapname:"+mapname, 1)>-1)
{
found_file=mfiles[i];
mdata=d;
break;
}
}
if(found_file==""){speak("Map file not found.");return;}
string[] lines=delinear(mdata);
int[] line_indices;
audio_form f;
f.create_window("Delete Line", false, true);
int f_list=f.create_list("Map lines", 0, false);
for(uint i=0; i<lines.length(); i++)
{
if(lines[i]!="")
{
f.add_list_item(f_list, (i+1)+": "+lines[i]);
line_indices.insert_last(i);
}
}
int del_btn=f.create_button("&Delete selected", true);
int cancel_btn=f.create_button("Cancel", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if(f.is_pressed(cancel_btn)) return;
if(f.is_pressed(del_btn))
{
int sel=f.get_list_position(f_list);
if(sel>=0 and sel<int(line_indices.length()))
{
send_reliable(0, "builder_delete_line "+found_file+" "+line_indices[sel], 0);
speak("Line deleted.");
return;
}
}
}
}

void builder_edit_line_menu()
{
string[] mfiles={"main", "habitat_alpha", "battleroyale"};
string found_file="";
string mdata="";
for(uint i=0; i<mfiles.length(); i++)
{
string d=builder_fetch_map_data(mfiles[i]);
if(d!="" and string_contains(d, "mapname:"+mapname, 1)>-1)
{
found_file=mfiles[i];
mdata=d;
break;
}
}
if(found_file==""){speak("Map file not found.");return;}
string[] lines=delinear(mdata);
int[] line_indices;
audio_form f;
f.create_window("Edit Line", false, true);
int f_list=f.create_list("Map lines", 0, false);
for(uint i=0; i<lines.length(); i++)
{
if(lines[i]!="")
{
f.add_list_item(f_list, (i+1)+": "+lines[i]);
line_indices.insert_last(i);
}
}
int edit_btn=f.create_button("&Edit selected", true);
int cancel_btn=f.create_button("Cancel", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if(f.is_pressed(cancel_btn)) return;
if(f.is_pressed(edit_btn))
{
int sel=f.get_list_position(f_list);
if(sel>=0 and sel<int(line_indices.length()))
{
int line_idx=line_indices[sel];
string old_line=lines[line_idx];
audio_form ef;
ef.create_window("Edit Line "+(line_idx+1), false, true);
ef.create_input_box("Line content", old_line);
int save_btn=ef.create_button("&Save", true);
int ecancel=ef.create_button("Cancel", false, true);
ef.focus(0);
while(true)
{
wait(5);
ef.monitor();
if(ef.is_pressed(ecancel)) return;
if(ef.is_pressed(save_btn))
{
string new_line=ef.get_text(0);
send_reliable(0, "builder_edit_line "+found_file+" "+line_idx+" "+new_line, 0);
speak("Line edited.");
return;
}
}
}
}
}
}

