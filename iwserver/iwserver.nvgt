else if(parsed[0]=="hitwall" and parsed.length()>3)
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
send_reliable(0, "hitwall "+players[index].name+" "+parsed[1]+" "+parsed[2]+" "+parsed[3]+" "+players[index].map, 0, index);
}
}
else if(parsed[0]=="plane_turn" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
for(int i=0; i<planes.length(); i++)
{
if(players[index].in_plane==true and players[index].name==planes[i].owner)
{
planes[i].dir=string_to_number(parsed[1]);
players[index].facing=string_to_number(parsed[1]);
}
}
}
}
else if(parsed[0]=="plane_stop")
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
play("duoplaneout", players[index].x, players[index].y, players[index].z, players[index].map, index);
players[index].in_plane=false;
}
}
else if(parsed[0]=="use" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
if(parsed[1]=="duo_plane")
{
bool can_spawn=true;
for(int i=0; i<planes.length(); i++)
{
if(players[index].name==planes[i].owner or players[index].name==planes[i].mate)
{
can_spawn=false;
}
else
can_spawn=true;
}
if(can_spawn==true)
{
spawn_plane(players[index].x,players[index].y, players[index].z,players[index].map,players[index].name);
send_reliable(players[index].peer_id, "give duo_plane -1", 0);
}
else
send_reliable(players[index].peer_id, "Your duo already has a plane, so you can't place another one.", 0);
}
else if(parsed[1]=="health_potion")
{
if(players[index].health>1001)
send_reliable(players[index].peer_id, "Your health is already full.", 2);
else if(players[index].health_potiontimer.elapsed<=20000)
{
int cd_remain=(20000-players[index].health_potiontimer.elapsed)/1000;
send_reliable(players[index].peer_id, "You must wait "+cd_remain+" seconds before using another health potion.", 2);
}
else
{
players[index].usehealth_potion=true;
players[index].usehealth_potiontimer.restart();
players[index].health_potiontimer.restart();
send_reliable(players[index].peer_id, "give health_potion -1", 0);
players[index].health+=200;
play("health_potion", players[index].x, players[index].y, players[index].z, players[index].map, index);
send_reliable(players[index].peer_id, "movestop", 0);
}
}
if(string_contains(parsed[1], "corpse_", 1)>-1)
{
open_corpse(string_replace(parsed[1], "corpse_", "", true), index);
//players[index].give(parsed[1],-1);
send_reliable(players[index].peer_id, "give parsed[1] -1", 0);
}
if(parsed[1]=="life_injection")
{
if(players[index].mate=="")
{
send_reliable(players[index].peer_id, "You don't have a duo mate set.", 2);
}
else
{
int index2=get_player_index_from(players[index].mate);
if(index2>-1)
{
if(players[index2].death!=true)
{
send_reliable(players[index].peer_id, "Your duo mate is not dead.", 2);
}
else if(players[index].map!=players[index2].map or get_3d_distance(players[index].x,players[index].y,players[index].z,players[index2].x,players[index2].y,players[index2].z)>4)
{
send_reliable(players[index].peer_id, "You are too far away from your duo mate.", 2);
}
else
{
send_reliable(players[index].peer_id, "give life_injection -1", 0);
players[index2].health=500;
players[index].life_injection=true;
players[index].life_injectiontimer.restart();
play("life_injection", players[index].x, players[index].y, players[index].z, players[index].map, index);
players[index2].death==false;
send_reliable(players[index].peer_id, "movestop", 0);
}
}
else
{
send_reliable(players[index].peer_id, "Your duo mate was not found on the server.", 2);
}
}
}
if(parsed[1]=="ultra_health_potion") 
{
players[index].ultra_health_potion=true;
players[index].ultra_health_potiontimer.restart();
send_reliable(players[index].peer_id, "give ultra_health_potion -1", 0);
players[index].health+=random(500,600);
play("ultra_health_potion", players[index].x, players[index].y, players[index].z, players[index].map, index);
send_reliable(players[index].peer_id, "movestop", 0);
}
if(players[index].health>=1000)
{
players[index].health=1000;
}
if(parsed[1]=="bag")
{
send_reliable(players[index].peer_id, "give bag -1", 0);
send_reliable(players[index].peer_id, "give health_potion 2", 0);
send_reliable(players[index].peer_id, "give bomb_vest 1", 0);
play("bagopen", players[index].x, players[index].y, players[index].z, players[index].map, index);
send_unreliable(players[index].peer_id, "ammogive benelli_m4_shotgun 15", 0);
send_unreliable(players[index].peer_id, "ammogive 357magnum_revolver 30", 0);
}
if(parsed[1]=="fake_item")
{
if(players[index].fake_itemtimer.elapsed>2000)
{
players[index].fake_itemtimer.restart();
spawn_item(players[index].x,players[index].y,players[index].z,players[index].map,"fake.item",players[index].name);
send_reliable(players[index].peer_id, "give fake_item -1", 0);
play("fakeitemplace",players[index].x,players[index].y,players[index].z,players[index].map);
}
else
{
int cd_remain=(2000-players[index].fake_itemtimer.elapsed)/1000;
send_reliable(players[index].peer_id, "You must wait "+cd_remain+" seconds before placing another fake item.", 2);
}
}
if(parsed[1]=="box")
{
send_reliable(players[index].peer_id, "give box -1", 0);
