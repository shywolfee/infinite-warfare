bool is_dvr=is_dev_account(aname);
if(is_admr or is_dvr)
{
string result="admin_reset_list ";
string[] files=find_files("accounts/*.dat");
bool first3=true;
for(uint i=0; i<files.length(); i++)
{
savedata acct("accounts/"+files[i], ACCOUNT_SECRET);
acct.load();
string rc=acct.read("resetcode");
if(rc!="")
{
if(!first3) result+=",";
result+=acct.read("username")+"|"+rc;
first3=false;
}
}
send_reliable(e.peer_id, result, 0);
}
}
