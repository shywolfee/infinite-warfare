ballista@[] ballistas(0);
class ballista
{
int x;
int y;
int z;
string map;
ballista(int bx,int by,int bz,string bmap)
{
x=bx;
y=by;
z=bz;
map=bmap;
}
}
void bunkerloop()
{
for (uint i=0; i<bunkers.length(); i++)
{
for (uint e=0; e<players.length(); e++)
{
if(bunkers[i].healtimer.elapsed>=3000 and players[e].x==bunkers[i].x and players[e].y==bunkers[i].y and players[e].z==bunkers[i].z and players[e].name==bunkers[i].owner)
{
play("healing",bunkers[i].x,bunkers[i].y,bunkers[i].z,bunkers[i].map);
bunkers[i].healtimer.restart();
players[e].health+=random(20,25);
}
}
}
}
