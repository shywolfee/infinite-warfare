weapon@[] weapons(0);
class weapon
{
double vertical_angle;
double x;
double y;
double z;
int dir;
string type;
timer speedtimer;
int speedtime;
int range;
int distance=0;
int mindammage=50;
int maxdammage=1000;
string cn;
string map;
int spread=0;
double gravity=0.02;
double vertical_velocity;
weapon(double wx, double wy, double wz, double wdir, double wvertical_angle, string wtype, string wcn, string wmap)
{
vertical_angle=wvertical_angle;
x=wx;
y=wy;
z=wz;
dir=wdir;
type=wtype;
cn=wcn;
map=wmap;
double theta_v=vertical_angle*pi/180;
vertical_velocity=sine(theta_v);
if(type=="beretta92fs_pistol")
{
speedtime=5;
range=40;
mindammage=1050;
maxdammage=2500;
spread=1;
gravity=0.015;
}
else if(type=="m1garantBattleRifle")
{
speedtime=5;
range=90;
mindammage=2500;
maxdammage=4000;
spread=4;
gravity=0.01;
}
else if(type=="AK47")
{
speedtime=5;
range=40;
mindammage=100;
maxdammage=1400;
spread=3;
gravity=0.02;
}
else if(type=="120mm_mortar")
{
speedtime=50;
range=100;
mindammage=3000;
maxdammage=4000;
spread=5;
gravity=0.05;
}
else if(type=="tar_21_assault_rifle")
{
