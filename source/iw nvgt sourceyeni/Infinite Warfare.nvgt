string af_input(string title, string text="", bool online=false)
{
audio_form af;
af.create_window(title, false, true);
int af_n=af.create_input_box(title, text, "", 0, false, false, false);
int af_ok=af.create_button("&OK", true);
int af_cancel=af.create_button("&Cancel", false, true);
af.focus(af_n);
while(true)
{
wait(5);
af.monitor();
if(online==true)
{
mainloop();
netloop();
p.update_listener_3d(me.x, me.y, me.z, calculate_theta(facing));
}
if(af.is_pressed(af_cancel))
return "";
if(af.is_pressed(af_ok))
return af.get_text(af_n);
}
return "";
}
