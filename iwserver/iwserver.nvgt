}
}
if(parsed[1]=="p90_mp")
{
send_unreliable(players[index].peer_id, "weapon_set p90_mp", 0);
}
if(parsed[1]=="semtex_pack")
{
play("bagopen", players[index].x, players[index].y, players[index].z, players[index].map, index);
send_unreliable(players[index].peer_id, "give semtex 1", 0);
send_unreliable(players[index].peer_id, "give semtex_controller 1", 0);
send_unreliable(players[index].peer_id, "give semtex_pack -1", 0);
}
if(parsed[1]=="semtex_controller")
{
bool semtex_found=false;
for (uint i=0; i<samtexs.length(); i++)
{
if(samtexs[i].owner==players[index].name)
{
play("semtexactivate",players[index].x,players[index].y,players[index].z,players[index].map);
explode();
semtex_found=true;
}
}
if(!semtex_found)
send_reliable(players[index].peer_id, "You have no semtex charges placed.", 2);
}
if(parsed[1]=="semtex")
{
if(samtexs.length()<15)
{
send_reliable(players[index].peer_id, "give semtex -1", 0);
spawn_samtex(players[index].x,players[index].y,players[index].z,players[index].map,players[index].name);
play("semtexplace",players[index].x,players[index].y,players[index].z,players[index].map);
send_reliable(players[index].peer_id, "movestop", 0);
players[index].semtex=true;
players[index].semtextimer.restart();
}
else
send_reliable(players[index].peer_id, "Too many explosives placed.", 2);
}
if(parsed[1]=="bunker_bomb")
{
bool bomb_found=false;
for(int i=0; i<bunkers.length(); i++)
{
if(players[index].x==bunkers[i].x and players[index].y==bunkers[i].y and players[index].z==bunkers[i].z)
{
send_reliable(players[index].peer_id, "give bunker_bomb -1", 0);
spawn_bunkerbomb(players[index].x,players[index].y,players[index].z,players[index].map,players[index].name);
play("bunkerbombplace",players[index].x,players[index].y,players[index].z,players[index].map);
send_reliable(players[index].peer_id, "movestop", 0);
players[index].bunkerbomb=true;
players[index].bunkerbombtimer.restart();
bomb_found=true;
break;
}
}
if(!bomb_found)
send_reliable(players[index].peer_id, "You must be at a bunker control panel to place a bunker bomb.", 2);
}
if(parsed[1]=="torpedo") 
{
if(get_tile_at(players[index].x, players[index].y, players[index].z, players[index].map)=="shallow" and players[index].torpedotimer.elapsed>3000)
{
players[index].torpedotimer.restart();
send_reliable(players[index].peer_id, "give torpedo -1", 0);
spawn_torpedo(players[index].x,players[index].y,players[index].z,players[index].facing,players[index].map,players[index].name);
play("torpedolounch",players[index].x,players[index].y,players[index].z,players[index].map);
send_reliable(0,"distsound torpedolounchdist.ogg "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].map,0);
}
else
send_reliable(players[index].peer_id, "you have to stand in water to let this wurk...", 0);
}
for(int i=0; i<bunkers.length(); i++)
{
if(parsed[1]=="bunker_key")
{
if(players[index].x==bunkers[i].x and players[index].y==bunkers[i].y and players[index].z==bunkers[i].z)
{
if(players[index].name==bunkers[i].owner)
{
send_reliable(players[index].peer_id, "You already own this bunker.", 2);
}
else if(bunkers[i].owner!="")
{
send_reliable(players[index].peer_id, "This bunker is already claimed by someone else.", 2);
}
else
{
send_reliable(players[index].peer_id, "give bunker_key -1", 0);
bunkers[i].owner=players[index].name;
send_reliable(0, "play_s notify.ogg", 0);
send_reliable(0, bunkers[i].name+", has been captured by, "+players[index].name, 2);
int owned=0;
for(uint b=0; b<bunkers.length(); b++)
{
if(bunkers[b].owner==players[index].name) owned++;
}
players[index].bunkers_owned=owned;
if(owned>=2 and !players[index].has_hypercomp)
{
players[index].has_hypercomp=true;
send_reliable(players[index].peer_id, "give hypercomp 1", 0);
send_reliable(players[index].peer_id, "play_s killachievement.ogg", 0);
send_reliable(players[index].peer_id, "You've claimed your second bunker! You receive the HyperComp, a structure management device. Use it from your inventory.", 2);
}
}
}
}
}
if(parsed[1]=="rock")
{
bool rock_found=false;
for(int i=0; i<ballistas.length(); i++)
{
if(players[index].x==ballistas[i].x and players[index].y==ballistas[i].y and players[index].z==ballistas[i].z and players[index].map==ballistas[i].map)
{
send_reliable(players[index].peer_id, "give rock -1", 0);
players[index].ballista=true;
players[index].ballistatimer.restart();
play("ballistareload", players[index].x, players[index].y, players[index].z, players[index].map, index);
send_reliable(players[index].peer_id, "movestop", 0);
rock_found=true;
break;
}
}
if(!rock_found)
send_reliable(players[index].peer_id, "You must be at a ballista to load rocks.", 2);
}
if(parsed[1]=="bomb_vest")
{
if(players[index].bombveston==false)
{
players[index].bombvesttime=0;
players[index].bombveston=true;
//rofl
play("bombvestwear", players[index].x, players[index].y, players[index].z, players[index].map, index);
send_reliable(players[index].peer_id, "give bomb_vest -1", 0);
}
else
send_reliable(players[index].peer_id, "you are already wearing a bomb_vest.", 0);
}
string[] usable_items={"duo_plane","health_potion","life_injection","ultra_health_potion","bag","fake_item","box","frag_grenade","bucket","empty_bucket","smoke_bomb","semtex_pack","semtex_controller","semtex","torpedo","bunker_bomb","bomb_vest","rock","bunker_key","hypercomp","c4","hayvork","ks123shotgun","trector_plow","p90_mp"};
bool is_usable=false;
for(uint ui=0; ui<usable_items.length(); ui++)
{
if(parsed[1]==usable_items[ui]){is_usable=true;break;}
}
if(!is_usable and string_contains(parsed[1], "corpse_", 1)<0)
send_reliable(players[index].peer_id, "This item cannot be used directly.", 2);
}
}
else if(parsed[0]=="afk_set" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
players[index].afk=(parsed[1]=="1");
}
else if(parsed[0]=="ac_violation")
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
send_reliable(0, players[index].name+" was removed by anti-cheat.", 2);
send_reliable(0, "offline "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].name+" "+players[index].map, 0);
players.remove_at(index);
}
}
else if(parsed[0]=="move_to_a" and parsed.length() > 3)
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
int new_x=string_to_number(parsed[1]);
int new_y=string_to_number(parsed[2]);
int new_z=string_to_number(parsed[3]);
int dx=new_x-players[index].last_x;
int dy=new_y-players[index].last_y;
if (dx<0) dx=-dx;
if (dy<0) dy=-dy;
int dist=dx+dy;
int elapsed=players[index].move_timer.elapsed;
if (dist>15 and elapsed<200)
{
players[index].teleport_warnings++;
if (players[index].teleport_warnings>5)
{
send_reliable(0, players[index].name+" was removed by anti-cheat.", 2);
send_reliable(0, "offline "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].name+" "+players[index].map, 0);
players.remove_at(index);
}
}
else
{
if (players[index].teleport_warnings>0) players[index].teleport_warnings--;
players[index].x=new_x;
players[index].y=new_y;
players[index].z=new_z;
players[index].last_x=new_x;
players[index].last_y=new_y;
players[index].last_z=new_z;
players[index].move_timer.restart();
}
}
}
else if(parsed[0]=="health")
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
int hp_pct=(players[index].health*100)/1000;
if(hp_pct<0) hp_pct=0;
send_reliable(e.peer_id,players[index].health+" health: "+hp_pct+"%, last hit by "+players[index].hitby, 0);
}
}
else if(parsed[0]=="use_potion")
{
int index=get_player_index(e.peer_id);
if(index > -1)  
{
if(players[index].health<=1001 and players[index].health_potiontimer.elapsed>20000)
{
players[index].health_potiontimer.restart();
send_reliable(players[index].peer_id, "give health_potion -1", 0);
players[index].health+=200;
play("health_potion", players[index].x, players[index].y, players[index].z, players[index].map, index);
}
}
}
else if(parsed[0]=="close")
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
send_reliable(0, "offline "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].name+" "+players[index].map, 0);
players.remove_at(index);
}
}
else if(parsed[0]=="whoonline")
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
string s="";
if (players.length()>1)
{
int active_count=0;
int afk_count=0;
for (uint i=0; i<players.length(); i++)
{
if (players[i].afk)
afk_count++;
else
active_count++;
}
s="There are "+players.length()+" players online, "+active_count+" active and "+afk_count+" afk. ";
string[] names;
for (uint i=0; i<players.length(); i++)
{
if (players[i].afk)
names.insert_last("[AFK] "+players[i].name);
else
names.insert_last(players[i].name);
}
for (uint i=0; i<names.length(); i++)
{
if (i>0) s+=", ";
s+=names[i];
}
}
else
s="You are alone";
send_reliable(players[index].peer_id, s, 2);
}
}
else if(parsed[0]=="report_message")
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
string message=string_replace(get_event_message(),"report_message ", "", true);
for(uint i=0; i<players.length(); i++)
{
if(players[i].dev or players[i].admin)
{
send_reliable(players[i].peer_id, "play_s notify.ogg", 0);
send_reliable(players[i].peer_id, "Report from "+players[index].name+": "+message, 2);
}
}
for(uint i=0; i<lobby_clients.length(); i++)
{
if(lobby_clients[i].dev or lobby_clients[i].admin)
{
send_reliable_id(lobby_clients[i].peer_id, "play_s notify.ogg", 0);
send_reliable_id(lobby_clients[i].peer_id, "Report from "+players[index].name+": "+message, 2);
}
}
send_reliable(players[index].peer_id, "Your report has been sent.", 2);
}
}
else if(parsed[0]=="report_quoted")
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
string raw=string_replace(get_event_message(),"report_quoted ", "", true);
string[] parts=string_split(raw, "\t", true);
if (parts.length()>=3)
{
string report_text="Report from "+players[index].name+": Message by "+parts[0]+": "+parts[1]+" | Quoted message: "+parts[2];
for(uint i=0; i<players.length(); i++)
{
if(players[i].dev or players[i].admin)
{
send_reliable(players[i].peer_id, "play_s notify.ogg", 0);
send_reliable(players[i].peer_id, report_text, 2);
}
}
for(uint i=0; i<lobby_clients.length(); i++)
{
if(lobby_clients[i].dev or lobby_clients[i].admin)
{
send_reliable_id(lobby_clients[i].peer_id, "play_s notify.ogg", 0);
send_reliable_id(lobby_clients[i].peer_id, report_text, 2);
}
}
}
send_reliable(players[index].peer_id, "Your report has been sent.", 2);
}
}
else if(parsed[0]=="nearplayers")
{
string p;
int index=get_player_index(e.peer_id);
if(index > -1)
{
for (uint i=0; i<players.length(); i++)
{
if (get_3d_distance(players[i].x,players[i].y,players[i].z,players[index].x,players[index].y,players[index].z)<=30 and players[index].map==players[i].map and players[i].death==false and players[index].name!=players[i].name)
{
p=players[i].name+" is "+calculate_x_y_string(calculate_x_y_angle(players[index].x, players[index].y, players[i].x, players[i].y, players[index].facing))+", "+get_2d_distance(players[index].x, players[index].y, players[i].x, players[i].y)+" feet away. ";
}
}
if(p=="")
p="no player around you.";
send_reliable(players[index].peer_id, p, 2);
}
}
else if(parsed[0]=="whatnear")
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
string s;
for (uint i=0; i<items.length(); i++)
{
if (get_3d_distance(items[i].x,items[i].y,items[i].z,players[index].x,players[index].y,players[index].z)<=30 and players[index].map==items[i].map)
{
int level=1;
if(items[i].z>players[index].z)
{
level=2;
}
else if(items[i].z<players[index].z)
{
level=0;
}
else
{
level=1;
}
{
if(string_contains(items[i].name, "ammo_", 1)>-1)
{
string work=string_replace(items[i].name, "ammo_", "", false);
string[] worksplit=string_split(work, "_", false);
string final_weapon=string_replace(worksplit[0], ".", "_", true);
int final_amount=random(string_to_number(worksplit[1]), string_to_number(worksplit[2]));
s+=final_weapon+" ammunition is ";
}
else
s+=items[i].name+" is ";
}
if(level==2)
{
s+="above, ";
}
else if(level==0)
{
s+="below, ";
}
s+=calculate_x_y_string(calculate_x_y_angle(players[index].x, players[index].y, items[i].x, items[i].y, players[index].facing))+", "+get_2d_distance(players[index].x, players[index].y, items[i].x, items[i].y)+" feet away. ";
}
}
for (uint i=0; i<chests.length(); i++)
{
if (get_3d_distance(chests[i].x,chests[i].y,chests[i].z,players[index].x,players[index].y,players[index].z)<=30 and players[index].map==chests[i].map)
{
int level=1;
if(chests[i].z>players[index].z)
{
level=2;
}
else if(chests[i].z<players[index].z)
{
level=0;
}
else
{
level=1;
}
{
s+="a chest is ";
}
if(level==2)
{
s+="above, ";
}
else if(level==0)
{
s+="below, ";
}
s+=calculate_x_y_string(calculate_x_y_angle(players[index].x, players[index].y, chests[i].x, chests[i].y, players[index].facing))+", "+get_2d_distance(players[index].x, players[index].y, chests[i].x, chests[i].y)+" feet away. ";
}
}
send_reliable(players[index].peer_id, "whatnear_result "+s, 0);
}
}
else if(parsed[0]=="lobby_credits")
{
int li=get_lobby_client_index(e.peer_id);
if(li>-1)
{
string cpath="accounts/"+string_to_lower_case(lobby_clients[li].name)+".dat";
int creds=0;
if(file_exists(cpath))
{
savedata acct(cpath, ACCOUNT_SECRET);
acct.load();
creds=int(acct.readn("credits"));
}
send_reliable(e.peer_id, "lobby_credits "+creds, 0);
}
}
else if(parsed[0]=="use_c4")
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
spawn_c4(players[index].x,players[index].y,players[index].z,players[index].map,players[index].name);
send_reliable(players[index].peer_id, "give c4 -1", 0);
play("semtexplace",players[index].x,players[index].y,players[index].z,players[index].map);
send_reliable(players[index].peer_id, "C4 placed. "+count_player_c4(players[index].name)+" charges active.", 2);
}
}
else if(parsed[0]=="hypercomp" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1 and players[index].has_hypercomp)
{
if(parsed[1]=="bunker_status")
{
string s="";
for(uint b=0; b<bunkers.length(); b++)
{
if(bunkers[b].owner==players[index].name)
{
s+=bunkers[b].name+" at "+bunkers[b].x+", "+bunkers[b].y+", "+bunkers[b].z+": ";
bool found_player=false;
for(uint p=0; p<players.length(); p++)
{
if(p==uint(index)) continue;
if(players[p].map==bunkers[b].map and players[p].death==false and get_3d_distance(players[p].x,players[p].y,players[p].z,bunkers[b].x,bunkers[b].y,bunkers[b].z)<=30)
{
int dist=get_2d_distance(players[index].x,players[index].y,players[p].x,players[p].y);
s+=players[p].name+" ("+dist+" meters from you), ";
found_player=true;
}
}
if(!found_player) s+="no intruders detected. ";
else s=string_replace(s, ", "+bunkers[b].name, ". "+bunkers[b].name, false);
}
}
if(s=="") s="You don't own any bunkers.";
send_reliable(players[index].peer_id, s, 2);
}
else if(parsed[1]=="c4_count")
{
int c=count_player_c4(players[index].name);
send_reliable(players[index].peer_id, "hypercomp_c4 "+c, 0);
}
else if(parsed[1]=="detonate_c4" and parsed.length()>2)
{
int count=string_to_number(parsed[2]);
int available=count_player_c4(players[index].name);
if(count<1) count=1;
if(count>available) count=available;
if(available>0)
{
detonate_c4(players[index].name, count);
send_reliable(players[index].peer_id, count+" C4 charges detonated.", 2);
}
else
send_reliable(players[index].peer_id, "No C4 charges placed.", 2);
}
else if(parsed[1]=="query_bunkers")
{
init_player_bunker_arrays(index);
string s="hypercomp_bunkers ";
bool first=true;
for(uint b=0; b<bunkers.length(); b++)
{
if(bunkers[b].owner==players[index].name)
{
if(!first) s+=",";
string mon_str=(players[index].bunker_monitor[b] ? "1" : "0");
string alm_str=(bunker_alarm_active[b] ? "1" : "0");
s+=""+b+"|"+bunkers[b].name+"|"+bunkers[b].x+"|"+bunkers[b].y+"|"+bunkers[b].z+"|"+mon_str+"|"+alm_str;
first=false;
}
}
if(first) s+="none";
send_reliable(players[index].peer_id, s, 0);
}
else if(parsed[1]=="toggle_monitor" and parsed.length()>2)
{
init_player_bunker_arrays(index);
int bi=string_to_number(parsed[2]);
if(bi>=0 and bi<int(bunkers.length()) and bunkers[bi].owner==players[index].name)
{
players[index].bunker_monitor[bi]=!players[index].bunker_monitor[bi];
if(players[index].bunker_monitor[bi])
send_reliable(players[index].peer_id, "Monitor activated for "+bunkers[bi].name+".", 2);
else
send_reliable(players[index].peer_id, "Monitor deactivated for "+bunkers[bi].name+".", 2);
}
}
else if(parsed[1]=="toggle_alarm" and parsed.length()>2)
{
int bi=string_to_number(parsed[2]);
if(bi>=0 and bi<int(bunkers.length()) and bunkers[bi].owner==players[index].name)
{
bunker_alarm_active[bi]=!bunker_alarm_active[bi];
bunker_alarm_timers[bi].restart();
if(bunker_alarm_active[bi])
send_reliable(players[index].peer_id, "Alarm activated in "+bunkers[bi].name+".", 2);
else
send_reliable(players[index].peer_id, "Alarm deactivated in "+bunkers[bi].name+".", 2);
}
}
}
}
else if(parsed[0]=="turn2" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
players[index].turn=string_to_number(parsed[1]);
}
}
else if(parsed[0]=="turn" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
players[index].facing=string_to_number(parsed[1]);
}
else if(parsed[0]=="spawn_wall" and parsed.length()>4)
 {
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
string map=parsed[4];
send_reliable(0, "wall_spawned "+x+" "+y+" "+z+" "+map, 0);
spawn_wall(x,y,z,z+10,map,1000);
}
else if(parsed[0]=="spawn_ladder" and parsed.length()>4)
 {
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
string map=parsed[4];
send_reliable(0, "ladder_spawned "+x+" "+y+" "+z+" "+map, 0);
spawn_ladder(x,y,z,z+10,map,1000);
}
else if(parsed[0]=="heal" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
int heal_amount=string_to_number(parsed[1]);
if(heal_amount>0 and heal_amount<=2000)
players[index].health+=heal_amount;
}
}
else if(parsed[0]=="attach" and parsed.length()>2)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
string attachment=parsed[1];
string wname=parsed[2];
if(string_contains(attachment, "suppressor", 1)>-1)
{
bool already=false;
for(uint s=0; s<players[index].suppressed_weapons.length(); s++)
{
if(players[index].suppressed_weapons[s]==wname){already=true;break;}
}
if(!already)
players[index].suppressed_weapons.insert_last(wname);
play("supressoron", players[index].x, players[index].y, players[index].z, players[index].map, -1, true, false, 5);
}
}
}
else if(parsed[0]=="detach" and parsed.length()>2)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
string attachment=parsed[1];
string wname=parsed[2];
if(string_contains(attachment, "suppressor", 1)>-1)
{
for(uint s=0; s<players[index].suppressed_weapons.length(); s++)
{
if(players[index].suppressed_weapons[s]==wname)
{
players[index].suppressed_weapons.remove_at(s);
break;
}
}
play("supressoroff", players[index].x, players[index].y, players[index].z, players[index].map, -1, true, false, 5);
}
}
}
else if(parsed[0]=="fire" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
if (players[index].fire_timer.elapsed<50)
{
players[index].rapid_fire_warnings++;
if (players[index].rapid_fire_warnings>10)
{
send_reliable(0, players[index].name+" was removed by anti-cheat.", 2);
send_reliable(0, "offline "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].name+" "+players[index].map, 0);
players.remove_at(index);
}
}
else
{
if (players[index].rapid_fire_warnings>0) players[index].rapid_fire_warnings--;
}
players[index].fire_timer.restart();
string wname=parsed[1];
string fire_mode_str="";
if (parsed.length()>2) fire_mode_str=parsed[2];
spawn_weapon(players[index].x, players[index].y, players[index].z, players[index].facing,players[index].turn, wname, players[index].name, players[index].map, fire_mode_str);
bool suppressed=false;
for(uint s=0; s<players[index].suppressed_weapons.length(); s++)
{
if(players[index].suppressed_weapons[s]==wname){suppressed=true;break;}
}
if(suppressed)
{
play(wname+"supressedfire"+random(1, 3), players[index].x, players[index].y, players[index].z, players[index].map, index);
send_reliable(0, "distsound "+wname+"supresseddist.ogg "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].map, 5);
}
else
{
play(wname+"fire"+random(1, 3), players[index].x, players[index].y, players[index].z, players[index].map, index);
send_reliable(0, "distsound "+wname+"dist.ogg "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].map, 5);
} 
}
}
else if(parsed[0]=="player_remove")
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
players.remove_at(index);
}
}
else if(parsed[0]=="builder_read" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1 and players[index].dev==true)
{
string mname=parsed[1];
string path=find_map_path(mname);
if(path!="")
{
file mf;
mf.open(path, "rb");
string data=mf.read();
mf.close();
send_reliable(players[index].peer_id, "builder_data "+data, 0);
}
else
send_reliable(players[index].peer_id, "Map file not found.", 2);
}
}
else if(parsed[0]=="builder_append" and parsed.length()>2)
{
int index=get_player_index(e.peer_id);
if(index>-1 and players[index].dev==true)
{
string mname=parsed[1];
string line=string_replace(get_event_message(), "builder_append "+mname+" ", "", false);
string path=find_map_path(mname);
if(path!="")
{
file mf;
mf.open(path, "rb");
string data=mf.read();
mf.close();
data+="\r\n"+line;
file wf;
wf.open(path, "wb");
wf.write(data);
wf.close();
reload_map(mname);
send_reliable(players[index].peer_id, "Line added and map reloaded.", 2);
}
}
}
else if(parsed[0]=="builder_delete_line" and parsed.length()>2)
{
int index=get_player_index(e.peer_id);
if(index>-1 and players[index].dev==true)
{
string mname=parsed[1];
int line_idx=string_to_number(parsed[2]);
string path=find_map_path(mname);
if(path!="")
{
file mf;
mf.open(path, "rb");
string[] lines=delinear(mf.read());
mf.close();
if(line_idx>=0 and line_idx<int(lines.length()))
{
lines.remove_at(line_idx);
file wf;
wf.open(path, "wb");
wf.write(linear(lines));
wf.close();
reload_map(mname);
send_reliable(players[index].peer_id, "Line deleted and map reloaded.", 2);
}
}
}
}
else if(parsed[0]=="builder_edit_line" and parsed.length()>3)
{
int index=get_player_index(e.peer_id);
if(index>-1 and players[index].dev==true)
{
string mname=parsed[1];
int line_idx=string_to_number(parsed[2]);
string new_line=string_replace(get_event_message(), "builder_edit_line "+mname+" "+parsed[2]+" ", "", false);
string path=find_map_path(mname);
if(path!="")
{
file mf;
mf.open(path, "rb");
string[] lines=delinear(mf.read());
mf.close();
if(line_idx>=0 and line_idx<int(lines.length()))
{
lines[line_idx]=new_line;
file wf;
wf.open(path, "wb");
wf.write(linear(lines));
wf.close();
reload_map(mname);
send_reliable(players[index].peer_id, "Line edited and map reloaded.", 2);
}
}
}
}
else if(parsed[0]=="builder_write_map" and parsed.length()>2)
{
int index=get_player_index(e.peer_id);
if(index>-1 and players[index].dev==true)
{
string mname=parsed[1];
string data=string_replace(get_event_message(), "builder_write_map "+mname+" ", "", false);
string path=find_map_path(mname);
if(path=="") path="content/maps/battlegrounds/"+mname+".map";
file wf;
wf.open(path, "wb");
wf.write(data);
wf.close();
reload_map(mname);
send_reliable(players[index].peer_id, "Map saved and reloaded.", 2);
}
}
else if(parsed[0]=="builder_delete_map" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1 and players[index].dev==true)
{
string mname=parsed[1];
string path=find_map_path(mname);
if(path!="")
{
file_delete(path);
int mi=get_map_index(mname);
if(mi>=0) maps.remove_at(mi);
send_reliable(players[index].peer_id, "Map deleted.", 2);
}
}
}
else if(parsed[0]=="move_to" and parsed.length() > 3)
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
int new_x=string_to_number(parsed[1]);
int new_y=string_to_number(parsed[2]);
int new_z=string_to_number(parsed[3]);
int dx=new_x-players[index].last_x;
int dy=new_y-players[index].last_y;
if (dx<0) dx=-dx;
if (dy<0) dy=-dy;
int dist=dx+dy;
int elapsed=players[index].move_timer.elapsed;
if (dist>15 and elapsed<200)
{
players[index].teleport_warnings++;
if (players[index].teleport_warnings>5)
{
send_reliable(0, players[index].name+" was removed by anti-cheat.", 2);
send_reliable(0, "offline "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].name+" "+players[index].map, 0);
players.remove_at(index);
}
}
else
{
if (players[index].teleport_warnings>0) players[index].teleport_warnings--;
string name=players[index].name;
players[index].x=new_x;
players[index].y=new_y;
players[index].z=new_z;
players[index].last_x=new_x;
players[index].last_y=new_y;
players[index].last_z=new_z;
players[index].move_timer.restart();
if(get_tile_at(players[index].x, players[index].y, players[index].z, players[index].map)!="")
send_reliable(0, "step "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].map+" "+name, 0, index);
}
}
}
}
}
}
void send_reliable_x(uint peer, string mess, uint channel, int tx, int ty, int tz)
{
int x=tx;
int y=ty;
int z=tz;
mess=string_encrypt(mess, "masonandsamare2bitches");
for(uint i=0; i<players.length(); i++)
{
if(players[i].x > x-35 and players[i].x < x+35 and players[i].y > y-35 and players[i].y < y+35 and players[i].z > z-35 and players[i].z < z+35)
{
n.send_reliable(players[i].peer_id, mess, channel);
}
}
}
void send_unreliable_x(uint peer, string mess, uint channel, int tx, int ty, int tz)
{
int x=tx;
int y=ty;
int z=tz;
mess=string_encrypt(mess, "masonandsamare2bitches");
for(uint i=0; i<players.length(); i++)
{
if(players[i].x > x-35 and players[i].x < x+35 and players[i].y > y-35 and players[i].y < y+35 and players[i].z > z-35 and players[i].z < z+35)
{
n.send_unreliable(players[i].peer_id, mess, channel);
}
}
}
void send_reliable(uint peer, string mess, uint channel, int index=-1)
{
mess=string_encrypt(mess, "masonandsamare2bitches");
if(index>-1)
{
int x=players[index].x;
int y=players[index].y;
int z=players[index].z;
for(uint i=0; i<players.length(); i++)
{
if(players[i].x > x-35 and players[i].x < x+35 and players[i].y > y-35 and players[i].y < y+35 and players[i].z > z-35 and players[i].z < z+35 and players[i].map==players[index].map)
{
n.send_reliable(players[i].peer_id, mess, channel);
}
}
}
else
{
n.send_reliable(peer, mess, channel);
}
}
void send_unreliable(uint peer, string mess, uint channel, int index=-1)
{
mess=string_encrypt(mess, "masonandsamare2bitches");
if(index>-1)
{
int x=players[index].x;
int y=players[index].y;
int z=players[index].z;
for(uint i=0; i<players.length(); i++)
{
if(players[i].x > x-35 and players[i].x < x+35 and players[i].y > y-35 and players[i].y < y+35 and players[i].z > z-35 and players[i].z < z+35 and players[i].map==players[index].map)
{
n.send_unreliable(players[i].peer_id, mess, channel);
}
}
}
else
{
n.send_unreliable(peer, mess, channel);
}
}
void send_reliable_id(uint peer, string mess, uint channel)
{
mess=string_encrypt(mess, "masonandsamare2bitches");
n.send_reliable(peer, mess, channel);
}
string get_event_message()
{
string r=e.message;
if(r=="")
{
return "";
}
r=string_decrypt(r, "_';'_clickclick!");
return r;
}
bool is_dev_account(string uname)
{
for(uint i=0; i<dev_list.length(); i++)
{
if(string_to_lower_case(uname)==dev_list[i]) return true;
}
return false;
}
void login(string user, uint peer_id, double version,string comp,bool from_source=false)
{
file f;
if(version<minversion)
{
send_reliable(peer_id,"ver", 0);
return;
}
if(from_source and !is_dev_account(user))
{
send_reliable(peer_id, "dev_denied", 0);
return;
}
for(uint i=0; i<players.length(); i++)
{
if(string_to_lower_case(players[i].name)==string_to_lower_case(user))
{
send_reliable(peer_id, "alreadyin", 0);
return;
}
}
if(file_exists("banned.txt"))
{
f.open("banned.txt", "rb");
string banlist=f.read();
if(string_contains(banlist,comp,1)>-1)
{
send_reliable(peer_id, "banned", 0);
}
f.close();
}
send_reliable(peer_id, "loggedin123", 0);
}
int get_player_index(uint id)
{
for(uint i=0; i<players.length(); i++)
{
if(players[i].peer_id==id)
{
return i;
}
}
return -1;
}
int get_player_index_from(string name)
{
for(uint i=0; i<players.length(); i++)
{
if(players[i].name==name)
{
return i;
}
}
return -1;
}
void play(string sound, int x, int y, int z, string map, int index=-1, bool onlynear=true, bool reliable=true, int channel=5)
{
if(onlynear==true)
{
if(index>-1)
{
if(reliable)
send_reliable(0, sound+" "+x+" "+y+" "+z+" "+map, channel, index);
else
send_unreliable(0, sound+" "+x+" "+y+" "+z+" "+map, channel, index);
}
else
{
if(reliable)
send_reliable_x(0, sound+" "+x+" "+y+" "+z+" "+map, channel, x, y, z);
else
send_unreliable_x(0, sound+" "+x+" "+y+" "+z+" "+map, channel, x, y, z);
}
}
else
send_reliable(0, sound+" "+x+" "+y+" "+z+" "+map, channel);
}
string killmsg(string player1, string player2, string playermap, string playerzone)
{
string temp=killmsgs[random(0,killmsgs.length()-1)];
temp=string_replace(temp,"%1",player1,true);
temp=string_replace(temp,"%2",player2,true);
temp=string_replace(temp,"%3",playermap,true);
temp=string_replace(temp,"%4",playerzone,true);
return temp;
}