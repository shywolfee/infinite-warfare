void mortarloop()
{
for (uint i=0; i<mortarbombs.length(); i++)
{
if (mortarbombs[i].bombtimer.elapsed>=1)
{
mortarbombs[i].bombtimer.restart();
play("120mm_mortarexplode",mortarbombs[i].x,mortarbombs[i].y,mortarbombs[i].z,mortarbombs[i].map);
send_reliable(0,"distsound 120mm_mortarexplodedist.ogg "+mortarbombs[i].x+" "+mortarbombs[i].y+" "+mortarbombs[i].z+" "+mortarbombs[i].map,0);
for (uint i2=0; i2<players.length(); i2++)
{
if (get_3d_distance(mortarbombs[i].x,mortarbombs[i].y,mortarbombs[i].z,players[i2].x,players[i2].y,players[i2].z)<=20 and players[i2].map==mortarbombs[i].map and players[i2].death==false and players[i2].in_plane==false)
{
players[i2].hitby=mortarbombs[i].owner+"'s 120mm_mortar";
players[i2].health-=random(1000,2000);
play("120mm_mortarhit",players[i2].x,players[i2].y,players[i2].z,players[i2].map);
}
}
for (uint i2=0; i2<planes.length(); i2++)
{
if (get_3d_distance(mortarbombs[i].x,mortarbombs[i].y,mortarbombs[i].z,planes[i2].x,planes[i2].y,planes[i2].z)<=20 and planes[i2].map==mortarbombs[i].map)
{
planes[i2].health-=random(1000,2000);
play("duoplanebombhit",planes[i2].x,planes[i2].y,planes[i2].z,planes[i2].map);
}
}

}
mortarbombs.remove_at(i);
return;
}
}
bunkerbomb@[] bunkerbombs(0);
class bunkerbomb
{
timer bombtimer;
int x;
int y;
int z;
string map;
string  owner;
bunkerbomb(int bx,int by,int bz,string bmap,string bowner)
{
x=bx;
y=by;
z=bz;
map=bmap;
owner=bowner;
}
}
void bunkerbombloop()
{
for (uint i=0; i<bunkerbombs.length(); i++)
{
if (bunkerbombs[i].bombtimer.elapsed>=14000)
{
play("bunkerbombexplode",bunkerbombs[i].x,bunkerbombs[i].y,bunkerbombs[i].z,bunkerbombs[i].map);
send_reliable(0,"distsound bunkerbombdist.ogg "+bunkerbombs[i].x+" "+bunkerbombs[i].y+" "+bunkerbombs[i].z+" "+bunkerbombs[i].map,0);
for (uint i2=0; i2<players.length(); i2++)
{
if (get_3d_distance(bunkerbombs[i].x,bunkerbombs[i].y,bunkerbombs[i].z,players[i2].x,players[i2].y,players[i2].z)<=150 and players[i2].map==bunkerbombs[i].map and players[i2].death==false and players[i2].in_plane==false)

{
int index=get_player_index_from(bunkerbombs[i].owner);
if(index>-1)
{
send_reliable(players[index].peer_id, "play_s weaponping.ogg", 0);
}

players[i2].hitby=bunkerbombs[i].owner+"'s bunkerbomb";
players[i2].health-=random(11000,20000);
play("bunkerbombhit",players[i2].x,players[i2].y,players[i2].z,players[i2].map);
}
for (uint i2=0; i2<planes.length(); i2++)
{
if (get_3d_distance(bunkerbombs[i].x,bunkerbombs[i].y,bunkerbombs[i].z,planes[i2].x,planes[i2].y,planes[i2].z)<=20 and planes[i2].map==bunkerbombs[i].map)
{
planes[i2].health-=random(10000,20000);
play("duoplanebombhit",planes[i2].x,planes[i2].y,planes[i2].z,planes[i2].map);
}
}
}

bunkerbombs.remove_at(i);
return;
}
}
}
void spawn_bunkerbomb(int x,int y, int z, string map,string owner)
{
bunkerbomb bomb1(x,y,z,map,owner);
bunkerbombs.insert_last(bomb1);
}
