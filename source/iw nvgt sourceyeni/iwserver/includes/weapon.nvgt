range=15;
mindammage=750;
maxdammage=800;
spread=2;
gravity=0.025;
}
else if(type=="famas_f1_assault_rifle")
{
speedtime=5;
range=50;
mindammage=2000;
maxdammage=3000;
spread=3;
gravity=0.018;
}
else if(type=="trector_plow")
{
speedtime=5;
range=12;
mindammage=3000;
maxdammage=7000;
spread=2;
gravity=0.0;
}
else if(type=="hayvork")
{
speedtime=5;
range=10;
mindammage=2000;
maxdammage=3000;
spread=2;
gravity=0.0;
}

else if(type=="hk_g36")
{
speedtime=5;
range=35;
mindammage=250;
maxdammage=1450;
spread=2;
gravity=0.02;
}
else if(type=="benelli_m4_shotgun")
{
speedtime=5;
range=20;
