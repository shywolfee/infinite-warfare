class wpn_stats
{
string id;
int firetime;
int walktime;
bool melee;
}
wpn_stats@[] wpn_cache(0);

void load_all_weapons()
{
string wpn_dir="iwserver/content/weapons";
if (!directory_exists(wpn_dir))
wpn_dir="content/weapons";
string[] files=find_files(wpn_dir+"/*.wpn");
for (uint i=0; i<files.length(); i++)
{
string fname=files[i];
// Extract weapon id from filename (remove .wpn extension)
string wid=string_left(fname, fname.length()-4);
// Read the file
file f;
f.open(wpn_dir+"/"+fname, "rb");
string content=f.read();
f.close();
// Normalize line endings: replace \r\n with \n, then split on \n
content=string_replace(content, "\r\n", "\n", true);
string[] lines=string_split(content, "\n", true);
// Parse key=value pairs into a dictionary
dictionary props;
for (uint j=0; j<lines.length(); j++)
{
int eq_pos=string_contains(lines[j], "=", 1);
if (eq_pos<0) continue;
string k=string_left(lines[j], eq_pos);
string val=string_replace(lines[j], k+"=", "", false);
props.set(k, val);
}
// Build wpn_stats entry
wpn_stats ws;
ws.id=wid;
string tmp;
if (props.get("firetime", tmp)) ws.firetime=string_to_number(tmp);
else ws.firetime=500;
if (props.get("walktime", tmp)) ws.walktime=string_to_number(tmp);
else ws.walktime=200;
string melee_str;
if (props.get("melee", melee_str) and melee_str=="true") ws.melee=true;
else ws.melee=false;
wpn_cache.insert_last(ws);
// Register gun for non-melee weapons that have ammo fields
string ammo_type, feed_device, capacity_str, reserve_item, reserve_label, is_mag_str, starting_reserve_str, reload_ms_str;
if (!ws.melee and props.get("ammo_type", ammo_type) and props.get("feed_device", feed_device) and props.get("capacity", capacity_str) and props.get("reserve_item", reserve_item) and props.get("reserve_label", reserve_label) and props.get("is_magazine", is_mag_str) and props.get("starting_reserve", starting_reserve_str) and props.get("reload_ms", reload_ms_str))
{
int capacity=string_to_number(capacity_str);
bool is_magazine=(is_mag_str=="true");
int starting_reserve=string_to_number(starting_reserve_str);
int reload_ms=string_to_number(reload_ms_str);
register_gun(wid, ammo_type, feed_device, capacity, reserve_item, reserve_label, is_magazine, starting_reserve, reload_ms);
// Set ammo display if not default "rounds"
string ammo_display;
if (props.get("ammo_display", ammo_display) and ammo_display!="rounds")
set_ammo_display(wid, ammo_display);
}
// Register fire modes
string fire_modes_str;
if (props.get("fire_modes", fire_modes_str))
{
string[] mode_parts=string_split(fire_modes_str, ",", true);
if (mode_parts.length()>1)
{
int[] modes(mode_parts.length());
for (uint m=0; m<mode_parts.length(); m++)
{
if (mode_parts[m]=="semi") modes[m]=FIREMODE_SEMI;
else if (mode_parts[m]=="burst") modes[m]=FIREMODE_BURST;
else if (mode_parts[m]=="auto") modes[m]=FIREMODE_AUTO;
}
register_fire_modes(wid, modes);
}
}
}
}

