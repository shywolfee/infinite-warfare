send_unreliable(players[index].peer_id, "weapon_set trector_plow", 0);
}
if(parsed[1]=="smoke_bomb")
{
if(players[index].smokebombtimer.elapsed>60000)
{
players[index].smokebombtimer.restart();
spawn_smokebomb(players[index].x,players[index].y,players[index].z,players[index].map,players[index].name);
