send_reliable(players[index].peer_id, "give fake_item 5", 0);
send_reliable(players[index].peer_id, "give ultra_health_potion 1", 0);
send_unreliable(players[index].peer_id, "ammogive glock17 100", 0);
send_unreliable(players[index].peer_id, "ammogive hk_g36 100", 0);
send_unreliable(players[index].peer_id, "ammogive magnum_revolver 100", 0);
send_unreliable(players[index].peer_id, "ammogive AK47 80", 0);
send_unreliable(players[index].peer_id, "ammogive sg08_sniper_rifle 30", 0);
}
if(parsed[1]=="frag_grenade")
{
if(players[index].fraggrenadetimer.elapsed>5000)
{
spawn_fraggrenade(players[index].x,players[index].y,players[index].z,players[index].facing,players[index].map,players[index].name);
