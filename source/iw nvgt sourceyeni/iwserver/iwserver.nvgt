{
s=players.length()+" players online. ";
for (uint i=0; i<players.length(); i++)
{
if (i==players.length()-1)
s+="and "+players[i].name+" with "+players[i].kills+" kills. ";
else
s+=players[i].name+"  with "+players[i].kills+" kills. ";
}
}
else
s="You are alone";
send_reliable(players[index].peer_id, s, 2);
}
}
else if(parsed[0]=="nearplayers")
{
string p;
int index=get_player_index(e.peer_id);
if(index > -1)
{
for (uint i=0; i<players.length(); i++)
{
if (get_3d_distance(players[i].x,players[i].y,players[i].z,players[index].x,players[index].y,players[index].z)<=30 and players[index].map==players[i].map and players[i].death==false and players[index].name!=players[i].name)
{
p=players[i].name+" is "+calculate_x_y_string(calculate_x_y_angle(players[index].x, players[index].y, players[i].x, players[i].y, players[index].facing))+", "+get_2d_distance(players[index].x, players[index].y, players[i].x, players[i].y)+" feet away. ";
}
}
if(p=="")
p="no player around you.";
send_reliable(players[index].peer_id, p, 2);
}
}
else if(parsed[0]=="whatnear")
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
string s;
for (uint i=0; i<items.length(); i++)
{
if (get_3d_distance(items[i].x,items[i].y,items[i].z,players[index].x,players[index].y,players[index].z)<=30 and players[index].map==items[i].map)
{
int level=1;
if(items[i].z>players[index].z)
{
level=2;
}
else if(items[i].z<players[index].z)
{
level=0;
}
else
{
level=1;
}
{
if(string_contains(items[i].name, "ammo_", 1)>-1)
{
string work=string_replace(items[i].name, "ammo_", "", false);
string[] worksplit=string_split(work, "_", false);
string final_weapon=string_replace(worksplit[0], ".", "_", true);
int final_amount=random(string_to_number(worksplit[1]), string_to_number(worksplit[2]));
s+=final_weapon+" ammunition is ";
}
else
s+=items[i].name+" is ";
}
if(level==2)
{
s+="above, ";
}
else if(level==0)
{
s+="below, ";
}
s+=calculate_x_y_string(calculate_x_y_angle(players[index].x, players[index].y, items[i].x, items[i].y, players[index].facing))+", "+get_2d_distance(players[index].x, players[index].y, items[i].x, items[i].y)+" feet away. ";
}
}
for (uint i=0; i<chests.length(); i++)
{
if (get_3d_distance(chests[i].x,chests[i].y,chests[i].z,players[index].x,players[index].y,players[index].z)<=30 and players[index].map==chests[i].map)
{
int level=1;
if(chests[i].z>players[index].z)
{
level=2;
}
else if(chests[i].z<players[index].z)
{
level=0;
}
else
{
level=1;
}
{
s+="a chest is ";
}
if(level==2)
{
s+="above, ";
}
else if(level==0)
{
s+="below, ";
}
s+=calculate_x_y_string(calculate_x_y_angle(players[index].x, players[index].y, chests[i].x, chests[i].y, players[index].facing))+", "+get_2d_distance(players[index].x, players[index].y, chests[i].x, chests[i].y)+" feet away. ";
}
}
if (s=="")
s="Nothing near you";
send_reliable(players[index].peer_id, s, 2);
}
}
else if(parsed[0]=="turn2" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
players[index].turn=string_to_number(parsed[1]);
}
}
else if(parsed[0]=="turn" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
players[index].facing=string_to_number(parsed[1]);
}
else if(parsed[0]=="spawn_wall" and parsed.length()>4)
 {
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
string map=parsed[4];
send_reliable(0, "wall_spawned "+x+" "+y+" "+z+" "+map, 0);
spawn_wall(x,y,z,z+10,map,1000);
}
else if(parsed[0]=="spawn_ladder" and parsed.length()>4)
 {
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
string map=parsed[4];
send_reliable(0, "ladder_spawned "+x+" "+y+" "+z+" "+map, 0);
spawn_ladder(x,y,z,z+10,map,1000);
}
else if(parsed[0]=="heal" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
int heal_amount=string_to_number(parsed[1]);
if(heal_amount>0 and heal_amount<=2000)
players[index].health+=heal_amount;
}
}
else if(parsed[0]=="fire" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
string wname=parsed[1];
spawn_weapon(players[index].x, players[index].y, players[index].z, players[index].facing,players[index].turn, wname, players[index].name, players[index].map);
if(players[index].hk_g_supressor==true and wname=="hk_g36" or players[index].magnum_revolver_supressor==true and wname=="magnum_revolver" or players[index].taurus_supressor==true and wname=="taurus_model66_revolver" or players[index].beretta_supressor==true and wname=="beretta92fs_pistol" or players[index].magnum_revolver_supressor==true and wname=="magnum_revolver")
{
play(wname+"supressedfire"+random(1, 3), players[index].x, players[index].y, players[index].z, players[index].map, index);
}
else 
play(wname+"fire"+random(1, 3), players[index].x, players[index].y, players[index].z, players[index].map, index);
if(players[index].hk_g_supressor==true and wname=="hk_g36" or players[index].magnum_revolver_supressor==true and wname=="magnum_revolver" or players[index].taurus_supressor==true and wname=="taurus_model66_revolver" or players[index].beretta_supressor==true and wname=="beretta92fs_pistol" or players[index].magnum_revolver_supressor==true and wname=="magnum_revolver")
{
send_reliable(0, "distsound "+wname+"supresseddist.ogg "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].map, 5);
}
else
send_reliable(0, "distsound "+wname+"dist.ogg "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].map, 5); 
}
}
else if(parsed[0]=="player_remove")
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
players.remove_at(index);
}
}
else if(parsed[0]=="move_to" and parsed.length() > 3)
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
string name=players[index].name;
players[index].x=string_to_number(parsed[1]);
players[index].y=string_to_number(parsed[2]);
players[index].z=string_to_number(parsed[3]);
if(get_tile_at(players[index].x, players[index].y, players[index].z, players[index].map)!="")
send_reliable(0, "step "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].map+" "+name, 0, index);
}
}
}
}
}
void send_reliable_x(uint peer, string mess, uint channel, int tx, int ty, int tz)
{
int x=tx;
int y=ty;
int z=tz;
mess=string_encrypt(mess, "masonandsamare2bitches");
for(uint i=0; i<players.length(); i++)
{
if(players[i].x > x-35 and players[i].x < x+35 and players[i].y > y-35 and players[i].y < y+35 and players[i].z > z-35 and players[i].z < z+35)
{
n.send_reliable(players[i].peer_id, mess, channel);
}
}
}
void send_unreliable_x(uint peer, string mess, uint channel, int tx, int ty, int tz)
{
int x=tx;
int y=ty;
int z=tz;
mess=string_encrypt(mess, "masonandsamare2bitches");
for(uint i=0; i<players.length(); i++)
{
if(players[i].x > x-35 and players[i].x < x+35 and players[i].y > y-35 and players[i].y < y+35 and players[i].z > z-35 and players[i].z < z+35)
{
n.send_unreliable(players[i].peer_id, mess, channel);
}
}
}
void send_reliable(uint peer, string mess, uint channel, int index=-1)
{
mess=string_encrypt(mess, "masonandsamare2bitches");
if(index>-1)
{
int x=players[index].x;
int y=players[index].y;
int z=players[index].z;
for(uint i=0; i<players.length(); i++)
{
if(players[i].x > x-35 and players[i].x < x+35 and players[i].y > y-35 and players[i].y < y+35 and players[i].z > z-35 and players[i].z < z+35 and players[i].map==players[index].map)
{
n.send_reliable(players[i].peer_id, mess, channel);
}
}
}
else
{
n.send_reliable(peer, mess, channel);
}
}
void send_unreliable(uint peer, string mess, uint channel, int index=-1)
{
mess=string_encrypt(mess, "masonandsamare2bitches");
if(index>-1)
{
int x=players[index].x;
int y=players[index].y;
int z=players[index].z;
for(uint i=0; i<players.length(); i++)
{
if(players[i].x > x-35 and players[i].x < x+35 and players[i].y > y-35 and players[i].y < y+35 and players[i].z > z-35 and players[i].z < z+35 and players[i].map==players[index].map)
{
n.send_unreliable(players[i].peer_id, mess, channel);
}
}
}
else
{
n.send_unreliable(peer, mess, channel);
}
}
void send_reliable_id(uint peer, string mess, uint channel)
{
mess=string_encrypt(mess, "masonandsamare2bitches");
n.send_reliable(peer, mess, channel);
}
string get_event_message()
{
string r=e.message;
if(r=="")
{
return "";
}
r=string_decrypt(r, "_';'_clickclick!");
return r;
}
void mapupdate(string map)
{
file f;
f.open("map/"+map+".map", "rb");
string mdata=f.read();
f.close();
for(uint i=0; i<players.length(); i++)
{
if(players[i].map!=map) players[i].map=map;
if(players[i].map==map)
{
send_reliable(players[i].peer_id, "mapdata "+mdata+"\r\n", 0);
send_reliable(players[i].peer_id, "setcoords 0 0 0", 0);
}
}
}
void login(string user, uint peer_id, double version,string comp)
{
file f;
if(version<minversion)
{
send_reliable(peer_id,"ver", 0);
return;
}
for(uint i=0; i<players.length(); i++)
{
if(string_to_lower_case(players[i].name)==string_to_lower_case(user))
{
send_reliable(peer_id, "alreadyin", 0);
return;
}
}
if(file_exists("banned.txt"))
{
f.open("banned.txt", "rb");
string banlist=f.read();
if(string_contains(banlist,comp,1)>-1)
{
send_reliable(peer_id, "banned", 0);
}
f.close();
}
f.open("map/"+current_map+".map", "rb");
send_reliable(peer_id, "mapdata "+f.read(), 0);
f.close();
send_reliable(peer_id, "facing 0", 0);
send_reliable(peer_id, "x "+random(0, 400), 0);
send_reliable(peer_id, "y "+random(0, 499), 0);
send_reliable(peer_id, "z 0", 0);
send_reliable(peer_id, "loggedin123", 0);
}
int get_player_index(uint id)
{
for(uint i=0; i<players.length(); i++)
{
if(players[i].peer_id==id)
{
return i;
}
}
return -1;
}
int get_player_index_from(string name)
{
for(uint i=0; i<players.length(); i++)
{
if(players[i].name==name)
{
return i;
}
}
return -1;
}
void play(string sound, int x, int y, int z, string map, int index=-1, bool onlynear=true, bool reliable=true, int channel=5)
{
if(onlynear==true)
{
if(index>-1)
{
if(reliable)
send_reliable(0, sound+" "+x+" "+y+" "+z+" "+map, channel, index);
else
send_unreliable(0, sound+" "+x+" "+y+" "+z+" "+map, channel, index);
}
else
{
if(reliable)
send_reliable_x(0, sound+" "+x+" "+y+" "+z+" "+map, channel, x, y, z);
else
send_unreliable_x(0, sound+" "+x+" "+y+" "+z+" "+map, channel, x, y, z);
}
}
else
send_reliable(0, sound+" "+x+" "+y+" "+z+" "+map, channel);
}
string killmsg(string player1, string player2, string playermap, string playerzone)
{
string temp=killmsgs[random(0,killmsgs.length()-1)];
temp=string_replace(temp,"%1",player1,true);
temp=string_replace(temp,"%2",player2,true);
temp=string_replace(temp,"%3",playermap,true);
temp=string_replace(temp,"%4",playerzone,true);
return temp;
}