else if(wname=="laser_rifle"){base_firetime=160;base_walktime=220;}
else if(wname=="laser_sniper"){base_firetime=2500;base_walktime=800;}
else if(wname=="laser_cannon"){base_firetime=90;base_walktime=450;}
else if(wname=="flamethrower"){base_firetime=50;base_walktime=300;}
else if(wname=="chainsaw"){base_firetime=100;base_walktime=250;}
float ft_mult=get_attachment_firetime_mult(wname);
float wt_mult=get_attachment_walktime_mult(wname);
int final_firetime=int(base_firetime*ft_mult);
int final_walktime=int(base_walktime*wt_mult);
if(is_melee_weapon)
f.create_input_box("Type", "Melee", "", 0, false, true, false);
else if(gi>=0)
{
f.create_input_box("Type", "Ranged", "", 0, false, true, false);
f.create_input_box("Ammo type", gun_ammos[gi].ammo_type, "", 0, false, true, false);
f.create_input_box("Feed device", gun_ammos[gi].feed_device, "", 0, false, true, false);
f.create_input_box("Capacity", ""+gun_ammos[gi].mag_capacity, "", 0, false, true, false);
}
f.create_input_box("Fire rate", ""+final_firetime+" ms"+(ft_mult!=1.0?" (base "+base_firetime+" ms)":""), "", 0, false, true, false);
f.create_input_box("Movement speed", ""+final_walktime+" ms"+(wt_mult!=1.0?" (base "+base_walktime+" ms)":""), "", 0, false, true, false);
string[] attached=get_weapon_attachments(wname);
if(attached.length()>0)
{
int att_list=f.create_list("Attachments", 0, false);
for(uint i=0; i<attached.length(); i++)
{
int def_idx=find_attachment_def(attached[i]);
if(def_idx>=0)
{
string label=attachment_defs[def_idx].display_name+" ("+attachment_defs[def_idx].slot+")";
if(ft_mult!=1.0 or wt_mult!=1.0)
{
label+=" -";
if(attachment_defs[def_idx].firetime_mult!=1.0)
label+=" fire rate x"+attachment_defs[def_idx].firetime_mult;
if(attachment_defs[def_idx].walktime_mult!=1.0)
label+=" move speed x"+attachment_defs[def_idx].walktime_mult;
}
if(!attachment_defs[def_idx].removable) label+=" [permanent]";
f.add_list_item(att_list, label);
}
}
int remove_btn=f.create_button("Remove selected attachment", false, false);
int close_btn=f.create_button("Close", false, true);
f.focus(att_list);
while(true)
{
wait(5);
f.monitor();
if(f.is_pressed(close_btn)) return;
if(f.is_pressed(remove_btn))
{
int sel=f.get_list_position(att_list);
if(sel>=0 and sel<int(attached.length()))
{
int def_idx=find_attachment_def(attached[sel]);
if(def_idx>=0 and !attachment_defs[def_idx].removable)
{
speak("This attachment cannot be removed.");
}
else if(detach_from_weapon(attached[sel], wname))
{
give(attached[sel], 1);
apply_weapon_stats(wname);
send_reliable(0, "detach "+attached[sel]+" "+wname, 0);
speak(attachment_defs[def_idx].display_name+" removed. Returned to inventory.");
return;
}
}
}
}
}
else
{
int close_btn=f.create_button("Close", false, true);
while(true)
{
wait(5);
f.monitor();
if(f.is_pressed(close_btn)) return;
}
}
}
string[] hypercomp_fetch_bunkers()
{
string[] result;
send_reliable(0, "hypercomp query_bunkers", 0);
timer ct;
while(ct.elapsed<3000)
{
wait(5);
e=n.request();
if(e.type==event_receive)
{
string msg=get_event_message();
if(string_contains(msg, "hypercomp_bunkers ", 1)==0)
{
string data=string_replace(msg, "hypercomp_bunkers ", "", false);
if(data!="none")
result=string_split(data, ",", false);
break;
}
}
}
return result;
}
void hypercomp_menu()
{
audio_form f;
f.create_window("HyperComp", false, true);
int f_status=f.create_button("View &bunker status");
int f_monitor=f.create_button("Toggle &monitor mode");
int f_c4=f.create_button("&C4 management");
int f_alarm=f.create_button("Toggle bunker &alarm");
int f_close=f.create_button("Cl&ose", true, true);
f.focus(f_status);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(f_status))
{
send_reliable(0, "hypercomp bunker_status", 0);
}
else if(f.is_pressed(f_monitor))
{
hypercomp_monitor_menu();
}
else if(f.is_pressed(f_c4))
{
hypercomp_c4_menu();
}
else if(f.is_pressed(f_alarm))
{
hypercomp_alarm_menu();
}
else if(f.is_pressed(f_close))
return;
}
}
void hypercomp_c4_menu()
{
send_reliable(0, "hypercomp c4_count", 0);
speak("Checking C4 charges, please wait.");
int c4count=-1;
timer ct;
while(ct.elapsed<3000)
{
wait(5);
e=n.request();
if(e.type==event_receive)
{
string msg=get_event_message();
if(string_contains(msg, "hypercomp_c4 ", 1)==0)
{
c4count=string_to_number(string_replace(msg, "hypercomp_c4 ", "", false));
break;
}
}
}
if(c4count<0)
{
speak("Could not retrieve C4 data.");
return;
}
audio_form f;
f.create_window("C4 Management", false, true);
f.create_input_box("Active C4 charges", ""+c4count, "", 0, false, true, false);
int f_det=f.create_button("&Detonate");
int f_close=f.create_button("&Close", true, true);
f.focus(f_det);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(f_det))
{
if(c4count<=0)
{
speak("No C4 charges placed.");
continue;
}
audio_form d;
d.create_window("Detonate C4", false, true);
int d_count=d.create_input_box("How many to detonate (max "+c4count+")", ""+c4count, "", 0, false, false, false);
int d_go=d.create_button("&Detonate", true);
int d_cancel=d.create_button("&Cancel", false, true);
d.focus(d_count);
while(true)
{
wait(5);
d.monitor();
if(connected==true) netloop();
if(d.is_pressed(d_go))
{
string val=d.get_text(d_count);
int num=string_to_number(val);
if(num<1) num=1;
if(num>c4count) num=c4count;
send_reliable(0, "hypercomp detonate_c4 "+num, 0);
break;
}
if(d.is_pressed(d_cancel))
break;
}
return;
}
if(f.is_pressed(f_close))
return;
}
}
void hypercomp_monitor_menu()
{
speak("Fetching bunker data, please wait.");
string[] bdata=hypercomp_fetch_bunkers();
if(bdata.length()==0)
{
speak("You don't own any bunkers.");
return;
}
audio_form f;
f.create_window("Bunker Monitor", false, true);
int f_list=f.create_list("Select a bunker to toggle monitor mode", 0, false);
string[] bunker_ids;
for(uint i=0; i<bdata.length(); i++)
{
string[] parts=string_split(bdata[i], "|", false);
if(parts.length()<7) continue;
string bname=parts[1];
string mon_status=(parts[5]=="1" ? "ON" : "OFF");
f.add_list_item(f_list, bname+" at "+parts[2]+", "+parts[3]+", "+parts[4]+" - Monitor: "+mon_status);
bunker_ids.insert_last(parts[0]);
}
int f_toggle=f.create_button("&Toggle monitor");
int f_close=f.create_button("&Close", true, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(f_toggle))
{
int sel=f.get_list_position(f_list);
if(sel>=0 and sel<int(bunker_ids.length()))
{
send_reliable(0, "hypercomp toggle_monitor "+bunker_ids[sel], 0);
return;
}
}
if(f.is_pressed(f_close))
return;
}
}
void hypercomp_alarm_menu()
{
speak("Fetching bunker data, please wait.");
string[] bdata=hypercomp_fetch_bunkers();
