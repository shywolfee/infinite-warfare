t.add("status", "closed");
t.add("close_reason", reason);
t.save();
send_reliable(e.peer_id, "ticket_closed", 0);
for(uint i=0; i<players.length(); i++)
{
if(players[i].peer_id==e.peer_id) continue;
if(players[i].dev or players[i].admin)
{
send_reliable(players[i].peer_id, "play_s notify.ogg", 0);
send_reliable(players[i].peer_id, "Ticket #"+tid+" ("+t_subject+") was closed by "+closer+".", 2);
}
else if(string_to_lower_case(players[i].name)==string_to_lower_case(t_owner))
{
send_reliable(players[i].peer_id, "play_s notify.ogg", 0);
if(reason!="none")
send_reliable(players[i].peer_id, "Your ticket #"+tid+" ("+t_subject+") was closed by "+closer+". Reason: "+reason, 2);
else
send_reliable(players[i].peer_id, "Your ticket #"+tid+" ("+t_subject+") has been closed.", 2);
}
}
for(uint i=0; i<lobby_clients.length(); i++)
{
if(lobby_clients[i].peer_id==int(e.peer_id)) continue;
if(lobby_clients[i].dev or lobby_clients[i].admin)
{
send_reliable_id(lobby_clients[i].peer_id, "play_s notify.ogg", 0);
send_reliable_id(lobby_clients[i].peer_id, "Ticket #"+tid+" ("+t_subject+") was closed by "+closer+".", 2);
}
else if(string_to_lower_case(lobby_clients[i].name)==string_to_lower_case(t_owner))
{
