{
string final;
int level=1;
if(players[i].z>players[index].z)
{
level=2;
}
else if(players[i].z<players[index].z)
{
level=0;
}
else
{
level=1;
}
if(level==2)
{
final+="above, ";
}
else if(level==0)
{
final+="below, ";
}
final+=calculate_x_y_string(calculate_x_y_angle(players[index].x, players[index].y, players[i].x, players[i].y, players[index].facing))+", "+get_2d_distance(players[index].x, players[index].y, players[i].x, players[i].y)+" feet away at "+players[i].x+", "+players[i].y+", "+players[i].z+". ";
send_reliable(players[index].peer_id, final, 2);
if(players[i].death==false)
{
send_reliable(players[index].peer_id, "tracking "+players[i].x+" "+players[i].y+" "+players[i].z+" "+players[i].map, 0);
}
}
else
{
send_reliable(e.peer_id, "you can't see this player at the moment!", 0);
}
}
