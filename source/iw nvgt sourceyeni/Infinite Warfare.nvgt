}
}

// ---------------------------------------------------------------------------
// Translocator system — battery level in cells, teleport to POIs.
// ---------------------------------------------------------------------------
int translocator_cells=0;
int translocator_max_cells=10;

int get_translocator_percentage()
{
if (translocator_max_cells==0) return 0;
return (translocator_cells*100)/translocator_max_cells;
}

// Returns the number of cells required to translocate to a POI at given distance.
int cells_for_distance(double dist)
{
int tiles=int(dist);
if (tiles<1) tiles=1;
int needed=tiles/50;
if (tiles%50>0) needed++;
return needed;
}

// Sort POIs by distance from player and return sorted indices.
int[] get_sorted_poi_indices()
{
int[] indices;
double[] distances;
for (uint i=0; i<pois.length(); i++)
{
indices.insert_last(int(i));
distances.insert_last(get_poi_distance(pois[i].x, pois[i].y, pois[i].z));
}
// Simple insertion sort by distance.
for (uint i=1; i<indices.length(); i++)
{
int ki=indices[i];
double kd=distances[i];
int j=int(i)-1;
while (j>=0 and distances[j]>kd)
{
indices[j+1]=indices[j];
distances[j+1]=distances[j];
j--;
}
indices[j+1]=ki;
distances[j+1]=kd;
}
return indices;
}

void show_poi_list()
{
if (pois.length()==0)
{
speak("No points of interest on this map.");
return;
}
int[] sorted=get_sorted_poi_indices();
audio_form f;
f.create_window("Points of Interest", false, true);
int f_list=f.create_list("Points of interest", 0, false);
for (uint i=0; i<sorted.length(); i++)
{
int idx=sorted[i];
double dist=get_poi_distance(pois[idx].x, pois[idx].y, pois[idx].z);
string label=string_replace(pois[idx].name, "_", " ", true)+" ("+int(dist)+" tiles)";
f.add_list_item(f_list, label);
}
int f_close=f.create_button("&Close", true, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if (connected==true)
netloop();
if (f.is_pressed(f_close))
break;
}
}

void show_translocator_interface()
{
if (pois.length()==0)
{
speak("No points of interest to translocate to.");
return;
}
int[] sorted=get_sorted_poi_indices();
audio_form f;
f.create_window("Translocator", false, true);
// Battery level display.
string battery_text="Battery: "+translocator_cells+" cells ("+get_translocator_percentage()+"%)";
f.create_input_box("Status", battery_text, "", 0, false, true, false);
int f_list=f.create_list("Points of interest", 0, false);
for (uint i=0; i<sorted.length(); i++)
{
int idx=sorted[i];
double dist=get_poi_distance(pois[idx].x, pois[idx].y, pois[idx].z);
int needed=cells_for_distance(dist);
string label=string_replace(pois[idx].name, "_", " ", true)+" - "+int(dist)+" tiles ("+needed+" cells)";
f.add_list_item(f_list, label);
}
int f_go=f.create_button("&Translocate", true);
int f_close=f.create_button("&Close", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if (connected==true)
netloop();
if (f.is_pressed(f_go))
{
int sel=f.get_list_position(f_list);
if (sel>=0 and sel<int(sorted.length()))
{
int idx=sorted[sel];
double dist=get_poi_distance(pois[idx].x, pois[idx].y, pois[idx].z);
int needed=cells_for_distance(dist);
if (needed>translocator_cells)
{
speak("Not enough cells. Need "+needed+", have "+translocator_cells+".");
continue;
}
translocator_cells-=needed;
speak("Powering up translocator.");
// Five second power up sequence.
for (int t=5; t>=1; t--)
{
speak(t+".");
wait(1000);
}
me.x=pois[idx].x;
me.y=pois[idx].y;
me.z=pois[idx].z;
mr.x=round(me.x, 0);
mr.y=round(me.y, 0);
send_reliable(1, "move_to "+mr.x+" "+mr.y+" "+me.z, 0);
checkzone();
speak("Translocated to "+string_replace(pois[idx].name, "_", " ", true)+".");
break;
}
}
else if (f.is_pressed(f_close))
{
break;
}
}
}

void use_translocator_cell()
{
if (get_item_count("translocator")<=0)
{
speak("You don't have a translocator to insert cells into.");
return;
}
int available=get_item_count("translocator_cell");
if (available<=0)
{
speak("You don't have any translocator cells.");
return;
}
int space=translocator_max_cells-translocator_cells;
if (space<=0)
{
speak("Translocator is fully charged.");
return;
}
string input_str=af_input("How many cells to insert? (have "+available+", space for "+space+")", "", true);
if (input_str=="") return;
int amount=string_to_number(input_str);
if (amount<=0) return;
if (amount>available) amount=available;
if (amount>space) amount=space;
give("translocator_cell", -amount);
translocator_cells+=amount;
speak("Inserted "+amount+" cells. Battery: "+translocator_cells+" cells ("+get_translocator_percentage()+"%).");
}

// ---------------------------------------------------------------------------
// Repair Kit — restores a partial ammo item to full.
// ---------------------------------------------------------------------------
void use_repair_kit()
{
if (partial_items.length() == 0)
{
speak("You have no partial ammo items to repair.");
return;
}
audio_form f;
f.create_window("Repair Kit", false, true);
int f_list = f.create_list("Select a partial item to restore", 0, false);
for (uint i = 0; i < partial_items.length(); i++)
{
string base_name = string_replace(partial_items[i].base_item, "_", " ", true);
int pct = get_ammo_percentage(partial_items[i].remaining, partial_items[i].max_capacity);
f.add_list_item(f_list, base_name + " (" + pct + "%)");
}
int f_repair = f.create_button("&Repair", true);
int f_close = f.create_button("&Close", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if (connected == true)
netloop();
if (f.is_pressed(f_repair))
{
int sel = f.get_list_position(f_list);
if (sel >= 0 and sel < int(partial_items.length()))
{
string base = partial_items[sel].base_item;
remove_partial(sel);
give(base, 1);
give("repair_kit", -1);
speak("Repaired. You now have a full " + string_replace(base, "_", " ", true) + ".");
}
break;
}
else if (f.is_pressed(f_close))
{
break;
}
}
}

// ---------------------------------------------------------------------------
// Waypoint Marker — save a position, then track back to it.
// ---------------------------------------------------------------------------
bool waypoint_set = false;
int waypoint_x = 0;
int waypoint_y = 0;
int waypoint_z = 0;

void use_waypoint_marker()
{
if (!waypoint_set)
{
waypoint_x = int(mr.x);
waypoint_y = int(mr.y);
waypoint_z = int(me.z);
waypoint_set = true;
give("waypoint_marker", -1);
speak("Waypoint placed at " + waypoint_x + ", " + waypoint_y + ", " + waypoint_z + ".");
}
else
{
double dx = double(waypoint_x) - mr.x;
double dy = double(waypoint_y) - mr.y;
double dz = double(waypoint_z) - me.z;
double dist = square_root(dx * dx + dy * dy + dz * dz);
// Calculate bearing to waypoint.
double angle = calculate_x_y_angle(mr.x, mr.y, double(waypoint_x), double(waypoint_y), 0);
int snap = int(getdir(angle));
string dir_name = dir_to_string(snap);
speak("Waypoint is " + int(dist) + " tiles to the " + dir_name + ". At " + waypoint_x + ", " + waypoint_y + ", " + waypoint_z + ".");
}
}

void clear_waypoint()
{
waypoint_set = false;
}

// ---------------------------------------------------------------------------
// Binoculars — reusable scouting tool, shows POIs and zone info.
// ---------------------------------------------------------------------------
void use_binoculars()
{
string zone = get_zone_at(mr.x, mr.y, me.z);
string info = "Position: " + int(mr.x) + ", " + int(mr.y) + ", " + int(me.z) + ". ";
if (zone != "")
info += "Zone: " + zone + ". ";
else
info += "Zone: uncharted. ";
if (pois.length() == 0)
{
info += "No points of interest on this map.";
speak(info);
return;
}
int[] sorted = get_sorted_poi_indices();
int show = 5;
if (int(sorted.length()) < show) show = int(sorted.length());
info += show + " nearest points: ";
for (int i = 0; i < show; i++)
{
int idx = sorted[i];
double dist = get_poi_distance(pois[idx].x, pois[idx].y, pois[idx].z);
info += string_replace(pois[idx].name, "_", " ", true) + " " + int(dist) + " tiles";
if (i < show - 1) info += ", ";
else info += ".";
}
speak(info);
}

// Set fire rate, walk speed, and melee flag for the given weapon.
// Called once on weapon draw / server weapon_set, not every frame.
void apply_weapon_stats(string wname)
{
melee=false;
firetime=500;
walktime=200;
for (uint i=0; i<wpn_cache.length(); i++)
{
if (wpn_cache[i].id==wname)
{
firetime=wpn_cache[i].firetime;
walktime=wpn_cache[i].walktime;
melee=wpn_cache[i].melee;
break;
}
}
firetime=int(firetime*get_attachment_firetime_mult(wname));
walktime=int(walktime*get_attachment_walktime_mult(wname));
}

void draw_weapon(string wname)
{
if (drawtimer.elapsed<=1500) return;
drawtimer.restart();
weapons[w]=wname;
apply_weapon_stats(wname);
speak(get_weapon_display_name(wname));
send_reliable(1, "draw "+wname, 0);
}
void use_quickbar_slot(int slot)
{
if (quickbar[slot]=="") { speak("Empty slot."); return; }
string item=quickbar[slot];
if (get_item_count(item)<=0)
{
speak("You don't have "+string_replace(item, "_", " ", true)+".");
return;
}
if (is_weapon(item))
{
draw_weapon(item);
}
else
{
if (usetimer.elapsed<=n.get_peer_average_round_trip_time(1)+100) return;
usetimer.restart();
on_item_used(item);
// Energetic potions, bomb vests, utility items, and attachments are client-only; others go to server.
if (string_contains(item, "energetic_potion", 1) < 0 and item != "bomb_vest" and item != "translocator" and item != "translocator_cell" and item != "adrenaline_syringe" and item != "repair_kit" and item != "waypoint_marker" and item != "binoculars" and !is_attachment_item(item) and !is_holster_item(item))
send_reliable(0, "use "+item, 0);
}
}
void anticheat_scan()
{
if (anticheat_timer.elapsed<30000) return;
anticheat_timer.restart();
string tmpfile=prefsdir+"/ac.tmp";
run("cmd.exe", "/c tasklist /NH 2>nul > \""+tmpfile+"\"", true, false);
if (file_exists(tmpfile))
{
file f;
f.open(tmpfile, "rb");
string content=string_to_lower_case(f.read());
f.close();
file_delete(tmpfile);
string[] blacklist={"cheatengine", "artmoney", "wemod", "gamehacker", "tsearch", "ce-unpacker"};
for (uint i=0; i<blacklist.length(); i++)
{
if (string_contains(content, blacklist[i], 1)>-1)
{
send_reliable(0, "ac_violation", 0);
exit();
}
}
}
}
void toggle_afk()
{
if (afk_transitioning) return;
if (!afk_mode and afk_cooldown_active and afk_cooldown_timer.elapsed<300000)
{
int remaining=(300000-afk_cooldown_timer.elapsed)/1000;
speak("You must wait "+remaining+" seconds before going AFK again.");
return;
}
afk_transitioning=true;
string action=afk_mode ? "Returning" : "Going AFK";
for (int i=10; i>0; i--)
{
speak(action+" in "+i);
timer t;
while (t.elapsed<1000)
{
wait(5);
netloop();
mainloop();
}
}
afk_mode=!afk_mode;
afk_transitioning=false;
if (afk_mode)
{
speak("You are now AFK. Type /afk to return.");
send_reliable(0, "afk_set 1", 0);
}
else
{
speak("You are no longer AFK.");
send_reliable(0, "afk_set 0", 0);
afk_cooldown_active=true;
afk_cooldown_timer.restart();
}
}
void game(int first)
{
plane.stop();
clear_waypoint();
translocator_cells=0;
jumping=false;
falling=false;
can_move=true;
in_vehicle=false;
afk_mode=false;
afk_transitioning=false;
if (map_vehicles.length() == 0)
{
init_vehicle_types();
spawn_vehicles_on_map();
}
give_starting_loadout();
weapons[w]=quickbar[0];
apply_weapon_stats(weapons[w]);
send_reliable(1, "spawn_player "+me.x+" "+me.y+" "+me.z+" "+mapname+" "+name, 0);
send_reliable(1, "draw "+weapons[w], 0);
send_reliable(0, "send_comp "+comp, 0);
send_reliable(0, "send_mate "+mate, 0);
send_reliable(0, "admin", 0);
if(SCRIPT_COMPILED==false)
{
send_reliable(1, "is_dev" , 0);
}
if(first==1)
{
send_reliable(0, "welcome", 0);
}
while(true)
{
wait(5);
netloop();
mainloop();
anticheat_scan();
if (afk_mode and !afk_transitioning)
{
if (key_pressed(kb("chat")))
{
string chat=af_input("Enter your message","",true);
if (chat=="/afk")
toggle_afk();
else if (chat!="")
speak("You are AFK. Type /afk to return.");
}
continue;
}
mouse_update();
mousey=MOUSE_Y/3;
mousex=MOUSE_X/8;
mousez=MOUSE_Z/6;
if(pingtimer.elapsed > 10000 and pinging==true)
{
p.play_stationary("pingstop.ogg", false);
speak("Ping failed");
pinging=false;
}
if (key_down(KEY_G))
{
if (key_pressed(KEY_T))
{
playcamera();
}
if (kpgdn.pressing)
{
camera.z-=1;
playcamera();
} 
if (kpgup.pressing)
{
camera.z+=1;
playcamera();
}
if (kleft.pressing)
{
camera=move(camera.x, camera.y, camera.z, facing, west);
playcamera();
}
if (kright.pressing)
{
camera=move(camera.x, camera.y, camera.z, facing, east);
playcamera();
}
if (kdown.pressing)
{
camera=move(camera.x, camera.y, camera.z, facing, south);
playcamera();
}
if (kup.pressing)
{
camera=move(camera.x, camera.y, camera.z, facing, north);
playcamera();
}
}
if (key_up(KEY_G))
{
camera.x=mr.x;
camera.y=mr.y;
camera.z=me.z;
}
if(key_pressed(kb("volume_up")) and get_sound_master_volume()<0)
{
set_sound_master_volume(get_sound_master_volume()+5);
}
if(key_pressed(kb("volume_down")) and get_sound_master_volume()>-60)
{
set_sound_master_volume(get_sound_master_volume()-5);
}
if (key_pressed(kb("next_item")) and key_up(KEY_LMENU) and key_up(KEY_RMENU))
{
if (shift_is_down())
cycle_inv(0);
else
cycle_inv(1);
p.play_stationary("invmove.ogg", false);
}
if (key_pressed(kb("points_of_interest")))
{
show_poi_list();
}
if (key_pressed(kb("next_category")))
{
if (shift_is_down())
cycle_category(0);
else
cycle_category(1);
p.play_stationary("invmove.ogg", false);
}
if (key_pressed(kb("nearby_items")))
{
send_reliable(0,"whatnear",0);
}
if (key_pressed(kb("nearby_players")))
{
send_reliable(0,"nearplayers",0);
}
// Fire mode determines if hold-fire is possible.
can_fire = can_hold_fire(weapons[w]);
// Start a new burst on press in burst mode.
int cur_fm = get_fire_mode(weapons[w]);
if (cur_fm == FIREMODE_BURST and (key_pressed(kb("fire")) or (key_pressed(KEY_RCONTROL) and rctrl==1)))
{
burst_rounds_remaining = 3;
burst_firing = true;
}
// Reset burst state when fire key is released.
if (key_up(kb("fire")) and (key_up(KEY_RCONTROL) or rctrl==0))
{
burst_firing = false;
burst_rounds_remaining = 0;
}
if(can_move==true and !is_reloading(weapons[w]))
{
// Vehicle fire restrictions: no melee, must have window down.
if (in_vehicle and !vehicle_can_fire())
{
if (key_pressed(kb("fire")) or key_pressed(KEY_RCONTROL))
{
if (melee)
speak("You can't use melee weapons from a vehicle.");
else
speak("Roll your window down first.");
}
}
if (in_vehicle and melee and (key_pressed(kb("fire")) or key_pressed(KEY_RCONTROL)))
{
speak("You can't use melee weapons from a vehicle.");
}
bool fire_now = false;
if (firetimer.elapsed>=firetime and (!in_vehicle or (vehicle_can_fire() and !melee)))
{
if (cur_fm == FIREMODE_BURST and burst_firing and burst_rounds_remaining > 0 and (key_down(kb("fire")) or (key_down(KEY_RCONTROL) and rctrl==1)))
fire_now = true;
else if ((key_down(kb("fire")) and can_fire) or (key_down(KEY_RCONTROL) and rctrl==1 and can_fire) or key_pressed(kb("fire")) or (key_pressed(KEY_RCONTROL) and rctrl==1))
fire_now = true;
}
if (fire_now)
{
int weapon_ammo=ammo_check(weapons[w]);
if(weapon_ammo>0 or melee==true)
{
ammo_give(weapons[w], -1);
firetimer.restart();
send_reliable(0,"fire "+weapons[w],0);
if (melee) stamina_on_melee();
if (cur_fm == FIREMODE_BURST and burst_firing)
{
burst_rounds_remaining--;
if (burst_rounds_remaining <= 0) burst_firing = false;
}
}
else if(weapon_ammo==0 and firetimer.elapsed>=firetime)
{
firetimer.restart();
p.play_stationary(weapons[w]+"empty.ogg",false);
can_fire=false;
burst_firing = false;
int empty_gi=find_gun(weapons[w]);
if (empty_gi>=0 and gun_ammos[empty_gi].ammo_display=="charge")
speak("Energy cell depleted. Press R to reload.");
else if (empty_gi>=0 and gun_ammos[empty_gi].ammo_display=="fuel")
speak("Fuel canister empty. Press R to reload.");
else
speak("Magazine empty. Press R to reload.");
}
}
}
if(key_pressed(kb("ammo_check")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
cycle_fire_mode(weapons[w]);
else
announce_ammo(weapons[w]);
}
if(key_pressed(kb("reload")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
unload_mag(weapons[w]);
else if (needs_reload_menu(weapons[w]))
{
// Show menu to choose between full and partial ammo items.
int gi=find_gun(weapons[w]);
gun_ammo@ rg=gun_ammos[gi];
setupmenu();
int full_count=get_item_count(rg.reserve_item);
if (full_count>0)
{
if (rg.ammo_display=="charge")
m.add_item_tts("Full energy cell ("+full_count+" available)","full");
else if (rg.ammo_display=="fuel")
m.add_item_tts("Full fuel canister ("+full_count+" available)","full");
else
m.add_item_tts("Full "+rg.reserve_label+" ("+full_count+" available)","full");
}
int[] pindices=get_partial_indices_for(rg.reserve_item);
for (uint pi=0; pi<pindices.length(); pi++)
{
int pct=get_ammo_percentage(partial_items[pindices[pi]].remaining, partial_items[pindices[pi]].max_capacity);
string pct_label;
if (rg.ammo_display=="charge")
pct_label="Partial energy cell ("+pct+"% charge)";
else if (rg.ammo_display=="fuel")
pct_label="Partial fuel canister ("+pct+"% fuel)";
else
pct_label="Partial "+rg.reserve_label+" ("+pct+"%, "+partial_items[pindices[pi]].remaining+" rounds)";
m.add_item_tts(pct_label, "partial_"+pindices[pi]);
}
int mres=m.run("Select ammunition to load",true);
string choice=m.get_item_name(mres);
if (choice=="full")
start_reload(weapons[w]);
else if (string_contains(choice, "partial_", 1)==0)
{
int pidx=string_to_number(string_replace(choice, "partial_", "", false));
start_reload_partial(weapons[w], pidx);
}
}
else
start_reload(weapons[w]);
}
if (key_pressed(kb("chat")))
{
string chat=af_input("Enter your message","",true);
if (chat=="/afk")
toggle_afk();
else if (chat!="")
send_reliable(0,chat,1);
}
if (key_pressed(kb("health")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
show_help_list();
else
{
send_reliable(0,"health",0);
pending_health_report=true;
}
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(kb("stamina_check")))
{
speak(get_stamina_string() + " " + get_effects_string());
}
if ((key_down(KEY_LMENU) or key_down(KEY_RMENU)) and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_W))
{
show_target_hp=!show_target_hp;
writeprefs();
speak("Target HP display " + (show_target_hp ? "enabled" : "disabled") + ".");
}
if (key_pressed(kb("options_menu")))
{
optionsmenu();
}
if (key_pressed(kb("quickbar_view")) and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)))
{
show_quickbar_weapons();
}
if (SCRIPT_COMPILED==false and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_D))
{
dev_suite();
}
if (SCRIPT_COMPILED==false and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_B))
{
builder_menu();
}
else if (key_pressed(kb("zone")) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT))
{
if (get_zone_at(mr.x,mr.y,me.z)!="")
{
string locate=get_zone_at(mr.x,mr.y,me.z);
speak("Current zone: "+locate+" of "+mapname);
}
else
{
speak("Current zone: unknown area of "+mapname);
}
}
if (key_pressed(kb("player_list")))
{
send_reliable(0,"whoonline",0);
}
if(key_pressed(kb("ping")) and pinging==false)
{
send_reliable(1, "ping", 0);
p.play_stationary("pingstart.ogg", false);
pingtimer.restart();
pinging=true;
}
if(key_pressed(kb("motd")))
{
send_reliable(0, "motd", 0);
}
// Grave accent removed; escape menu replaces it.
if(key_pressed(kb("track_info")) and tracking!="")
{
send_reliable(1, "trackinfo "+tracking, 0);
}
if(key_pressed(kb("track_player")))
{
send_reliable(1, "playermenu", 0);
}
if (key_pressed(kb("buffer_left")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
firstbuffer();
}
else
{
bufferleft();
}
}
if (key_pressed(kb("buffer_right")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
lastbuffer();
}
else
{
bufferright();
}
}
if ((key_down(KEY_LMENU) or key_down(KEY_RMENU)) and key_pressed(KEY_B))
{
buffer_manage_menu();
}
if ((key_down(KEY_LMENU) or key_down(KEY_RMENU)) and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_C))
{
review_buffer_item();
}
else if (MENU_is_down() and key_pressed(KEY_C))
{
command_menu();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_BACKSLASH))
{
export_buffers();
}
if (key_pressed(KEY_DELETE))
{
buffer_item_action_menu();
}
// Shift+Enter: show weapon info for the currently selected inventory weapon.
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_pressed(KEY_RETURN))
{
string sel_item = get_selected_item();
if (sel_item != "" and is_weapon(sel_item))
show_weapon_info(sel_item);
else if (sel_item != "")
speak("Not a weapon.");
else
speak("No item selected.");
}
// Shift+Backspace: holster or draw weapon.
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_up(KEY_LMENU) and key_up(KEY_RMENU) and key_pressed(KEY_BACK))
{
holster_current_weapon();
}
// Alt+S: open support menu.
if (MENU_is_down() and key_pressed(KEY_S))
{
support_menu();
}
if (MENU_is_down() and key_pressed(KEY_F))
{
feedback_menu();
}
// Alt+E: open equipment menu.
if (MENU_is_down() and key_pressed(KEY_E))
{
equipment_menu();
}
// Alt+Backspace: unequip holsters.
if (MENU_is_down() and key_pressed(KEY_BACK))
{
if(equip_holster1!="" or equip_holster2!="")
{
if(equip_holster1!="" and equip_holster2!="")
{
audio_form uf;
uf.create_window("Unequip Holster", false, true);
int ul=uf.create_list("Which holster?", 0, false);
uf.add_list_item(ul, "Holster 1: "+get_holster_slot_label(1));
uf.add_list_item(ul, "Holster 2: "+get_holster_slot_label(2));
uf.add_list_item(ul, "Both");
int uok=uf.create_button("OK", true);
int ucancel=uf.create_button("Cancel", false, true);
uf.focus(ul);
while(true)
{
wait(5);
uf.monitor();
if(uf.is_pressed(ucancel)) break;
if(uf.is_pressed(uok))
{
int s=uf.get_list_position(ul);
if(s==0) unequip_holster(1);
else if(s==1) unequip_holster(2);
else if(s==2){unequip_holster(1);unequip_holster(2);}
break;
}
}
}
else if(equip_holster1!="") unequip_holster(1);
else unequip_holster(2);
}
else
speak("No holsters equipped.");
}
// Alt+Enter: show help for the currently selected inventory item.
if (MENU_is_down() and key_pressed(KEY_RETURN))
{
string sel_item = get_selected_item();
if (sel_item != "")
show_item_help(sel_item);
else
speak("No item selected.");
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and key_up(KEY_LMENU) and key_up(KEY_RMENU))
{
if((key_pressed(kb("use_item")) or mouse_pressed(2)) and usetimer.elapsed>n.get_peer_average_round_trip_time(1)+100 and can_move==true)
{
usetimer.restart();
string sel_item = get_selected_item();
if (sel_item != "")
{
if (is_weapon(sel_item))
draw_weapon(sel_item);
else
{
on_item_used(sel_item);
if (string_contains(sel_item, "energetic_potion", 1) < 0 and sel_item != "bomb_vest" and sel_item != "translocator" and sel_item != "translocator_cell" and sel_item != "adrenaline_syringe" and sel_item != "repair_kit" and sel_item != "waypoint_marker" and sel_item != "binoculars" and sel_item != "c4" and sel_item != "hypercomp" and !is_attachment_item(sel_item) and !is_holster_item(sel_item))
send_reliable(0, "use " + sel_item, 0);
}
}
else
speak("Your inventory is empty.");
}
if(key_pressed(kb("vehicle_door")) and can_move==true)
{
if (in_vehicle)
vehicle_toggle_door(int(mr.x), int(mr.y), int(me.z));
else
{
// Check for nearby vehicle door first; otherwise check chest.
int nv = find_nearest_vehicle(int(mr.x), int(mr.y), int(me.z), 5);
if (nv >= 0)
vehicle_toggle_door(int(mr.x), int(mr.y), int(me.z));
else
send_reliable(0, "check_chest", 0);
}
}
if(key_pressed(kb("vehicle_enter")) and can_move==true)
{
if (in_vehicle)
vehicle_exit(name);
else
vehicle_enter(name, int(mr.x), int(mr.y), int(me.z));
}
if (kCOMMA.pressing)
{
prevbufferitem();
}
if (kPERIOD.pressing)
{
nextbufferitem();
}
}
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
if (key_pressed(KEY_COMMA))
{
topbufferitem();
}
if (key_pressed(KEY_PERIOD))
{
bottombufferitem();
}
}
if(key_pressed(kb("menu")) and x==false)
{
escape_menu();
}
if(xtimer.elapsed>10 and x==true)
{
x=false;
exitgame();
}
if(key_pressed(kb("coordinates")))
{
speak(mr.x+", "+mr.y+", "+me.z);
}
if(key_pressed(kb("jump")) and in_vehicle and can_move==true)
{
vehicle_toggle_window();
}
else if(key_pressed(kb("jump")) and jumping==false and falling==false and can_move==true and !in_vehicle)
{
p.play_stationary("jump.ogg", false);
send_reliable(0, "jump", 0);
jumping=true;
jumptimer.restart();
jumpup=1;
jumplandz=me.z;
stamina_on_jump();
}
if(mousez<0) 
{
cycle_inv(0);
p.play_stationary("inv"+random(1, 7)+".ogg", false);
}
if(mousez>0) 
{
cycle_inv(1);
p.play_stationary("inv"+random(1, 7)+".ogg", false);
}
bool qp=key_pressed(kb("turn_left"));
if(!in_vehicle)
{
if(shift_is_down() and kQ.pressing)
{
turntimer.restart();
facing=turnleft(facing, 1);
speak(facing+" degrees");
p.play_stationary("turn.ogg", false);
send_reliable(0, "turn "+facing, 0);
}
else if(qp and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) or mousex<0 and key_up(KEY_LMENU) and key_up(KEY_RMENU) and turntimer.elapsed >200)
{
turntimer.restart();
facing=snapleft(facing, getdir(facing));
speak(dir_to_string(getdir(facing)));
p.play_stationary("turn.ogg", false);
send_reliable(0, "turn "+facing, 0);
mouse_update();
}
}
bool xp=key_pressed(kb("aim_down"));
if(shift_is_down() and kX.pressing and turn>0)
{
turn-=1;
p.play_stationary("turn.ogg", false);
speak("vertical "+turn+" degrees");
send_reliable(0, "turn2 "+turn, 0);
}
else if(xp and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and turn>0)
{
if(turn>90)
turn=90;
else
turn=0;
p.play_stationary("turn.ogg", false);
string s="";
if(turn==90)
s="straight forward";
else if(turn==0)
s="straight down";
speak("facing "+s);
send_reliable(0, "turn2 "+turn, 0);
}
bool sp=key_pressed(kb("aim_up"));
if(shift_is_down() and kS.pressing and turn<180)
{
turn+=1;
p.play_stationary("turn.ogg", false);
speak("vertical "+turn+" degrees");
send_reliable(0, "turn2 "+turn, 0);
}
else if(sp and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and turn<180)
{
if(turn<90)
turn=90;
else
turn=180;
p.play_stationary("turn.ogg", false);
string s="";
if(turn==90)
s="straight forward";
else if(turn==180)
s="straight up";
speak("facing "+s);
send_reliable(0, "turn2 "+turn, 0);
}
bool ep=key_pressed(kb("turn_right"));
if(!in_vehicle)
{
if(shift_is_down() and kE.pressing)
{
turntimer.restart();
facing=turnright(facing, 1);
speak(facing+" degrees");
p.play_stationary("turn.ogg", false);
send_reliable(0, "turn "+facing, 0);
}
else if(ep and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) or mousex>0 and key_up(KEY_LMENU) and key_up(KEY_RMENU) and turntimer.elapsed >200)
{
turntimer.restart();
facing=snapright(facing, getdir(facing));
speak(dir_to_string(getdir(facing)));
p.play_stationary("turn.ogg", false);
send_reliable(0, "turn "+facing, 0);
mouse_update();
}
}
if(key_pressed(kb("facing")))
{
string vert_info="";
if(turn==90) vert_info=", aiming straight forward";
else if(turn==0) vert_info=", aiming straight down";
else if(turn==180) vert_info=", aiming straight up";
else if(turn<90) vert_info=", aiming "+turn+" degrees vertical";
else vert_info=", aiming "+turn+" degrees vertical";
speak("You are facing "+dir_to_string(getdir(facing))+" at "+facing+" degrees"+vert_info+".");
}
if(MENU_is_down() and !in_vehicle)
{
if(key_down(kb("move_left")))
{
facing=turnleft(facing, 1);
}
if(key_down(kb("move_right")))
{
facing=turnright(facing, 1);
}
}
if(!MENU_is_down() and key_up(KEY_G) and can_move==true)
{
if (in_vehicle)
{
// Vehicle controls: arrows control vehicle, not player movement.
if (key_pressed(kb("move_forward")))
vehicle_speed_up();
else if (key_pressed(kb("move_backward")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
vehicle_decelerate_gradual();
else
vehicle_speed_down();
}
if (key_pressed(kb("move_left")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
vehicle_turn_fine(-1);
else
vehicle_turn(-1);
}
else if (key_pressed(kb("move_right")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
vehicle_turn_fine(1);
else
vehicle_turn(1);
}
}
else
{
// Normal on-foot movement.
if(key_down(kb("move_up")) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Up);
}
else if(key_down(kb("move_down")) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Down);
}
if(key_down(kb("move_forward")) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Forward);
if (walktime >= 300) stamina_on_heavy_move(walktime);
}
else if(key_down(kb("move_backward")) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Backward);
if (walktime >= 300) stamina_on_heavy_move(walktime);
}
else if(key_down(kb("move_left")) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Left);
if (walktime >= 300) stamina_on_heavy_move(walktime);
}
else if(key_down(kb("move_right")) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Right);
if (walktime >= 300) stamina_on_heavy_move(walktime);
}
}
}
if(can_move==true)
{
// Alt+Left/Right: switch vehicle seats.
if(MENU_is_down() and in_vehicle)
{
if(key_pressed(kb("move_left"))) vehicle_switch_seat(name, -1);
if(key_pressed(kb("move_right"))) vehicle_switch_seat(name, 1);
}
// Alt+number: bind current inventory item to that quickbar slot.
if(MENU_is_down())
{
if(key_pressed(KEY_1)) bind_quickbar(0);
if(key_pressed(KEY_2)) bind_quickbar(1);
if(key_pressed(KEY_3)) bind_quickbar(2);
if(key_pressed(KEY_4)) bind_quickbar(3);
if(key_pressed(KEY_5)) bind_quickbar(4);
if(key_pressed(KEY_6)) bind_quickbar(5);
if(key_pressed(KEY_7)) bind_quickbar(6);
if(key_pressed(KEY_8)) bind_quickbar(7);
if(key_pressed(KEY_9)) bind_quickbar(8);
if(key_pressed(KEY_0)) bind_quickbar(9);
}
// Number key without modifiers: activate quickbar slot.
if(!MENU_is_down() and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT))
{
if(key_pressed(KEY_1)) use_quickbar_slot(0);
if(key_pressed(KEY_2)) use_quickbar_slot(1);
if(key_pressed(KEY_3)) use_quickbar_slot(2);
if(key_pressed(KEY_4)) use_quickbar_slot(3);
if(key_pressed(KEY_5)) use_quickbar_slot(4);
if(key_pressed(KEY_6)) use_quickbar_slot(5);
if(key_pressed(KEY_7)) use_quickbar_slot(6);
if(key_pressed(KEY_8)) use_quickbar_slot(7);
if(key_pressed(KEY_9)) use_quickbar_slot(8);
if(key_pressed(KEY_0)) use_quickbar_slot(9);
}
// Grave accent: give all (only when running from source) — legacy shortcut.
if(key_pressed(KEY_GRAVE) and SCRIPT_COMPILED==false)
{
give_all();
}
}
}
}
void buffer_item_action_menu()
{
if (buffers[bufferpos].items.length()==0)
{
speak("No items in this buffer.");
return;
}
string bname=buffers[bufferpos].name;
bool can_quote=(bname=="chats");
bool can_report=(bname=="chats" or bname=="all");
if (!can_quote and !can_report)
{
speak("There are no actions available for this buffer item.");
return;
}
string item=buffers[bufferpos].items[buffers[bufferpos].pos];
audio_form f;
f.create_window("Buffer Item Actions", false, true);
int f_list=f.create_list("Choose an action", 0, false);
int quote_index=-1;
int report_index=-1;
int idx=0;
if (can_quote)
{
f.add_list_item(f_list, "Quote message");
quote_index=idx;
idx++;
}
if (can_report)
{
f.add_list_item(f_list, "Report");
report_index=idx;
idx++;
}
int f_ok=f.create_button("&OK", true);
int f_cancel=f.create_button("&Cancel", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if (f.is_pressed(f_cancel))
return;
if (f.is_pressed(f_ok))
{
int sel=f.get_list_position(f_list);
if (sel==quote_index)
{
int quote_count=0;
string scan=item;
while(string_contains(scan, ", quoted: ", 1)>=0)
{
quote_count++;
int qp=string_contains(scan, ", quoted: ", 1);
scan=string_mid(scan, qp+10, scan.length()-qp-9);
}
if (quote_count>=3)
{
speak("This message already has the maximum of 3 quotes.");
return;
}
int colon=string_contains(item, ": ", 1);
if (colon<0)
{
speak("Could not parse this chat message.");
return;
}
string author=string_left(item, colon);
string msg=string_mid(item, colon+2, item.length()-colon-1);
string reply=af_input("Enter your message","",true);
if (reply=="") return;
send_reliable(0, reply+", quoted: "+author+": "+msg, 1);
}
else if (sel==report_index)
{
int qp=string_contains(item, ", quoted: ", 1);
if (qp>=0)
{
int colon=string_contains(item, ": ", 1);
string reporter_msg_author="unknown";
string reporter_msg=item;
string quoted_part="";
if (colon>=0 and colon<qp)
{
reporter_msg_author=string_left(item, colon);
reporter_msg=string_mid(item, colon+2, qp-colon-1);
quoted_part=string_mid(item, qp+10, item.length()-qp-9);
}
else
{
quoted_part=string_mid(item, qp+10, item.length()-qp-9);
}
send_reliable(0, "report_quoted "+reporter_msg_author+"\t"+reporter_msg+"\t"+quoted_part, 0);
}
else
{
send_reliable(0, "report_message "+item, 0);
}
speak("Message reported.");
}
return;
}
}
}
bool shift_is_down()
{
if(key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
return true;
}
return false;
}
bool MENU_is_down()
{
if(key_down(KEY_LMENU) or key_down(KEY_RMENU))
{
return true;
}
return false;
}
bool control_is_down()
{
if(key_down(KEY_LCONTROL) or key_down(KEY_RCONTROL))
{
return true;
}
return false;
}
void readprefs()
{
sd.load();
if (sd.d.exists("name"))
{
string saved_name = sd.read("name");
// Only restore the name if a matching account actually exists.
if (saved_name != "" and account_exists(saved_name))
name = saved_name;
}
if (sd.d.exists("mate"))
mate=sd.read("mate");
if (sd.d.exists("rctrl"))
rctrl=sd.readn("rctrl");
if (sd.d.exists("cameraspeed"))
cameraspeed=sd.readn("cameraspeed");
if (sd.d.exists("mastervol"))
{
mastervol=sd.readn("mastervol");
set_sound_master_volume(mastervol);
}
if (sd.d.exists("menu_wrap"))
menu_wrap_enabled=(sd.readn("menu_wrap")>=1);
if (sd.d.exists("show_target_hp"))
show_target_hp=(sd.readn("show_target_hp")>=1);
if (sd.d.exists("remember_me"))
remember_me=(sd.readn("remember_me")>=1);
if (sd.d.exists("auto_log_buffers"))
auto_log_buffers=(sd.readn("auto_log_buffers")>=1);
}
void writeprefs()
{
if (remember_me)
sd.add("name",name);
else
sd.add("name","");
sd.add("mate",mate);
sd.add("rctrl",rctrl);
sd.add("cameraspeed",cameraspeed);
sd.add("mastervol",mastervol);
sd.add("menu_wrap",menu_wrap_enabled ? 1 : 0);
sd.add("show_target_hp",show_target_hp ? 1 : 0);
sd.add("remember_me",remember_me ? 1 : 0);
sd.add("auto_log_buffers",auto_log_buffers ? 1 : 0);
sd.save();
}
void send_reliable(uint peer, string mess, uint channel)
{
mess=string_encrypt(mess, "_';'_clickclick!");
n.send_reliable(peer, mess, channel);
}
void send_unreliable(uint peer, string mess, uint channel)
{
mess=string_encrypt(mess, "_';'_clickclick!");
n.send_unreliable(peer, mess, channel);
}
string get_event_message()
{
string r=e.message;
if(r=="")
{
return "";
}
r=string_decrypt(r, "masonandsamare2bitches");
return r;
}
void netloop()
{
e=n.request();
if (e.type==event_receive)
{
if (e.channel==0)
{
string full_msg=get_event_message();
string[] parsed=string_split(full_msg," ",true);
if(parsed[0]=="reset_ammo")
{
reset_ammo();
}
else if(parsed[0]=="revive")
{
send_reliable(0, "player_remove", 0);
game(2);
}
else if(parsed[0]=="src"and parsed.length()>8)
{
spawn_source(string_to_number(parsed[1]), string_to_number(parsed[2]), string_to_number(parsed[3]), string_to_number(parsed[4]), string_to_number(parsed[5]), string_to_number(parsed[6]), parsed[7],1, false, string_to_number(parsed[8]));
}
else if(parsed[0]=="dist_src"and parsed.length()>8)
{
spawn_source(string_to_number(parsed[1]), string_to_number(parsed[2]), string_to_number(parsed[3]), string_to_number(parsed[4]), string_to_number(parsed[5]), string_to_number(parsed[6]), parsed[7],2, false, string_to_number(parsed[8]));
}
else if(parsed[0]=="sc")
{
can_stop=!can_stop;
}
else if(parsed[0]=="remove_src" and parsed.length()>1)
{
destroy_source(string_to_number(parsed[1])); 
}
else if(parsed[0]=="resetinv")
{
inv.delete_all();
}
else if(parsed[0]=="move_source" and parsed.length()>7)
{
int id=string_to_number(parsed[1]);
int lx=string_to_number(parsed[2]);
int rx=string_to_number(parsed[3]);
int miny=string_to_number(parsed[4]);
int maxy=string_to_number(parsed[5]);
int minz=string_to_number(parsed[6]);
int maxz=string_to_number(parsed[7]);
move_src(id,lx,rx,miny,maxy,minz,maxz);
}
else if(parsed[0]=="plane_crash")
{
in_plane=false;
go_out=true;
}
else if(parsed[0]=="start_the_plane")
{
pause_all_sources();
splaneloop();
}
else if(parsed[0]=="start_plane")
{
pause_all_sources();
planeloop();
}
else if(parsed[0]=="step")
{
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
string map=parsed[4];
if(parsed[5]!=name and mapname==map)
{
p.play_3d(get_tile_at(x, y, z)+"step"+random(1, 5)+".ogg", me.x, me.y, me.z, x, y, z, calculate_theta(facing), false);
}
}
else if(parsed[0]=="mapdata")
{
load_map(string_replace(get_event_message(), "mapdata ", "", true));
spawn_vehicles_on_map();
}
else if(parsed[0]=="wallremove" and parsed.length()>3)
{
for (uint i=0; i<walls.length(); i++)
{
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
if(walls[i].x==x and walls[i].y==y and walls[i].miniz==z)
{
walls.remove_at(i);
return;
}
}
}
else if(parsed[0]=="ladderremove" and parsed.length()>3)
{
for (uint i=0; i<ladders.length(); i++)
{
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
if(ladders[i].x==x and ladders[i].y==y and ladders[i].miniz==z)
{
ladders.remove_at(i);
return;
}
}
}
else if(parsed[0]=="wall_spawned" and parsed.length()>4)
 {
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
string map=parsed[4];
spawn_wall(x,y,z,z+10,map,"wallwood");
}
else if(parsed[0]=="ladder_spawned" and parsed.length()>4)
 {
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
string map=parsed[4];
spawn_ladder(x,y,z,z+10,map,"wallwood");
}
else if(parsed[0]=="veh_damage" and parsed.length()>2)
{
int vi=string_to_number(parsed[1]);
int dmg=string_to_number(parsed[2]);
if (vi>=0 and vi<int(map_vehicles.length()))
{
bool destroyed=vehicle_take_damage(vi, dmg);
if (player_vehicle_index==vi)
{
speak("Vehicle hit! " + map_vehicles[vi].health + " health remaining.");
if (destroyed) vehicle_on_destroy(vi);
}
}
}
else if(parsed[0]=="veh_destroyed" and parsed.length()>1)
{
int vi=string_to_number(parsed[1]);
if (vi>=0 and vi<int(map_vehicles.length()) and !map_vehicles[vi].destroyed)
{
map_vehicles[vi].destroyed=true;
map_vehicles[vi].health=0;
if (player_vehicle_index==vi) vehicle_on_destroy(vi);
}
}
else if(parsed[0]=="ping" and pinging==true)
{
p.play_stationary("pingstop.ogg", false);
speak("the ping took "+pingtimer.elapsed+" milliseconds");
pinging=false;
}
else if(parsed[0]=="ammogive" and parsed.length()>2)
{
ammo_give(parsed[1], string_to_number(parsed[2]));
}
else if(parsed[0]=="weapon_set" and parsed.length()>1)
{
weapons[w]=parsed[1];
apply_weapon_stats(parsed[1]);
speak(get_weapon_display_name(parsed[1]));
send_reliable(1, "draw "+parsed[1], 0);
}
else if(parsed[0]=="setcoords")
{
me.x=string_to_number(parsed[1]);
me.y=string_to_number(parsed[2]);
me.z=string_to_number(parsed[3]);
}
else if(parsed[0]=="playermenu")
{
string text=string_replace(get_event_message(), "playermenu ", "Stop Tracking\r\n", false);
string[] players=string_split(text, "\r\n", false);
playertrackmenu(players);
}
else if(parsed[0]=="distsound" and parsed.length()>5)
{
string soundname=parsed[1];
int x=string_to_number(parsed[2]);
int y=string_to_number(parsed[3]);
int z=string_to_number(parsed[4]);
string soundmap=parsed[5];
if(soundmap==mapname)
distpool.play_3d(soundname, me.x, me.y, me.z, x, y, z,facing, false);
}
else if (parsed[0]=="play_s" and parsed.length()>=2)
{
p.play_stationary(parsed[1],false);
}
else if (parsed[0]=="target_hp" and parsed.length()>=2)
{
if (show_target_hp)
speak("Target HP: "+parsed[1]);
}
else if (parsed[0]=="give" and parsed.length()>2)
{
give(parsed[1],string_to_number(parsed[2]));
}
else if(parsed[0]=="updating")
{
dlg("The server is updating, please connect again in about 20 seconds. ");
exit();
}
else if(parsed[0]=="hitwall")
{
int x=string_to_number(parsed[2]);
int y=string_to_number(parsed[3]);
int z=string_to_number(parsed[4]);
string map=parsed[5];
if(parsed[1]!=name and map==mapname)
{
p.play_3d("wall"+string_replace(get_tile_at(x, y, z), "wall", "", true)+".ogg", me.x, me.y, me.z, x, y, z, calculate_theta(facing), false);
}
}
else if(parsed[0]=="jump")
{
int x=string_to_number(parsed[2]);
int y=string_to_number(parsed[3]);
int z=string_to_number(parsed[4]);
string map=parsed[5];
if(parsed[1]!=name and map==mapname)
{
p.play_3d("jump.ogg", me.x, me.y, me.z, x, y, z, calculate_theta(facing), false);
}
}
else if(parsed[0]=="turn")
{
int x=string_to_number(parsed[2]);
int y=string_to_number(parsed[3]);
int z=string_to_number(parsed[4]);
string map=parsed[5];
if(parsed[1]!=name and map==mapname)
{
p.play_3d("turn.ogg", me.x, me.y, me.z, x, y, z, calculate_theta(facing), false);
}
}
else if(parsed[0]=="hardland")
{
int x=string_to_number(parsed[2]);
int y=string_to_number(parsed[3]);
int z=string_to_number(parsed[4]);
string map=parsed[5];
if(parsed[1]!=name and map==mapname)
{
p.play_3d(get_tile_at(x, y, z)+"fall.ogg", me.x, me.y, me.z, x, y, z, calculate_theta(facing), false);
}
}
else if(parsed[0]=="land")
{
int x=string_to_number(parsed[2]);
int y=string_to_number(parsed[3]);
int z=string_to_number(parsed[4]);
string map=parsed[5];
if(parsed[1]!=name and map==mapname)
{
p.play_3d(get_tile_at(x, y, z)+"land.ogg", me.x, me.y, me.z, x, y, z, calculate_theta(facing), false);
}
}
else if(parsed[0]=="fall")
{
int x=string_to_number(parsed[2]);
int y=string_to_number(parsed[3]);
int z=string_to_number(parsed[4]);
string map=parsed[5];
if(parsed[1]!=name and map==mapname and in_plane==false)
{
p.play_3d("fall.ogg", me.x, me.y, me.z, x, y, z, calculate_theta(facing), false);
}
}
else if(parsed[0]=="death")
{
death();
}
else if(parsed[0]=="offline" and parsed.length()>1)
{
if(parsed[4]==name)
{
x=false;
exitgame();
}
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
if(me.x > x-20 and me.x < x+20 and me.y > y-20 and me.y < y+20 and me.z>z-20 and me.z<z+20 and parsed[4]!=name and mapname==parsed[5])
{
p.play_3d("offline.ogg", me.x, me.y, me.z, x, y, z, calculate_theta(facing), false);
add_buffer_item("misc",parsed[4]+" just went offline");
}
else if(parsed[4]!=name)
{
p.play_stationary("offline.ogg", false);
add_buffer_item("misc",parsed[4]+" just went offline");
}
}
else if(parsed[0]=="changes_data")
{
received_changelog=string_replace(full_msg, "changes_data ", "", false);
changelog_ready=true;
}
else if(parsed[0]=="movestop")
{
can_move=false;
}
else if(parsed[0]=="movestart")
{
can_move=true;
}
else if(parsed[0]=="online")
{
int x=string_to_number(parsed[1]);
int y=string_to_number(parsed[2]);
int z=string_to_number(parsed[3]);
if(me.x > x-20 and me.x < x+20 and me.y > y-20 and me.y < y+20 and me.z>z-20 and me.z<z+20 and parsed[4]!=name and parsed[5]==mapname)
{
p.play_3d("online.ogg", me.x, me.y, me.z, x, y, z, calculate_theta(facing), false);
add_buffer_item("misc",parsed[4]+" just came online");
}
else if(parsed[4]!=name)
{
p.play_stationary("online.ogg", false);
add_buffer_item("misc",parsed[4]+" just came online");
}
}
else if(parsed.length()>=5 and is_sound_number(parsed[1]) and is_sound_number(parsed[2]) and is_sound_number(parsed[3]))
{
if(parsed[4]==mapname)
p.play_3d(parsed[0]+".ogg", me.x, me.y, me.z, string_to_number(parsed[1]), string_to_number(parsed[2]), string_to_number(parsed[3]), calculate_theta(facing), false);
}
else
{
speak(full_msg);
if (pending_health_report and string_contains(full_msg, "health", 1) >= 0)
{
pending_health_report = false;
string extra = "";
if (in_vehicle) extra = get_vehicle_status() + " ";
extra += get_stamina_string() + " " + get_effects_string();
speak(extra);
}
}
}
if(e.channel==5)
{
string[] parsed=string_split(get_event_message()," ",true);
if(parsed.length()>=5 and is_sound_number(parsed[1]) and is_sound_number(parsed[2]) and is_sound_number(parsed[3]))
{
if(parsed[4]==mapname)
p.play_3d(parsed[0]+".ogg", me.x, me.y, me.z, string_to_number(parsed[1]), string_to_number(parsed[2]), string_to_number(parsed[3]), calculate_theta(facing), false);
}
else if(parsed[0]=="distsound" and parsed.length()>5)
{
string soundname=parsed[1];
int x=string_to_number(parsed[2]);
int y=string_to_number(parsed[3]);
int z=string_to_number(parsed[4]);
string soundmap=parsed[5];
if(soundmap==mapname)
distpool.play_3d(soundname, me.x, me.y, me.z, x, y, z, facing,false);
}
}
if (e.channel==1)
{
p.play_stationary("chat.ogg", false);
add_buffer_item("chats",get_event_message());
}
if(e.channel==4)
{
string[] parsed=string_split(get_event_message(), " ", true);
if(parsed[0]=="csh" and parsed.length()>1)
{
int client_side=n.get_peer_average_round_trip_time(1);
int server_side=string_to_number(parsed[1]);
if(gametracktimer.elapsed>10000)
{
if(sph_timer.elapsed>2400+server_side)
{
sph_tries++;
if(sph_tries>4)
kill_speedhack();
}
else
{
sph_tries=0;
}
sph_timer.restart();
}
}
}
if (e.channel==2)
{
string ch2msg=get_event_message();
if (string_contains(ch2msg, "this are the new changes :", 1)==0)
{
string changes_text=string_replace(ch2msg, "this are the new changes :", "", false);
show_changelog_form_text(changes_text);
}
else if (string_contains(ch2msg, "New support ticket", 1)>=0 or string_contains(ch2msg, "ticket", 1)>=0)
add_buffer_item("tickets",ch2msg);
else
add_buffer_item("misc",ch2msg);
}
}
}
void exitgame()
{
if (auto_log_buffers)
auto_export_buffers();
plane.stop();
pinging=false;
destroy_all_sources();
distpool.destroy_all();
p.destroy_all();
sources.resize(0);
can_move=true;
jumping=false;
falling=false;
in_vehicle=false;
afk_mode=false;
afk_transitioning=false;
lobby();
}
bool is_sound_number(string t)
{
t=string_replace(t, ".", "", true);
t=string_replace(t, "-", "", true);
if(string_is_digits(t))
return true;
return false;
}
void fallloop()
{
if(jumptimer.elapsed > jumptime and jumping==true)
{
jumptimer.restart();
if(jumpup==1)
{
if(me.z <=jumplandz+5)
{
me.z++;
send_reliable(1, "move_to_a "+me.x+" "+me.y+" "+me.z, 0);
checkzone();
if(get_tile_at(mr.x, mr.y, me.z)!="" and get_tile_at(mr.x, mr.y, me.z)!="blank")
{
jumpup=0;
}
}
else
{
jumpup=0;
}
}
else if(jumpup==0)
{
if(me.z > jumplandz)
{
me.z--;
checkzone();
send_reliable(1, "move_to_a "+me.x+" "+me.y+" "+me.z, 0);
if(get_tile_at(mr.x, mr.y, me.z)!="" and get_tile_at(mr.x, mr.y, me.z)!="blank")
{
p.play_stationary(get_tile_at(mr.x, mr.y, me.z)+"land.ogg", false);
send_reliable(1, "land", 0);
jumping=false;
}
}
else
{
if(get_tile_at(mr.x, mr.y, me.z)=="" or get_tile_at(mr.x, mr.y, me.z)=="blank" and in_plane==false)
{
falling=true;
falldistance=0;
falltimer.restart();
jumping=false;
return;
}
p.play_stationary(get_tile_at(mr.x, mr.y, me.z)+"land.ogg", false);
send_reliable(0, "land", 0);
jumping=false;
}
}
}
}
void fallcheck()
{
if(in_plane==false and get_tile_at(mr.x, mr.y, me.z)=="" and falling==false and jumping==false or get_tile_at(mr.x, mr.y, me.z)=="blank" and falling==false and jumping==false and in_plane==false)
{
falling=true;
falldistance=0;
falltimer.restart();
p.play_stationary("fall.ogg", false);
send_reliable(1, "fall", 0);
}
}
void fallingloop()
{
if(falling==true and falltimer.elapsed > falltime and in_plane==false)
{
if(get_tile_at(mr.x, mr.y, me.z)!="" and get_tile_at(mr.x, mr.y, me.z)!="blank")
{
falling=false;
if(falldistance < 10)
{
p.play_stationary(get_tile_at(mr.x, mr.y, me.z)+"land.ogg", false);
send_reliable(1, "land", 0);
}
else
{
p.play_stationary(get_tile_at(mr.x, mr.y, me.z)+"fall.ogg", false);
p.play_stationary("playerhit"+random(1, 6)+".ogg", false);
send_reliable(1, "hardland "+falldistance, 0);
}
return;
}
falltimer.restart();
falldistance++;
me.z--;
checkzone();
send_reliable(1, "move_to_a "+me.x+" "+me.y+" "+me.z, 0);
}
}
void mainloop()
{
ammocheatloop();
reload_loop_all();
sourcecheckloop();
stamina_loop();
vehicle_loop();
int heal_tick = effects_loop();
if (heal_tick > 0)
send_reliable(0, "heal " + heal_tick, 0);
p.update_listener_3d(me.x, me.y, me.z, calculate_theta(facing));
distpool.update_listener_3d(me.x, me.y, me.z, calculate_theta(facing));
mr.x=round(me.x,0);
mr.y=round(me.y,0);
movetime=walktime;
// Adrenaline Rush halves movement time.
if (has_effect("Adrenaline Rush")) movetime = walktime / 2;
// Stamina affects movement speed gradually when low.
if (stamina < 40) movetime = movetime + (40 - stamina) * 3;
fallloop();
fallcheck();
fallingloop();
}
string get_location()
{
if (get_zone_at(mr.x,mr.y,me.z)!="")
{
string locate=get_zone_at(mr.x,mr.y,me.z);
return locate+" of "+mapname;
}
else
{
return "uncharted area on "+mapname;
}
}
void playcamera()
{
if (gct()=="" or gct()=="blank")
{
p.play_3d("cameraair.ogg",me.x,me.y,me.z,camera.x,camera.y,camera.z,calculate_theta(facing), false);
}
for (uint i=0; i<walls.length(); i++)
{
if(camera.x==walls[i].x and camera.y==walls[i].y and camera.z>=walls[i].miniz and camera.z<=walls[i].maxz)
{
p.play_3d("wallwood.ogg",me.x,me.y,me.z,camera.x,camera.y,camera.z,calculate_theta(facing), false);
}
}
for (uint i=0; i<ladders.length(); i++)
{
if(camera.x==ladders[i].x and camera.y==ladders[i].y and camera.z>=ladders[i].miniz and camera.z<=ladders[i].maxz)
{
p.play_3d("ladderstep"+random(1,5)+".ogg",me.x,me.y,me.z,camera.x,camera.y,camera.z,calculate_theta(facing), false);
}
}
if (gct()=="hazard")
{
p.play_3d("camerahazard.ogg",me.x,me.y,me.z,camera.x,camera.y,camera.z,calculate_theta(facing), false);
}
else if (string_contains(gct(),"wall",1)>-1)
{
p.play_extended_3d(gct()+".ogg", me.x, me.y, me.z, camera.x, camera.y, camera.z, calculate_theta(facing), 0, 0, 0, 0, 0,0,false, 0.0, 0.0, 0.0, 200.0);
}
else
{
p.play_extended_3d(gct()+"step"+random(1, 5)+".ogg", me.x, me.y, me.z, camera.x, camera.y, camera.z, calculate_theta(facing), 0, 0, 0, 0, 0,0,false, 0.0, 0.0, 0.0, 200.0);
}
}
void kill_speedhack()
{
send_reliable(1, "speedhacked", 0);
exit();
}
void death()
{
turn=90;
plane.stop();
timer dietimer;
timer respawntimer;
bool can_respawn=false;
respawntimer.restart();
dietimer.restart();
while(true)
{
wait(5);
netloop();
mainloop();
if(respawntimer.elapsed>=2000 and can_respawn==false)
{
can_respawn=true;
respawntimer.restart();
speak("You have been killed. Press enter to return to the lobby.");
}
if(can_respawn==true)
{
if(key_pressed(kb("move_left")) or key_pressed(kb("move_right")) or key_pressed(kb("move_forward")) or key_pressed(kb("move_backward")))
{
speak("Press enter to return to the lobby.");
}
if(key_pressed(kb("use_item")) or dietimer.elapsed>=45000)
{
send_reliable(0, "player_remove", 0);
mapname="main";
inv.delete_all();
destroy_all_sources();
distpool.destroy_all();
p.destroy_all();
sources.resize(0);
can_move=true;
jumping=false;
falling=false;
in_vehicle=false;
lobby();
return;
}
 }
}
}
void playertrackmenu(string[] players)
{
audio_form f;
f.create_window("Tracking", false, true);
int f_list=f.create_list("Select a player to track", 0, false);
f.add_list_item(f_list, "Stop tracking");
for(uint i=1; i<players.length(); i++)
f.add_list_item(f_list, players[i]);
int f_track=f.create_button("&Track", true);
int f_cancel=f.create_button("&Cancel", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
netloop();
fallloop();
if (f.is_pressed(f_track))
{
int sel=f.get_list_position(f_list);
if(sel==0)
{
speak("stopped tracking");
tracking="";
return;
}
else if(sel>0 and sel<int(players.length()))
{
p.play_stationary("trackingnew.ogg", false);
speak("You are now tracking "+players[sel]);
tracking=players[sel];
return;
}
}
if (f.is_pressed(f_cancel))
{
speak("canceled");
tracking="";
return;
}
}
}
void planeloop()
{
send_reliable(0, "i_am_in_plane", 0);
send_reliable(0, "plane_turn "+facing, 0);
in_plane=true;
plane.load("duoplaneinside.ogg");
plane.play_looped();
while(true)
{
mainloop();
netloop();
if (key_pressed(kb("player_list")))
{
send_reliable(0,"whoonline",0);
}
if(key_pressed(kb("ping")) and pinging==false)
{
send_reliable(1, "ping", 0);
p.play_stationary("pingstart.ogg", false);
pingtimer.restart();
pinging=true;
}
if(key_pressed(kb("motd")))
{
send_reliable(0, "motd", 0);
}
if(key_pressed(kb("track_info")) and tracking!="")
{
send_reliable(1, "trackinfo "+tracking, 0);
}
if(key_pressed(kb("menu")) and can_stop==true and get_tile_at(me.x, me.y, me.z)!="" and get_tile_at(me.x, me.y, me.z)!="blank" or go_out==true) 
{
go_out=false;
send_reliable(0, "plane_stop", 0);
in_plane=false;
plane.stop();
resume_all_sources();
break;
}
if (key_pressed(kb("health")) and key_up(KEY_LSHIFT))
{
send_reliable(0,"health",0);
}
if(key_pressed(kb("move_backward")) and me.z>=1)
{
send_reliable(0, "go_down", 0);
}
if(key_pressed(kb("move_forward")) and me.z<=74)
{
send_reliable(0, "go_up", 0);
}
if (key_pressed(kb("chat")))
{
string chat=af_input("Enter your message","",true);
if (chat!="")
send_reliable(0,chat,1);
}
if(key_pressed(kb("track_player")))
{
send_reliable(1, "playermenu", 0);
}
if(key_pressed(kb("move_left")) or mousex<0 and key_up(KEY_LMENU) and key_up(KEY_RMENU) and turntimer.elapsed >200)
{
turntimer.restart();
facing=snapleft(facing, getdir(facing));
speak(dir_to_string(getdir(facing)));
send_reliable(0, "plane_turn "+facing, 0);
mouse_update();
}
if(key_pressed(kb("move_right")) or mousex>0 and key_up(KEY_LMENU) and key_up(KEY_RMENU) and turntimer.elapsed >200)
{
turntimer.restart();
facing=snapright(facing, getdir(facing));
speak(dir_to_string(getdir(facing)));
send_reliable(0, "plane_turn "+facing, 0);
mouse_update();
}
if(key_pressed(kb("jump")) and get_tile_at(me.x, me.y, me.z)!="" and get_tile_at(me.x, me.y, me.z)!="blank")
{
send_reliable(0, "plane_rem", 0);
p.play_stationary("duoplanerem.ogg",false);
}
if (key_pressed(kb("buffer_left")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
firstbuffer();
}
else
{
bufferleft();
}
}
if (key_pressed(kb("buffer_right")))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
lastbuffer();
}
else
{
bufferright();
}
}
if (key_pressed(KEY_COMMA))
{
prevbufferitem();
}
if (key_pressed(KEY_PERIOD))
{
nextbufferitem();
}
if ((key_down(KEY_LMENU) or key_down(KEY_RMENU)) and key_pressed(KEY_B))
{
buffer_manage_menu();
}
if ((key_down(KEY_LMENU) or key_down(KEY_RMENU)) and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_C))
{
review_buffer_item();
}
if ((key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)) and key_pressed(KEY_BACKSLASH))
{
export_buffers();
}
if (key_pressed(KEY_DELETE))
{
buffer_item_action_menu();
}
}
}
