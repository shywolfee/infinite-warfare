void bug_submit()
{
audio_form f;
f.create_window("Submit a Bug Report", false, true);
int f_title=f.create_input_box("Title", "", "", 0, false, false, false);
int f_body=f.create_input_box("Description", "", "", 0, false, false, true);
int f_submit=f.create_button("&Submit", true);
int f_cancel=f.create_button("&Cancel", false, true);
f.focus(f_title);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(f_submit))
{
string title=f.get_text(f_title);
string body=f.get_text(f_body);
if(title=="")
{
dlg("Please enter a title for your bug report.");
continue;
}
if(body=="")
{
dlg("Please enter a description of the bug.");
continue;
}
title=string_replace(title, "|", "/", true);
title=string_replace(title, "~", "-", true);
title=string_replace(title, "\n", " ", true);
body=string_replace(body, "|", "/", true);
body=string_replace(body, "~", "-", true);
body=string_replace(body, "\n", "<<NL>>", true);
send_reliable(0, "bug_create "+name+"|"+title+"|"+body, 0);
string result="";
timer wt;
while(wt.elapsed<3000)
{
wait(5);
e=n.request();
if(e.type==event_receive)
{
string msg=get_event_message();
if(string_contains(msg, "bug_created", 1)==0)
{
result=msg;
break;
}
}
if(e.type==event_disconnect)
{
speak("Disconnected from server.");
return;
}
}
if(result!="")
dlg("Your bug report has been submitted. The dev team has been notified.");
else
dlg("Failed to submit your bug report. The server may not have responded.");
return;
}
else if(f.is_pressed(f_cancel))
return;
}
}

void bugs_menu()
{
send_reliable(0, "bug_check_role", 0);
bool is_staff=false;
timer rt;
while(rt.elapsed<2000)
{
wait(5);
e=n.request();
if(e.type==event_receive)
{
string msg=get_event_message();
if(msg=="bug_role_staff")
{
is_staff=true;
break;
}
else if(msg=="bug_role_player")
break;
}
if(e.type==event_disconnect)
{
speak("Disconnected from server.");
return;
}
}
if(is_staff)
bugs_menu_staff();
else
bugs_menu_player();
}

void bugs_menu_player()
{
speak("Loading your bug reports, please wait.");
send_reliable(0, "bug_list_my "+name, 0);
string data="";
timer wt;
while(wt.elapsed<3000)
{
wait(5);
e=n.request();
if(e.type==event_receive)
{
string msg=get_event_message();
if(string_contains(msg, "bug_mylist ", 1)==0)
{
data=string_replace(msg, "bug_mylist ", "", false);
break;
}
}
if(e.type==event_disconnect)
{
speak("Disconnected from server.");
return;
}
}
audio_form f;
f.create_window("My Bug Reports", false, true);
int f_list=f.create_list("Bug reports", 0, false);
string[] bug_ids;
if(data=="" or data=="none")
{
f.add_list_item(f_list, "No bug reports found.");
}
else
{
string[] entries=string_split(data, ",", false);
for(uint i=0; i<entries.length(); i++)
{
string[] parts=string_split(entries[i], "~", false);
if(parts.length()<3) continue;
bug_ids.insert_last(parts[0]);
string flag_display=(parts[2]=="" or parts[2]=="none") ? "unflagged" : parts[2];
f.add_list_item(f_list, "#"+parts[0]+": "+parts[1]+" ["+flag_display+"]");
}
}
int f_view=f.create_button("&View selected");
int f_back=f.create_button("Go &back", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(f_view))
{
int sel=f.get_list_position(f_list);
if(sel>=0 and sel<int(bug_ids.length()))
{
bug_view_player(bug_ids[sel]);
return;
}
}
else if(f.is_pressed(f_back))
return;
}
}

void bug_view_player(string bug_id)
{
speak("Loading bug report, please wait.");
send_reliable(0, "bug_get "+bug_id, 0);
string data="";
timer wt;
while(wt.elapsed<3000)
{
wait(5);
e=n.request();
if(e.type==event_receive)
{
string msg=get_event_message();
if(string_contains(msg, "bug_data ", 1)==0)
{
data=string_replace(msg, "bug_data ", "", false);
break;
}
}
if(e.type==event_disconnect)
{
speak("Disconnected from server.");
return;
}
}
if(data=="" or data=="not_found")
{
dlg("Bug report not found.");
bugs_menu_player();
return;
}
string[] parts=string_split(data, "~", false);
if(parts.length()<6)
{
dlg("Invalid bug report data.");
bugs_menu_player();
return;
}
string b_id=parts[0];
string b_owner=parts[1];
string b_title=parts[2];
string b_flag=parts[3];
string b_comment=string_replace(parts[4], "<<NL>>", "\n", true);
string b_body=string_replace(parts[5], "<<NL>>", "\n", true);
audio_form f;
f.create_window("Bug Report #"+b_id+": "+b_title, false, true);
f.create_input_box("Title", b_title, "", 0, false, true, false);
f.create_input_box("Description", b_body, "", 0, false, true, true);
string flag_display=(b_flag=="" or b_flag=="none") ? "Unflagged" : b_flag;
f.create_input_box("Status", flag_display, "", 0, false, true, false);
if(b_comment!="" and b_comment!="none")
f.create_input_box("Staff comment", b_comment, "", 0, false, true, true);
int f_back=f.create_button("Go &back", false, true);
f.focus(0);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(f_back))
{
bugs_menu_player();
return;
}
}
}

void bugs_menu_staff()
{
speak("Loading all bug reports, please wait.");
send_reliable(0, "bug_list_all", 0);
string data="";
timer wt;
while(wt.elapsed<3000)
{
wait(5);
e=n.request();
