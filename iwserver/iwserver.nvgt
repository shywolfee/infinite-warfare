{
if(files[i]=="next_id.txt") continue;
savedata fb(feedback_dir+"/"+files[i], FEEDBACK_SECRET);
fb.load();
if(fb.read("status")!="open") continue;
if(!first) result+=",";
result+=fb.read("id")+"~"+fb.read("owner")+"~"+fb.read("subject")+"~"+fb.read("status");
