bool is_dv=(parsed.length()>2 and parsed[2]=="dev");
if(is_adm or is_dv)
{
string result="ticket_admin_alllist ";
string[] files=find_files(tickets_dir+"/*.dat");
bool first=true;
for(uint i=0; i<files.length(); i++)
{
if(files[i]=="next_id.txt") continue;
savedata t(tickets_dir+"/"+files[i], TICKET_SECRET);
t.load();
if(t.read("status")!="open") continue;
if(!first) result+=",";
result+=t.read("id")+"~"+t.read("owner")+"~"+t.read("subject")+"~"+t.read("status");
first=false;
}
if(first) result+="none";
send_reliable(e.peer_id, result, 0);
}
}
else if(parsed[0]=="ticket_admin_get" and parsed.length()>2)
{
