players[index].fraggrenadetimer.restart();
}
else
{
int cd_remain=(5000-players[index].fraggrenadetimer.elapsed)/1000;
send_reliable(players[index].peer_id, "You must wait "+cd_remain+" seconds before throwing another grenade.", 2);
}
}
else if(parsed[1]=="bucket")
{
for (uint index2=0; index2<watertanks.length(); index2++)
{
if(players[index].x==watertanks[index2].x and players[index].y==watertanks[index2].y and players[index].z==watertanks[index2].z and players[index].map==watertanks[index2].map)
{
play("watertankfill",players[index].x,players[index].y,players[index].z,players[index].map);
send_reliable(players[index].peer_id, "give bucket -1", 0);
watertanks[index2].water+=1;
send_reliable(players[index].peer_id, "give empty_bucket 1", 0);
send_reliable(players[index].peer_id, "movestop", 0);
players[index].use_bucket=true;
players[index].buckettimer.restart();
}
 }
}
else if(parsed[1]=="empty_bucket")
{
if(get_tile_at(players[index].x, players[index].y, players[index].z, players[index].map)=="shallow" and players[index].torpedotimer.elapsed>3000)
{
send_reliable(players[index].peer_id, "give empty_bucket -1", 0);
play("bucketfill",players[index].x,players[index].y,players[index].z,players[index].map);
send_reliable(players[index].peer_id, "give bucket 1", 0);
}
else
send_reliable(players[index].peer_id, "you have to stand in water to let this wurk...", 0);
}
