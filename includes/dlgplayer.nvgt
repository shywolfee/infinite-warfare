sound dlgaudio;
void dlgplay(string dlgsound, bool dlgfade=false, bool is_online=false, int fadespeed=30)
{
if(!is_online)
dlgaudio.load(dlgsound);
dlgaudio.play();
while(dlgaudio.playing)
{
if (connected) e=n.request();
wait(5);
if(key_pressed(KEY_RETURN))
{
if (dlgfade==true)
{
fade(dlgaudio, -50, fadespeed);
}
dlgaudio.stop();
break;
}
}
}