}
void weaponloop()
{
for(uint i=0; i<weapons.length(); i++)
{
if(weapons[i].speedtimer.elapsed > weapons[i].speedtime)
{
weapons[i].speedtimer.restart();
double theta_h=weapons[i].dir*pi/180;
double h_speed=cosine(weapons[i].vertical_angle*pi/180);
weapons[i].x+=sine(theta_h)*h_speed;
weapons[i].y+=cosine(theta_h)*h_speed;
weapons[i].z+=weapons[i].vertical_velocity;
weapons[i].vertical_velocity-=weapons[i].gravity;
weapons[i].distance++;
if(weapons[i].distance > weapons[i].range)
{
weapons.remove_at(i);
continue;
}
int rx=round(weapons[i].x, 0);
int ry=round(weapons[i].y, 0);
int rz=round(weapons[i].z, 0);
string tile=get_tile_at(rx,ry,rz,weapons[i].map);
if(tile=="wallstone" or tile=="wallwood" or tile=="wallbrick" or tile=="wallgrass" or tile=="wallfence" or tile=="wallrock")
{
play(weapons[i].type+"rico", rx, ry, rz, weapons[i].map);
if(weapons[i].type=="120mm_mortar")
{
spawn_mortarbomb(weapons[i].x,weapons[i].y,weapons[i].z,weapons[i].map,weapons[i].cn);
}
weapons.remove_at(i);
return;
}
}
for(int e=0; e<walls.length(); e++)
{
if (get_3d_distance(weapons[i].x,weapons[i].y,weapons[i].z,walls[e].x,walls[e].y,walls[e].miniz)<=weapons[i].spread and walls[e].map==weapons[i].map)
{
walls[e].health-=random(weapons[i].mindammage,weapons[i].maxdammage);
weapons.remove_at(i);
return;
}
}
for(int e=0; e<ladders.length(); e++)
{
if (get_3d_distance(weapons[i].x,weapons[i].y,weapons[i].z,ladders[e].x,ladders[e].y,ladders[e].miniz)<=weapons[i].spread and ladders[e].map==weapons[i].map)
{
ladders[e].health-=random(weapons[i].mindammage,weapons[i].maxdammage);
weapons.remove_at(i);
return;
}
}

for(int e=0; e<players.length(); e++)
{
if (get_3d_distance(weapons[i].x,weapons[i].y,weapons[i].z,players[e].x,players[e].y,players[e].z)<=weapons[i].spread and players[e].map==weapons[i].map and weapons[i].cn!=players[e].name and players[e].death==false and players[e].in_plane==false)
{
int index=get_player_index_from(weapons[i].cn);
{
if(players[index].mate!=players[e].name or players[e].mate!=players[index].name)
{
 if(weapons[i].type=="120mm_mortar")
{
spawn_mortarbomb(weapons[i].x,weapons[i].y,weapons[i].z,weapons[i].map,weapons[i].cn);
}
send_reliable(players[index].peer_id, "play_s weaponping.ogg", 0);
players[e].hitby=weapons[i].cn+"s "+weapons[i].type;
play(weapons[i].type+"hit"+random(1,3),players[e].x,players[e].y,players[e].z,players[e].map);
players[e].health-=random(weapons[i].mindammage,weapons[i].maxdammage);
weapons.remove_at(i);
return;
}
}
}
}
for(int e=0; e<planes.length(); e++)
{
if (get_3d_distance(weapons[i].x,weapons[i].y,weapons[i].z,planes[e].x,planes[e].y,planes[e].z)<=weapons[i].spread and planes[e].map==weapons[i].map)
{
int index=get_player_index_from(weapons[i].cn);
{
 if(weapons[i].type=="120mm_mortar")
{
spawn_mortarbomb(weapons[i].x,weapons[i].y,weapons[i].z,weapons[i].map,weapons[i].cn);
}
send_reliable(players[index].peer_id, "play_s weaponping.ogg", 0);
play("duoplanehit"+random(1,3),planes[e].x,planes[e].y,planes[e].z,planes[e].map);
planes[e].health-=random(weapons[i].mindammage,weapons[i].maxdammage);
weapons.remove_at(i);
return;
}
}
}

}
}
void spawn_weapon(double x, double y, double z, double dir, double vertical_angle, string type, string cn, string map)
{
weapon w1(x, y, z, dir, vertical_angle, type, cn, map);
weapons.insert_last(w1);
}
