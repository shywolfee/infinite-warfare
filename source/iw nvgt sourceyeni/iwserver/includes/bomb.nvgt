planebomb@[] planebombs(0);
class planebomb
{
timer bombtimer;
int x;
int y;
int z;
string map;
string  owner;
planebomb(int bx,int by,int bz,string bmap,string bowner)
{
x=bx;
y=by;
z=bz;
map=bmap;
owner=bowner;
}
}
void planebombloop()
{
for (uint i=0; i<planebombs.length(); i++)
{
if (planebombs[i].bombtimer.elapsed>=80 and get_tile_at(planebombs[i].x, planebombs[i].y, planebombs[i].z, planebombs[i].map)=="")
{
planebombs[i].bombtimer.restart();
planebombs[i].z-=1;
}
if(get_tile_at(planebombs[i].x, planebombs[i].y, planebombs[i].z, planebombs[i].map)!="")
{
play("planebombexplode",planebombs[i].x,planebombs[i].y,planebombs[i].z,planebombs[i].map);
send_reliable(0,"distsound planebombdist.ogg "+planebombs[i].x+" "+planebombs[i].y+" "+planebombs[i].z+" "+planebombs[i].map,0);
for (uint i2=0; i2<players.length(); i2++)
{
if (get_3d_distance(planebombs[i].x,planebombs[i].y,planebombs[i].z,players[i2].x,players[i2].y,players[i2].z)<=20 and players[i2].map==planebombs[i].map and players[i2].death==false and players[i2].in_plane==false)
{
players[i2].hitby=planebombs[i].owner+"'s planebomb";
players[i2].health-=random(6000,7000);
play("planebombhit",players[i2].x,players[i2].y,players[i2].z,players[i2].map);
}
}
for (uint i2=0; i2<planes.length(); i2++)
{
if (get_3d_distance(planebombs[i].x,planebombs[i].y,planebombs[i].z,planes[i2].x,planes[i2].y,planes[i2].z)<=20 and planes[i2].map==planebombs[i].map)
{
planes[i2].health-=random(6000,7000);
play("duoplanebombhit",planes[i2].x,planes[i2].y,planes[i2].z,planes[i2].map);
}
}
planebombs.remove_at(i);
return;
}
}
}
