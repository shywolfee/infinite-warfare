void main()
{
sound_global_hrtf=true;

p.behind_pitch_decrease=6;
distpool.pan_step=0.2;
distpool.volume_step=0.1;
weapons.insert_last("empty");
// Beta: players start with a full weapon + generous reserve magazines.
// register_gun(name, ammo_type, feed_device, mag_capacity, spare_mags, reload_ms)
register_gun("glock17",                "9x19mm Parabellum",     "17-round magazine",      17, 10, 2000);
register_gun("beretta92fs_pistol",     "9x19mm Parabellum",     "15-round magazine",      15, 10, 2000);
register_gun("taurus_model66_revolver",".357 Magnum",           "6-round cylinder",        6, 12, 3500);
register_gun("magnum_revolver",        ".44 Magnum",            "6-round cylinder",        6, 12, 3500);
register_gun("p90_mp",                 "FN 5.7x28mm",           "50-round magazine",       50,  6, 2000);
register_gun("hk_g36",                 "5.56x45mm NATO",        "30-round magazine",       30,  8, 2500);
register_gun("AK47",                   "7.62x39mm",             "30-round magazine",       30,  8, 2500);
register_gun("tar_21_assault_rifle",   "5.56x45mm NATO",        "30-round magazine",       30,  8, 2500);
register_gun("famas_f1_assault_rifle", "5.56x45mm NATO",        "25-round magazine",       25,  8, 2500);
register_gun("benelli_m4_shotgun",     "12-gauge buckshot",     "8-round tube magazine",    8,  8, 5000);
register_gun("ks123shotgun",           "12-gauge buckshot",     "5-round tube magazine",    5,  8, 5000);
register_gun("m1garantBattleRifle",    ".30-06 Springfield",    "8-round en-bloc clip",     8,  8, 2000);
register_gun("sg08_sniper_rifle",      ".308 Winchester",       "10-round magazine",       10,  5, 3000);
register_gun("120mm_mortar",           "120mm HE mortar shell", "single-load barrel",       1,  5, 8000);
create_buffer("all");
create_buffer("chats");
create_buffer("misc");
if (!directory_exists(prefsdir))
directory_create(prefsdir);
accounts_dir="iwserver/accounts";
if (!directory_exists(accounts_dir))
directory_create(accounts_dir);
readprefs();
set_sound_storage("sounds.dat");
set_sound_decryption_key("roflagerfkseuihfdruifysegyksGTRYHTTRGYJTHYT^$%%^#$%&^DTGRFGgdfygeyfgyjedfgydfgvGGBDGTRHR$#$5463r427547gERGRGHERsdfghjkl69",true);
if(file_exists("net.txt"))
{
netaddress="localhost";
}
show_game_window(gamename+"!, version "+version);
if (screen_reader_is_running(1))
install_keyhook();
//cfu("iw","iw.zip",true);
dlgplay("logo.ogg", true, false, 15);
mainmenu();
}
void game(int first)
{
plane.stop();
send_reliable(1, "spawn_player "+me.x+" "+me.y+" "+me.z+" "+mapname+" "+name, 0);
send_reliable(0, "send_comp "+comp, 0);
send_reliable(0, "send_mate "+mate, 0);
send_reliable(0, "admin", 0);
if(SCRIPT_COMPILED==false)
{
send_reliable(1, "is_dev" , 0);
}
if(first==1)
{
send_reliable(0, "welcome", 0);
}
while(true)
{
wait(5);
netloop();
mainloop();
mouse_update();
mousey=MOUSE_Y/3;
mousex=MOUSE_X/8;
mousez=MOUSE_Z/6;
if(pingtimer.elapsed > 10000 and pinging==true)
{
p.play_stationary("pingstop.ogg", false);
speak("Ping failed");
pinging=false;
}
if (key_down(KEY_G))
{
if (key_pressed(KEY_T))
{
playcamera();
}
if (kpgdn.pressing)
{
camera.z-=1;
playcamera();
} 
if (kpgup.pressing)
{
camera.z+=1;
playcamera();
}
if (kleft.pressing)
{
camera=move(camera.x, camera.y, camera.z, facing, west);
playcamera();
}
if (kright.pressing)
{
camera=move(camera.x, camera.y, camera.z, facing, east);
playcamera();
}
if (kdown.pressing)
{
camera=move(camera.x, camera.y, camera.z, facing, south);
playcamera();
}
if (kup.pressing)
{
camera=move(camera.x, camera.y, camera.z, facing, north);
playcamera();
}
}
if (key_up(KEY_G))
{
camera.x=mr.x;
camera.y=mr.y;
camera.z=me.z;
}
if(key_pressed(KEY_HOME) and get_sound_master_volume()<0)
{
set_sound_master_volume(get_sound_master_volume()+5);
}
if(key_pressed(KEY_END) and get_sound_master_volume()>-60)
{
set_sound_master_volume(get_sound_master_volume()-5);
}
if (key_pressed(KEY_TAB) and key_up(KEY_LMENU) and key_up(KEY_RMENU))
{
if (shift_is_down())
cycle_inv(0);
else
cycle_inv(1);
p.play_stationary("invmove.ogg", false);
}
if (key_pressed(KEY_M))
{
send_reliable(0,"whatnear",0);
}
if (key_pressed(KEY_P))
{
send_reliable(0,"nearplayers",0);
}
if (weapons[w]=="hk_g36" or weapons[w]=="AK47" or weapons[w]=="p90_mp" or weapons[w]=="tar_21_assault_rifle")
{
can_fire=true;
}
else if (weapons[w]!="hk_g36" or weapons[w]!="AK47" or weapons[w]!="p90_mp" or weapons[w]!="tar_21_assault_rifle")
{
can_fire=false;
}
if(can_move==true and !is_reloading(weapons[w]))
{
if (firetimer.elapsed>=firetime and key_down(KEY_LCONTROL) and can_fire==true and mapname!="battle_royale_waiting" or firetimer.elapsed>=firetime and key_down(KEY_RCONTROL)&&rctrl==1 and can_fire==true and mapname!="battle_royale_waiting" or firetimer.elapsed>=firetime and key_pressed(KEY_LCONTROL) and mapname!="battle_royale_waiting" or firetimer.elapsed>=firetime and key_pressed(KEY_RCONTROL)&&rctrl==1 and mapname!="battle_royale_waiting")
{
int weapon_ammo=ammo_check(weapons[w]);
if(weapon_ammo>0 or melee==true)
{
ammo_give(weapons[w], -1);
firetimer.restart();
send_reliable(0,"fire "+weapons[w],0);
}
else if(weapon_ammo==0 and firetimer.elapsed>=firetime)
{
firetimer.restart();
p.play_stationary(weapons[w]+"empty.ogg",false);
can_fire=false;
speak("Magazine empty. Press R to reload.");
}
}
}
if(key_pressed(KEY_A))
{
announce_ammo(weapons[w]);
}
if(key_pressed(KEY_R) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT))
{
start_reload(weapons[w]);
}
if(key_pressed(KEY_R) and (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT)))
{
unload_mag(weapons[w]);
}
if (key_pressed(KEY_SLASH))
{
string chat=v.input("Enter your message","",true);
if (chat!="")
send_reliable(0,chat,1);
}
if (key_pressed(KEY_H) and key_up(KEY_LSHIFT))
{
send_reliable(0,"health",0);
}
if (key_pressed(KEY_B))
{
if (get_zone_at(mr.x,mr.y,me.z)!="")
{
string locate=get_zone_at(mr.x,mr.y,me.z);
speak("Current zone: "+locate+" of "+mapname);
}
else
{
speak("Current zone: unknown area of "+mapname);
}
}
if (key_pressed(KEY_F1))
{
send_reliable(0,"whoonline",0);
}
if(key_pressed(KEY_F3) and pinging==false)
{
send_reliable(1, "ping", 0);
p.play_stationary("pingstart.ogg", false);
pingtimer.restart();
pinging=true;
}
if(key_pressed(KEY_F2))
{
send_reliable(0, "motd", 0);
}
if(key_pressed(KEY_GRAVE))
{
gamemenu();
}
if(key_pressed(KEY_W) and tracking!="")
{
send_reliable(1, "trackinfo "+tracking, 0);
}
if(key_pressed(KEY_T))
{
send_reliable(1, "playermenu", 0);
}
if (key_pressed(KEY_LBRACKET))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
firstbuffer();
}
else
{
bufferleft();
}
}
if (key_pressed(KEY_RBRACKET))
{
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
lastbuffer();
}
else
{
bufferright();
}
}
if (key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT))
{
if(key_pressed(KEY_RETURN) and mapname!="battle_royale_waiting" and usetimer.elapsed>n.get_peer_average_round_trip_time(1)+100 and can_move==true or mouse_pressed(2) and usetimer.elapsed>n.get_peer_average_round_trip_time(1)+100 and can_move==true and mapname!="battle_royale_waiting")
{
usetimer.restart();
if (inv.get_keys().length()>0 and invpos<inv.get_size())
send_reliable(0, "use "+inv.get_keys()[invpos], 0);
else
speak("Your inventory is empti.");
}
if(key_pressed(KEY_O) and can_move==true)
{
send_reliable(0, "check_chest", 0);
}
if (kCOMMA.pressing)
{
prevbufferitem();
}
if (kPERIOD.pressing)
{
nextbufferitem();
}
}
if (key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
if (key_pressed(KEY_COMMA))
{
topbufferitem();
}
if (key_pressed(KEY_PERIOD))
{
bottombufferitem();
}
}
if(key_pressed(KEY_ESCAPE) and x==false)
{
int q;
q=yesno("Are you sure you wish to exit the game?");
if(q==1)
{
speak("Exiting the game");
send_reliable(0, "close", 0);
x=true;
xtimer.restart();
}
}
if(xtimer.elapsed>10 and x==true)
{
x=false;
exitgame();
}
if(key_pressed(KEY_C))
{
speak(mr.x+", "+mr.y+", "+me.z);
}
if(key_pressed(KEY_SPACE) and jumping==false and falling==false and can_move==true)
{
p.play_stationary("jump.ogg", false);
send_reliable(0, "jump", 0);
jumping=true;
jumptimer.restart();
jumpup=1;
jumplandz=me.z;
}
if(mousez<0) 
{
cycle_inv(0);
p.play_stationary("inv"+random(1, 7)+".ogg", false);
}
if(mousez>0) 
{
cycle_inv(1);
p.play_stationary("inv"+random(1, 7)+".ogg", false);
}
if(key_pressed(KEY_Q) and shift_is_down())
{
turntimer.restart();
facing=turnleft(facing, 1);
speak(facing+" degrees");
p.play_stationary("turn.ogg", false);
send_reliable(0, "turn "+facing, 0);
}
else if(key_pressed(KEY_Q) or mousex<0 and key_up(KEY_LMENU) and key_up(KEY_RMENU) and turntimer.elapsed >200)
{
turntimer.restart();
facing=snapleft(facing, getdir(facing));
speak(dir_to_string(getdir(facing)));
p.play_stationary("turn.ogg", false);
send_reliable(0, "turn "+facing, 0);
mouse_update();
}
if(key_pressed(KEY_X) and shift_is_down() and turn>0)
{
turn-=1;
p.play_stationary("turn.ogg", false);
speak("vertical "+turn+" degrees");
send_reliable(0, "turn2 "+turn, 0);
}
else if(key_pressed(KEY_X) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and turn>0)
{
if(turn>90)
turn=90;
else
turn=0;
p.play_stationary("turn.ogg", false);
string s="";
if(turn==90)
s="straight forward";
else if(turn==0)
s="straight down";
speak("facing "+s);
send_reliable(0, "turn2 "+turn, 0);
}
if(key_pressed(KEY_S) and shift_is_down() and turn<180)
{
turn+=1;
p.play_stationary("turn.ogg", false);
speak("vertical "+turn+" degrees");
send_reliable(0, "turn2 "+turn, 0);
}
else if(key_pressed(KEY_S) and key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and turn<180)
{
if(turn<90)
turn=90;
else
turn=180;
p.play_stationary("turn.ogg", false);
string s="";
if(turn==90)
s="straight forward";
else if(turn==180)
s="straight up";
speak("facing "+s);
send_reliable(0, "turn2 "+turn, 0);
}
if(key_pressed(KEY_E) and shift_is_down())
{
turntimer.restart();
facing=turnright(facing, 1);
speak(facing+" degrees");
p.play_stationary("turn.ogg", false);
send_reliable(0, "turn "+facing, 0);
}
else if(key_pressed(KEY_E) or mousex>0 and key_up(KEY_LMENU) and key_up(KEY_RMENU) and turntimer.elapsed >200)
{
turntimer.restart();
facing=snapright(facing, getdir(facing));
speak(dir_to_string(getdir(facing)));
p.play_stationary("turn.ogg", false);
send_reliable(0, "turn "+facing, 0);
mouse_update();
}
if(key_pressed(KEY_F))
{
string vert_info="";
if(turn==90) vert_info=", aiming straight forward";
else if(turn==0) vert_info=", aiming straight down";
else if(turn==180) vert_info=", aiming straight up";
else if(turn<90) vert_info=", aiming "+turn+" degrees vertical";
else vert_info=", aiming "+turn+" degrees vertical";
speak("You are facing "+dir_to_string(getdir(facing))+" at "+facing+" degrees"+vert_info+".");
}
if(MENU_is_down())
{
if(key_down(KEY_LEFT))
{
facing=turnleft(facing, 1);
}
if(key_down(KEY_RIGHT))
{
facing=turnright(facing, 1);
}
}
if(!MENU_is_down() and key_up(KEY_G) and can_move==true)
{
if(key_down(KEY_PRIOR) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Up);
}
else if(key_down(KEY_NEXT) and walktimer.elapsed>movetime) 
{
walktimer.restart();
move(Down);
}
if(key_down(KEY_UP) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Forward);
}
else if(key_down(KEY_DOWN) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Backward);
}
else if(key_down(KEY_LEFT) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Left);
}
else if(key_down(KEY_RIGHT) and walktimer.elapsed>movetime)
{
walktimer.restart();
move(Right);
}
}
if(can_move==true)
{
if(key_up(KEY_LSHIFT) and key_up(KEY_RSHIFT) and drawtimer.elapsed >1500)
{
if(key_pressed(KEY_1))
{
drawtimer.restart();
weapons[w]="machete";
speak("machete");
send_reliable(1, "draw  machete", 0);
}
if(key_pressed(KEY_2))
{
drawtimer.restart();
weapons[w]="glock17";
speak("glock17");
send_reliable(1, "draw  glock17", 0);
}
if(key_pressed(KEY_3))
{
drawtimer.restart();
weapons[w]="benelli_m4_shotgun";
speak("benelli_m4_shotgun");
send_reliable(1, "draw  benelli_m4_shotgun", 0);
}
if(key_pressed(KEY_4))
{
drawtimer.restart();drawtimer.restart();
weapons[w]="beretta92fs_pistol";
speak("beretta92fs_pistol");
send_reliable(1, "draw  beretta92fs_pistol", 0);
}
if(key_pressed(KEY_5))
{
drawtimer.restart();
weapons[w]="magnum_revolver";
speak("magnum_revolver");
send_reliable(1, "draw  magnum_revolver", 0);
}
if(key_pressed(KEY_6))
{
drawtimer.restart();
weapons[w]="hk_g36";
speak("hk_g36");
send_reliable(1, "draw  hk_g36", 0);
}
if(key_pressed(KEY_7))
{
drawtimer.restart();
weapons[w]="AK47";
speak("AK47");
send_reliable(1, "draw  AK47", 0);
}
if(key_pressed(KEY_8))
{
drawtimer.restart();
weapons[w]="m1garantBattleRifle";
speak("m1garantBattleRifle");
send_reliable(1, "draw  m1garantBattleRifle", 0);
}
if(key_pressed(KEY_9))
{
drawtimer.restart();
weapons[w]="sg08_sniper_rifle";
speak("sg08_sniper_rifle");
send_reliable(1, "draw  sg08_sniper_rifle", 0);
}
if(key_pressed(KEY_0))
{
drawtimer.restart();
weapons[w]="famas_f1_assault_rifle";
speak("famas_f1_assault_rifle");
send_reliable(1, "draw famas_f1_assault_rifle", 0);
}
}
if(key_down(KEY_LSHIFT) and drawtimer.elapsed >1500 or key_down(KEY_RSHIFT) and drawtimer.elapsed >1500)
{
if(key_pressed(KEY_1))
{
drawtimer.restart();
weapons[w]="combatknife";
speak("combat knife");
send_reliable(1, "draw combatknife", 0);
}
if(key_pressed(KEY_2))
{
drawtimer.restart();
weapons[w]="taurus_model66_revolver";
speak("taurus_model66_revolver");
send_reliable(1, "draw taurus_model66_revolver", 0);
}
if(key_pressed(KEY_3))
{
drawtimer.restart();
weapons[w]="tar_21_assault_rifle";
speak("tar_21_assault_rifle");
send_reliable(1, "draw tar_21_assault_rifle", 0);
}
if(key_pressed(KEY_4))
{
drawtimer.restart();
weapons[w]="120mm_mortar";
speak("120mm_mortar");
send_reliable(1, "draw 120mm_mortar", 0);
}
}
}
}
}
bool shift_is_down()
{
if(key_down(KEY_LSHIFT) or key_down(KEY_RSHIFT))
{
return true;
}
return false;
}
bool MENU_is_down()
{
if(key_down(KEY_LMENU) or key_down(KEY_RMENU))
{
return true;
}
return false;
}
bool control_is_down()
{
if(key_down(KEY_LCONTROL) or key_down(KEY_RCONTROL))
{
return true;
}
return false;
}
void readprefs()
{
sd.load();
if (sd.d.exists("name"))
name=sd.read("name");
if (sd.d.exists("mate"))
mate=sd.read("mate");
if (sd.d.exists("rctrl"))
rctrl=sd.readn("rctrl");
if (sd.d.exists("cameraspeed"))
cameraspeed=sd.readn("cameraspeed");
if (sd.d.exists("mastervol"))
{
mastervol=sd.readn("mastervol");
set_sound_master_volume(mastervol);
}
}
void writeprefs()
{
sd.add("name",name);
sd.add("mate",mate);
sd.add("rctrl",rctrl);
sd.add("cameraspeed",cameraspeed);
sd.add("mastervol",mastervol);
sd.save();
}
