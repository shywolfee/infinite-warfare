void builder_menu()
{
audio_form f;
f.create_window("Builder - "+mapname, false, true);
int f_list=f.create_list("Builder options", 0, false);
f.add_list_item(f_list, "Add element");
f.add_list_item(f_list, "Edit line");
f.add_list_item(f_list, "Delete line");
f.add_list_item(f_list, "Edit map");
f.add_list_item(f_list, "Delete map");
int ok_btn=f.create_button("OK", true);
int cancel_btn=f.create_button("Close", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(cancel_btn)) return;
if(f.is_pressed(ok_btn))
{
int sel=f.get_list_position(f_list);
if(sel==0) builder_add_element();
else if(sel==1) builder_edit_line_menu();
else if(sel==2) builder_delete_line_menu();
else if(sel==3) builder_edit_map();
else if(sel==4) builder_delete_map();
}
}
}

// ---------------------------------------------------------------------------
// Command menu (Alt+C).
// Lists all slash commands and sends the selected one to the server.
// ---------------------------------------------------------------------------
void command_menu()
{
audio_form f;
f.create_window("Commands", false, true);
int f_list=f.create_list("Select a command", 0, false);
// Player commands
f.add_list_item(f_list, "/bunkers - Show bunker locations");
f.add_list_item(f_list, "/duomate [name] - Check a player's duo mate");
f.add_list_item(f_list, "/d [message] - Send a duo chat message");
f.add_list_item(f_list, "/pm [name] [message] - Private message a player");
f.add_list_item(f_list, "/feedback [message] - Submit feedback");
f.add_list_item(f_list, "/changes - View the changelog");
f.add_list_item(f_list, "/start_admin - Activate admin (if authorized)");
if (SCRIPT_COMPILED==false)
{
f.add_list_item(f_list, "/reboot - Reboot the server (dev)");
f.add_list_item(f_list, "/kick [name] - Kick a player (dev/admin)");
f.add_list_item(f_list, "/go [x y z] - Teleport to coordinates (dev/admin)");
f.add_list_item(f_list, "/ban [name] - Ban a player (dev/admin)");
f.add_list_item(f_list, "/newadmin [name] - Add an admin (dev)");
f.add_list_item(f_list, "/notify [message] - Broadcast a message (dev/admin)");
f.add_list_item(f_list, "/motd [message] - Set message of the day (dev/admin)");
f.add_list_item(f_list, "/give [name item amount] - Give items (dev/admin)");
f.add_list_item(f_list, "/givemyself [item amount] - Give items to self (admin)");
f.add_list_item(f_list, "/getmyshit - Get all world items (dev)");
f.add_list_item(f_list, "/removeitems - Remove all world items (dev)");
f.add_list_item(f_list, "/getfeedback - View feedback (dev)");
}
int f_run=f.create_button("&Run", true);
int f_close=f.create_button("&Close", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if (connected==true)
netloop();
if (f.is_pressed(f_run))
{
int sel=f.get_list_position(f_list);
string item=f.get_list_item(f_list, sel);
// Extract the command part (before " - ")
string cmd=item;
int dash=string_contains(cmd, " - ", 1);
if (dash>-1) cmd=string_mid(cmd, 0, dash);
// If command has parameters (brackets), prompt the user for input
if (string_contains(cmd, "[", 1)>-1)
{
// Extract the base command (before first bracket)
int bracket=string_contains(cmd, " [", 1);
string base=cmd;
if (bracket>-1) base=string_mid(cmd, 0, bracket);
string args=v.input("Enter arguments for "+base, "", true);
if (args!="")
{
send_reliable(0, base+" "+args, 1);
speak("Command sent.");
}
}
else
{
send_reliable(0, cmd, 1);
speak("Command sent.");
}
break;
}
else if (f.is_pressed(f_close))
{
break;
}
}
}

// ---------------------------------------------------------------------------
// Documentation / Help system.
// Reads .txt files from iwserver/docs/.
// ---------------------------------------------------------------------------
string[] get_help_entries(bool include_dev=false)
{
string[] entries;
string docs_dir = "iwserver/docs";
if (!directory_exists(docs_dir))
docs_dir = "docs";
// Scan known doc files
string[] known_docs = {
"getting_started", "controls", "turning_and_aiming", "fire_modes", "stamina", "equipment", "buffs_debuffs",
"modes", "battlegrounds_map", "habitat_alpha_map", "archipelago_map",
"commands", "duo_system", "bunkers", "inventory_system", "ammo_system", "rewards",
"machete", "combatknife", "katana", "baseball_bat",
"glock17", "beretta92fs_pistol", "taurus_model66_revolver", "magnum_revolver", "desert_eagle",
"p90_mp", "mp5", "uzi", "mp7",
"hk_g36", "AK47", "tar_21_assault_rifle", "famas_f1_assault_rifle", "m4a1_carbine",
"scar_h_battle_rifle", "fn_fal_battle_rifle",
"rpk_lmg", "m249_saw",
"benelli_m4_shotgun", "ks123shotgun", "spas_12_shotgun",
"m1garantBattleRifle", "sg08_sniper_rifle", "awp_sniper_rifle", "dragunov_svd",
"120mm_mortar", "ballista", "crossbow",
"hayvork", "trector_plow",
"laser_pistol", "laser_smg", "laser_rifle", "laser_sniper", "laser_cannon",
"flamethrower", "chainsaw",
"health_potion", "ultra_health_potion", "frag_grenade",
"energetic_potion_red", "energetic_potion_blue", "energetic_potion_green", "energetic_potion_rainbow"
};
for (uint i = 0; i < known_docs.length(); i++)
{
string path = docs_dir + "/" + known_docs[i] + ".txt";
if (file_exists(path))
entries.insert_last(known_docs[i]);
}
if (include_dev)
{
string[] dev_docs = {
"dev_commands", "dev_admin_system", "dev_network_architecture", "dev_map_format"
};
for (uint i = 0; i < dev_docs.length(); i++)
{
string path = docs_dir + "/" + dev_docs[i] + ".txt";
if (file_exists(path))
entries.insert_last(dev_docs[i]);
}
}
return entries;
}

string read_help_file(string entry_name)
{
string docs_dir = "iwserver/docs";
if (!directory_exists(docs_dir))
docs_dir = "docs";
string path = docs_dir + "/" + entry_name + ".txt";
if (!file_exists(path))
return "No help available for " + string_replace(entry_name, "_", " ", true) + ".";
file f;
if (!f.open(path, "rb"))
return "Could not open help file.";
string content = f.read();
f.close();
return content;
}

void show_help_entry(string entry_name)
{
string content = read_help_file(entry_name);
audio_form f;
f.create_window("Help: " + string_replace(entry_name, "_", " ", true), false, true);
f.create_input_box("Content", content, "", 0, false, true, false);
int f_close = f.create_button("&Close", true, true);
f.focus(0);
while(true)
{
wait(5);
f.monitor();
if (connected==true)
netloop();
if (f.is_pressed(f_close))
break;
}
}

void show_help_list()
{
string[] entries = get_help_entries(SCRIPT_COMPILED==false);
if (entries.length() == 0)
{
speak("No help entries found.");
return;
}
audio_form f;
f.create_window("Help Topics", false, true);
int f_list = f.create_list("Select a topic", 0, false);
for (uint i = 0; i < entries.length(); i++)
{
f.add_list_item(f_list, string_replace(entries[i], "_", " ", true));
}
int f_open = f.create_button("&Open", true);
int f_close = f.create_button("&Close", false, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if (connected==true)
netloop();
if (f.is_pressed(f_open))
{
int sel = f.get_list_position(f_list);
if (sel >= 0 and sel < int(entries.length()))
{
show_help_entry(entries[sel]);
}
}
else if (f.is_pressed(f_close))
{
break;
}
}
}

void show_item_help(string item)
{
string content = read_help_file(item);
if (string_contains(content, "No help available", 1) == 0)
{
speak("No help entry for " + string_replace(item, "_", " ", true) + ".");
return;
}
show_help_entry(item);
}

// ---------------------------------------------------------------------------
// Quickbar weapons view (Shift+I).
// ---------------------------------------------------------------------------
void show_quickbar_weapons()
{
audio_form f;
f.create_window("Quickbar Weapons", false, true);
int f_list = f.create_list("Weapons in quickbar", 0, false);
int count = 0;
for (int i = 0; i < 10; i++)
{
if (quickbar[i] != "" and is_weapon(quickbar[i]))
{
string label = "Slot " + (i+1) + ": " + get_weapon_display_name(quickbar[i]);
int ammo = ammo_check(quickbar[i]);
if (ammo >= 0)
{
int qgi = find_gun(quickbar[i]);
if (qgi >= 0 and gun_ammos[qgi].ammo_display == "charge")
label += " (" + get_ammo_percentage(ammo, gun_ammos[qgi].mag_capacity) + "% charge)";
else if (qgi >= 0 and gun_ammos[qgi].ammo_display == "fuel")
label += " (" + get_ammo_percentage(ammo, gun_ammos[qgi].mag_capacity) + "% fuel)";
else
label += " (" + ammo + " loaded)";
}
f.add_list_item(f_list, label);
count++;
}
}
if (count == 0)
{
f.add_list_item(f_list, "No weapons in quickbar.");
}
int f_close = f.create_button("&Close", true, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if (connected==true)
netloop();
if (f.is_pressed(f_close))
break;
}
}

// ---------------------------------------------------------------------------
// Item use side effects — apply buffs/effects on the client when items are used.
// Called from use_quickbar_slot and Enter key use path.
// ---------------------------------------------------------------------------
void on_item_used(string item)
{
if (item == "health_potion")
apply_residual_healing();
else if (item == "ultra_health_potion")
apply_ultra_residual_healing();
else if (item == "bomb_vest")
{
equip_item("bomb_vest", "body");
speak("Bomb vest equipped.");
}
else if (item == "energetic_potion_red")
{
restore_stamina(random(15, 25));
give("energetic_potion_red", -1);
speak("Stamina restored. " + get_stamina_string());
}
else if (item == "energetic_potion_blue")
{
restore_stamina(random(25, 40));
give("energetic_potion_blue", -1);
speak("Stamina restored. " + get_stamina_string());
}
else if (item == "energetic_potion_green")
{
restore_stamina(random(40, 60));
give("energetic_potion_green", -1);
speak("Stamina restored. " + get_stamina_string());
}
else if (item == "energetic_potion_rainbow")
{
restore_stamina(random(75, 100));
give("energetic_potion_rainbow", -1);
speak("Stamina fully restored. " + get_stamina_string());
}
else if (item == "translocator")
{
show_translocator_interface();
return;
}
else if (item == "translocator_cell")
{
use_translocator_cell();
return;
}
else if (item == "adrenaline_syringe")
{
apply_adrenaline_rush();
give("adrenaline_syringe", -1);
speak("Adrenaline rush! Movement speed doubled for 30 seconds.");
return;
}
else if (item == "repair_kit")
{
use_repair_kit();
return;
}
else if (item == "waypoint_marker")
{
use_waypoint_marker();
return;
}
else if (item == "binoculars")
{
use_binoculars();
return;
}
else if (item == "fortified_ration")
{
restore_stamina(random(35, 50));
give("fortified_ration", -1);
speak("Ration consumed. " + get_stamina_string());
}
else if (item == "c4")
{
send_reliable(0, "use_c4", 0);
return;
}
else if (item == "hypercomp")
{
hypercomp_menu();
return;
}
else if (is_attachment_item(item))
{
use_attachment_item(item);
return;
}
else if (is_holster_item(item))
{
equip_holster_item(item);
return;
}
else if (is_ammo_container(item) or string_contains(item, "ammo_belt", 1)>-1 or string_contains(item, "shell_box", 1)>-1)
{
if(try_store_ammo_in_belt(item)) return;
}
}
void use_attachment_item(string item)
{
string current_weapon=weapons[w];
if(current_weapon=="" or current_weapon=="empty")
{
speak("Draw a weapon first.");
return;
}
if(!can_attach_to(item, current_weapon))
{
speak("This attachment is not compatible with the "+get_weapon_display_name(current_weapon)+".");
return;
}
int def_idx=find_attachment_def(item);
if(def_idx<0) return;
if(weapon_has_attachment_in_slot(current_weapon, attachment_defs[def_idx].slot))
{
speak("This weapon already has an attachment in the "+attachment_defs[def_idx].slot+" slot.");
return;
}
if(attach_to_weapon(item, current_weapon))
{
give(item, -1);
apply_weapon_stats(current_weapon);
speak(attachment_defs[def_idx].display_name+" attached to "+get_weapon_display_name(current_weapon)+".");
send_reliable(0, "attach "+item+" "+current_weapon, 0);
}
}
void equip_holster_item(string item)
{
if(equip_holster1!="" and equip_holster2!="")
{
speak("Both holster slots are full. Remove one first.");
return;
}
int slot=0;
if(equip_holster1=="" and equip_holster2=="")
{
slot=1;
}
else if(equip_holster1=="")
slot=1;
else
slot=2;
if(equip_holster1!="" and equip_holster2=="")
{
audio_form sf;
sf.create_window("Select Holster Slot", false, true);
int sl=sf.create_list("Slot", 0, false);
sf.add_list_item(sl, "Holster 1: "+get_holster_slot_label(1));
sf.add_list_item(sl, "Holster 2: empty");
int ok=sf.create_button("OK", true);
int cancel=sf.create_button("Cancel", false, true);
sf.focus(sl);
while(true)
{
wait(5);
sf.monitor();
if(sf.is_pressed(cancel)) return;
if(sf.is_pressed(ok))
{
int s=sf.get_list_position(sl);
if(s==0){speak("Holster 1 is already occupied.");continue;}
slot=2;
break;
}
}
}
give(item, -1);
if(slot==1) equip_holster1=item;
else equip_holster2=item;
int idx=find_holster_def(item);
string dn=(idx>=0)?holster_defs[idx].display_name:string_replace(item,"_"," ",true);
speak(dn+" equipped in holster "+slot+".");
}
void holster_current_weapon()
{
string wname=weapons[w];
if(wname=="" or wname=="empty")
{
draw_from_holster();
return;
}
int[] valid_slots;
for(int s=1; s<=2; s++)
{
string hid=(s==1)?equip_holster1:equip_holster2;
if(hid=="") continue;
string hw=(s==1)?holster1_weapon:holster2_weapon;
if(hw!="") continue;
if(holster_supports_weapon(hid, wname))
valid_slots.insert_last(s);
}
if(valid_slots.length()==0)
{
speak("No empty compatible holster equipped.");
return;
}
int slot=valid_slots[0];
if(valid_slots.length()>1)
{
audio_form sf;
sf.create_window("Select Holster", false, true);
int sl=sf.create_list("Holster", 0, false);
for(uint i=0; i<valid_slots.length(); i++)
{
string hid=(valid_slots[i]==1)?equip_holster1:equip_holster2;
int idx=find_holster_def(hid);
string dn=(idx>=0)?holster_defs[idx].display_name:hid;
sf.add_list_item(sl, "Holster "+valid_slots[i]+": "+dn);
}
int ok=sf.create_button("OK", true);
int cancel=sf.create_button("Cancel", false, true);
sf.focus(sl);
while(true)
{
wait(5);
sf.monitor();
if(sf.is_pressed(cancel)) return;
if(sf.is_pressed(ok))
{
int s=sf.get_list_position(sl);
if(s>=0 and s<int(valid_slots.length()))
{slot=valid_slots[s];break;}
}
}
}
int ammo=ammo_check(wname);
if(ammo<0) ammo=0;
if(slot==1){holster1_weapon=wname;holster1_weapon_ammo=ammo;}
else{holster2_weapon=wname;holster2_weapon_ammo=ammo;}
give(wname, -1);
weapons[w]="empty";
melee=false;
firetime=500;
walktime=200;
string hid=(slot==1)?equip_holster1:equip_holster2;
int idx=find_holster_def(hid);
string dn=(idx>=0)?holster_defs[idx].display_name:hid;
speak(get_weapon_display_name(wname)+" holstered in "+dn+".");
}
void draw_from_holster()
{
bool h1_has=(holster1_weapon!="");
bool h2_has=(holster2_weapon!="");
if(!h1_has and !h2_has)
{
speak("No weapons holstered.");
return;
}
int slot=0;
if(h1_has and !h2_has) slot=1;
else if(!h1_has and h2_has) slot=2;
else
{
audio_form sf;
sf.create_window("Draw Weapon", false, true);
int sl=sf.create_list("Holstered weapons", 0, false);
string h1_label=holster1_weapon;
int idx1=find_holster_def(equip_holster1);
string dn1=(idx1>=0)?holster_defs[idx1].display_name:equip_holster1;
string label1=dn1+": "+get_weapon_display_name(holster1_weapon)+" ("+holster1_weapon_ammo+" loaded)";
sf.add_list_item(sl, label1);
int idx2=find_holster_def(equip_holster2);
string dn2=(idx2>=0)?holster_defs[idx2].display_name:equip_holster2;
string label2=dn2+": "+get_weapon_display_name(holster2_weapon)+" ("+holster2_weapon_ammo+" loaded)";
sf.add_list_item(sl, label2);
int ok=sf.create_button("OK", true);
int cancel=sf.create_button("Cancel", false, true);
sf.focus(sl);
while(true)
{
wait(5);
sf.monitor();
if(sf.is_pressed(cancel)) return;
if(sf.is_pressed(ok))
{
int s=sf.get_list_position(sl);
if(s==0) slot=1;
else slot=2;
break;
}
}
}
string wname=(slot==1)?holster1_weapon:holster2_weapon;
int ammo=(slot==1)?holster1_weapon_ammo:holster2_weapon_ammo;
int belt_ammo=(slot==1)?holster1_belt_ammo:holster2_belt_ammo;
string hid=(slot==1)?equip_holster1:equip_holster2;
give(wname, 1);
int gi=find_gun(wname);
if(gi>=0) gun_ammos[gi].mag_loaded=ammo;
int idx=find_holster_def(hid);
if(idx>=0 and holster_defs[idx].has_ammo_storage and belt_ammo>0 and gi>=0)
{
int need=gun_ammos[gi].mag_capacity-gun_ammos[gi].mag_loaded;
if(need>0)
{
int reload_amt=(belt_ammo<need)?belt_ammo:need;
gun_ammos[gi].mag_loaded+=reload_amt;
if(slot==1) holster1_belt_ammo-=reload_amt;
else holster2_belt_ammo-=reload_amt;
speak(reload_amt+" rounds auto-loaded from belt.");
}
}
if(slot==1){holster1_weapon="";holster1_weapon_ammo=0;}
else{holster2_weapon="";holster2_weapon_ammo=0;}
draw_weapon(wname);
}
void show_weapon_info(string wname)
{
audio_form f;
f.create_window(get_weapon_display_name(wname), false, true);
int gi=find_gun(wname);
int base_firetime=500;
int base_walktime=200;
bool is_melee_weapon=false;
if(wname=="machete"){base_firetime=1000;base_walktime=170;is_melee_weapon=true;}
else if(wname=="combatknife"){base_firetime=500;base_walktime=170;is_melee_weapon=true;}
else if(wname=="katana"){base_firetime=800;base_walktime=170;is_melee_weapon=true;}
else if(wname=="baseball_bat"){base_firetime=600;base_walktime=170;is_melee_weapon=true;}
else if(wname=="hayvork"){base_firetime=900;base_walktime=185;is_melee_weapon=true;}
else if(wname=="trector_plow"){base_firetime=1100;base_walktime=400;is_melee_weapon=true;}
else if(wname=="glock17"){base_firetime=800;base_walktime=180;}
else if(wname=="beretta92fs_pistol"){base_firetime=600;base_walktime=180;}
else if(wname=="desert_eagle"){base_firetime=900;base_walktime=180;}
else if(wname=="taurus_model66_revolver"){base_firetime=790;base_walktime=180;}
else if(wname=="magnum_revolver"){base_firetime=800;base_walktime=180;}
else if(wname=="p90_mp"){base_firetime=90;base_walktime=190;}
else if(wname=="mp5"){base_firetime=100;base_walktime=190;}
else if(wname=="uzi"){base_firetime=75;base_walktime=190;}
else if(wname=="mp7"){base_firetime=85;base_walktime=190;}
else if(wname=="hk_g36"){base_firetime=150;base_walktime=220;}
else if(wname=="AK47"){base_firetime=150;base_walktime=220;}
else if(wname=="tar_21_assault_rifle"){base_firetime=180;base_walktime=220;}
else if(wname=="famas_f1_assault_rifle"){base_firetime=750;base_walktime=210;}
else if(wname=="m4a1_carbine"){base_firetime=140;base_walktime=210;}
else if(wname=="scar_h_battle_rifle"){base_firetime=300;base_walktime=300;}
else if(wname=="fn_fal_battle_rifle"){base_firetime=280;base_walktime=300;}
else if(wname=="m1garantBattleRifle"){base_firetime=1200;base_walktime=400;}
else if(wname=="rpk_lmg"){base_firetime=120;base_walktime=350;}
else if(wname=="m249_saw"){base_firetime=100;base_walktime=500;}
else if(wname=="ks123shotgun"){base_firetime=850;base_walktime=230;}
else if(wname=="benelli_m4_shotgun"){base_firetime=1500;base_walktime=230;}
else if(wname=="spas_12_shotgun"){base_firetime=1000;base_walktime=250;}
else if(wname=="sg08_sniper_rifle"){base_firetime=3000;base_walktime=1000;}
else if(wname=="awp_sniper_rifle"){base_firetime=3500;base_walktime=1200;}
else if(wname=="dragunov_svd"){base_firetime=1500;base_walktime=600;}
else if(wname=="120mm_mortar"){base_firetime=4000;base_walktime=5000;}
else if(wname=="crossbow"){base_firetime=2000;base_walktime=250;}
else if(wname=="laser_pistol"){base_firetime=700;base_walktime=180;}
else if(wname=="laser_smg"){base_firetime=80;base_walktime=190;}
else if(wname=="laser_rifle"){base_firetime=160;base_walktime=220;}
else if(wname=="laser_sniper"){base_firetime=2500;base_walktime=800;}
else if(wname=="laser_cannon"){base_firetime=90;base_walktime=450;}
else if(wname=="flamethrower"){base_firetime=50;base_walktime=300;}
else if(wname=="chainsaw"){base_firetime=100;base_walktime=250;}
float ft_mult=get_attachment_firetime_mult(wname);
float wt_mult=get_attachment_walktime_mult(wname);
int final_firetime=int(base_firetime*ft_mult);
int final_walktime=int(base_walktime*wt_mult);
if(is_melee_weapon)
f.create_input_box("Type", "Melee", "", 0, false, true, false);
else if(gi>=0)
{
f.create_input_box("Type", "Ranged", "", 0, false, true, false);
f.create_input_box("Ammo type", gun_ammos[gi].ammo_type, "", 0, false, true, false);
f.create_input_box("Feed device", gun_ammos[gi].feed_device, "", 0, false, true, false);
f.create_input_box("Capacity", ""+gun_ammos[gi].mag_capacity, "", 0, false, true, false);
}
f.create_input_box("Fire rate", ""+final_firetime+" ms"+(ft_mult!=1.0?" (base "+base_firetime+" ms)":""), "", 0, false, true, false);
f.create_input_box("Movement speed", ""+final_walktime+" ms"+(wt_mult!=1.0?" (base "+base_walktime+" ms)":""), "", 0, false, true, false);
string[] attached=get_weapon_attachments(wname);
if(attached.length()>0)
{
int att_list=f.create_list("Attachments", 0, false);
for(uint i=0; i<attached.length(); i++)
{
int def_idx=find_attachment_def(attached[i]);
if(def_idx>=0)
{
string label=attachment_defs[def_idx].display_name+" ("+attachment_defs[def_idx].slot+")";
if(ft_mult!=1.0 or wt_mult!=1.0)
{
label+=" -";
if(attachment_defs[def_idx].firetime_mult!=1.0)
label+=" fire rate x"+attachment_defs[def_idx].firetime_mult;
if(attachment_defs[def_idx].walktime_mult!=1.0)
label+=" move speed x"+attachment_defs[def_idx].walktime_mult;
}
if(!attachment_defs[def_idx].removable) label+=" [permanent]";
f.add_list_item(att_list, label);
}
}
int remove_btn=f.create_button("Remove selected attachment", false, false);
int close_btn=f.create_button("Close", false, true);
f.focus(att_list);
while(true)
{
wait(5);
f.monitor();
if(f.is_pressed(close_btn)) return;
if(f.is_pressed(remove_btn))
{
int sel=f.get_list_position(att_list);
if(sel>=0 and sel<int(attached.length()))
{
int def_idx=find_attachment_def(attached[sel]);
if(def_idx>=0 and !attachment_defs[def_idx].removable)
{
speak("This attachment cannot be removed.");
}
else if(detach_from_weapon(attached[sel], wname))
{
give(attached[sel], 1);
apply_weapon_stats(wname);
send_reliable(0, "detach "+attached[sel]+" "+wname, 0);
speak(attachment_defs[def_idx].display_name+" removed. Returned to inventory.");
return;
}
}
}
}
}
else
{
int close_btn=f.create_button("Close", false, true);
while(true)
{
wait(5);
f.monitor();
if(f.is_pressed(close_btn)) return;
}
}
}
string[] hypercomp_fetch_bunkers()
{
string[] result;
send_reliable(0, "hypercomp query_bunkers", 0);
timer ct;
while(ct.elapsed<3000)
{
wait(5);
e=n.request();
if(e.type==event_receive)
{
string msg=get_event_message();
if(string_contains(msg, "hypercomp_bunkers ", 1)==0)
{
string data=string_replace(msg, "hypercomp_bunkers ", "", false);
if(data!="none")
result=string_split(data, ",", false);
break;
}
}
}
return result;
}
void hypercomp_menu()
{
audio_form f;
f.create_window("HyperComp", false, true);
int f_status=f.create_button("View &bunker status");
int f_monitor=f.create_button("Toggle &monitor mode");
int f_c4=f.create_button("&C4 management");
int f_alarm=f.create_button("Toggle bunker &alarm");
int f_close=f.create_button("Cl&ose", true, true);
f.focus(f_status);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(f_status))
{
send_reliable(0, "hypercomp bunker_status", 0);
}
else if(f.is_pressed(f_monitor))
{
hypercomp_monitor_menu();
}
else if(f.is_pressed(f_c4))
{
hypercomp_c4_menu();
}
else if(f.is_pressed(f_alarm))
{
hypercomp_alarm_menu();
}
else if(f.is_pressed(f_close))
return;
}
}
void hypercomp_c4_menu()
{
send_reliable(0, "hypercomp c4_count", 0);
speak("Checking C4 charges, please wait.");
int c4count=-1;
timer ct;
while(ct.elapsed<3000)
{
wait(5);
e=n.request();
if(e.type==event_receive)
{
string msg=get_event_message();
if(string_contains(msg, "hypercomp_c4 ", 1)==0)
{
c4count=string_to_number(string_replace(msg, "hypercomp_c4 ", "", false));
break;
}
}
}
if(c4count<0)
{
speak("Could not retrieve C4 data.");
return;
}
audio_form f;
f.create_window("C4 Management", false, true);
f.create_input_box("Active C4 charges", ""+c4count, "", 0, false, true, false);
int f_det=f.create_button("&Detonate");
int f_close=f.create_button("&Close", true, true);
f.focus(f_det);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(f_det))
{
if(c4count<=0)
{
speak("No C4 charges placed.");
continue;
}
audio_form d;
d.create_window("Detonate C4", false, true);
int d_count=d.create_input_box("How many to detonate (max "+c4count+")", ""+c4count, "", 0, false, false, false);
int d_go=d.create_button("&Detonate", true);
int d_cancel=d.create_button("&Cancel", false, true);
d.focus(d_count);
while(true)
{
wait(5);
d.monitor();
if(connected==true) netloop();
if(d.is_pressed(d_go))
{
string val=d.get_text(d_count);
int num=string_to_number(val);
if(num<1) num=1;
if(num>c4count) num=c4count;
send_reliable(0, "hypercomp detonate_c4 "+num, 0);
break;
}
if(d.is_pressed(d_cancel))
break;
}
return;
}
if(f.is_pressed(f_close))
return;
}
}
void hypercomp_monitor_menu()
{
speak("Fetching bunker data, please wait.");
string[] bdata=hypercomp_fetch_bunkers();
if(bdata.length()==0)
{
speak("You don't own any bunkers.");
return;
}
audio_form f;
f.create_window("Bunker Monitor", false, true);
int f_list=f.create_list("Select a bunker to toggle monitor mode", 0, false);
string[] bunker_ids;
for(uint i=0; i<bdata.length(); i++)
{
string[] parts=string_split(bdata[i], "|", false);
if(parts.length()<7) continue;
string bname=parts[1];
string mon_status=(parts[5]=="1" ? "ON" : "OFF");
f.add_list_item(f_list, bname+" at "+parts[2]+", "+parts[3]+", "+parts[4]+" - Monitor: "+mon_status);
bunker_ids.insert_last(parts[0]);
}
int f_toggle=f.create_button("&Toggle monitor");
int f_close=f.create_button("&Close", true, true);
f.focus(f_list);
while(true)
{
wait(5);
f.monitor();
if(connected==true) netloop();
if(f.is_pressed(f_toggle))
{
int sel=f.get_list_position(f_list);
if(sel>=0 and sel<int(bunker_ids.length()))
{
send_reliable(0, "hypercomp toggle_monitor "+bunker_ids[sel], 0);
return;
}
}
if(f.is_pressed(f_close))
return;
}
}
void hypercomp_alarm_menu()
{
speak("Fetching bunker data, please wait.");
string[] bdata=hypercomp_fetch_bunkers();
if(bdata.length()==0)
