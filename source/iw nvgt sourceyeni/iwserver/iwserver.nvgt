#include "bgt_compat.nvgt"
#include"includes/item.nvgt"
#include"includes/plane.nvgt"
#include"includes/flood.nvgt"
#include"includes/chest.nvgt"
#include"includes/bomb.nvgt"
#include"includes/building.nvgt"
#include"includes/torpedo.nvgt"
#include "includes/bodyfall.nvgt"
#include "includes/map.nvgt"
#include "includes/player.nvgt"
#include "includes/rotation.nvgt"
#include "includes/weapon.nvgt"
#include "includes/grenade.nvgt"
#include "includes/corpse.nvgt"
#include "includes/citem.nvgt"
#include "../includes/sd.nvgt"
int battlers=0;
int habitat_fighters=0;
string habitat_winner;
string[] killmsgs;
timer spawn_chesttimer;
string winner;
string changes;
double minversion=0.12;
string current_map="";
const int port=1316;
string adminlist="";
network n;
network_event e;
timer uptimer;
string motd;
bool auth_mode=false;
const string ACCOUNT_SECRET = "IW_aCc0unt_K3y_xK9mP2vL7nQ4wR8t!";
void main()
{
show_window("Infinite Warfare server!, version "+ minversion);
file pr;
if(file_exists("admins.txt"))
{
pr.open("admins.txt", "rb");
adminlist=pr.read();
pr.close();
}
if(file_exists("killmsgs.txt"))
{
pr.open("killmsgs.txt","rb");
killmsgs=delinear(pr.read());
pr.close();
}
else
{
killmsgs.insert_last("%1 was owned by %2 on map %3");
pr.open("killmsgs.txt","wb");
pr.write(linear(killmsgs));
pr.close();
}
file f;
if(file_exists("motd.svr"))
{
f.open("motd.svr", "rb");
motd=f.read();
f.close();
}
if(file_exists("currentmap.txt"))
{
file f;
f.open("currentmap.txt", "rb");
current_map=f.read();
f.close();
}
if(file_exists("authmode.svr"))
{
file af;
af.open("authmode.svr", "rb");
auth_mode=(af.read()=="1");
af.close();
}
n.setup_server(port, 20, 500);
init_mapsystem();
spawn_bunker(35,250,-5,"main","","bunker A");
spawn_bunker(305,250,-5,"main","","bunker B");
spawn_bunker(300,10,-5,"main","","bunker C");
spawn_bunker(300,490,-5,"main","","bunker D");
spawn_ballista(45,250,0,"main");
spawn_ballista(295,250,0,"main");
spawn_ballista(300,20,0,"main");
spawn_ballista(300,480,0,"main");
spawn_watertank(31,251,-50,"main");
spawn_watertank(309,251,-50,"main");
spawn_watertank(299,6,-50,"main");
spawn_watertank(299,494,-50,"main");
while(true)
{
wait(5);
netloop();
if(spawn_chesttimer.elapsed>=300000 and chests.length()<=10)
{
spawn_chesttimer.restart();
spawn_chest(random(0,400),random(0,500),0,"main",in_chest[random(0,in_chest.length()-1)]);
send_reliable(0, "there is a chest spawned", 2);  
}
if(key_pressed(KEY_ESCAPE))
{
exit();
}
}
}
void netloop()
{
bunkerloop();
floodloop();
planebombloop();
ladderloop();
planeloop();
bombloop();
wallloop();
bunkerbombloop();
mortarloop();
chestloop();
bombloop();
smokebombloop();
fraggrenadeloop();
torpedoloop();
weaponloop();
bodyfallloop();
playerloop();
itemloop();
maploop();
if(battlers==1)
{
for(int i=0; i<players.length(); i++)
{
if(players[i].map=="battleroyale" and players[i].death==false)
{
winner=players[i].name;
}
}
int index=get_player_index_from(winner);
if(index>-1)
{
send_reliable(players[index].peer_id, "nice job. you winned the battle royale!", 2);
players[index].x=random(0,500);
players[index].y=random(0,500);
players[index].battleroyale=false;
players[index].z=0;
players[index].map="main";
send_reliable(players[index].peer_id, "setcoords "+players[index].x+" "+players[index].y+" "+players[index].z, 0);
file f;
f.open("map/main.map", "rb");
send_reliable(players[index].peer_id, "mapdata "+f.read(), 0);
f.close();
send_reliable(0, players[index].name+"  wins the battleroyale.", 2); 
send_reliable(0, "play_s win.ogg", 0);
winner=""; 
}
battlers=0;
}
if(habitat_fighters==1)
{
for(int i=0; i<players.length(); i++)
{
if(players[i].map=="habitat_alpha" and players[i].death==false)
{
habitat_winner=players[i].name;
}
}
int hindex=get_player_index_from(habitat_winner);
if(hindex>-1)
{
send_reliable(players[hindex].peer_id, "nice job. you won habitat alpha!", 2);
players[hindex].x=random(0,500);
players[hindex].y=random(0,500);
players[hindex].habitat_alpha=false;
players[hindex].z=0;
players[hindex].map="main";
send_reliable(players[hindex].peer_id, "setcoords "+players[hindex].x+" "+players[hindex].y+" "+players[hindex].z, 0);
file hf;
hf.open("map/main.map", "rb");
send_reliable(players[hindex].peer_id, "mapdata "+hf.read(), 0);
hf.close();
send_reliable(0, players[hindex].name+" wins habitat alpha!", 2);
send_reliable(0, "play_s win.ogg", 0);
habitat_winner="";
}
habitat_fighters=0;
}
e=n.request();
if(key_pressed(KEY_H))
{
hide_window();
}
if(file_exists("updating.txt"))
{
send_reliable(0, "updating", 0);
file_delete("updating.txt");
wait(500);
exit();
}
if(current_map=="random") current_map=select_random_map();
if(e.type==event_disconnect)
{
int index=get_player_index(e.peer_id);
if(index > -1)
{
send_reliable(0, "offline "+players[index].x+" "+players[index].y+" "+players[index].z+" "+players[index].name+" "+players[index].map, 0);
wait(100);
players.remove_at(index);
}
int li=get_lobby_client_index(e.peer_id);
if(li>-1)
{
send_reliable(0, lobby_clients[li].name+" has left the lobby", 2);
lobby_clients.remove_at(li);
}
}
else if(e.type==event_receive)
{
if (e.channel==1)
{
string[] parsed=string_split(get_event_message(), " ",true);
int index=get_player_index(e.peer_id);
if (index>-1)
{
if(parsed[0]=="/currentmap" and players[index].dev)
{
if(parsed.length()>1)
{
current_map=parsed[1];
file f;
f.open("currentmap.txt", "wb");
f.write(current_map);
f.close();
if(parsed[1]=="random") mapupdate(select_random_map());
else mapupdate(current_map);
}
else send_reliable(players[index].peer_id, "the current map is "+current_map, 0);
}
else if(parsed[0]=="/bunkers")
{
send_reliable(players[index].peer_id, "bunker A is at :35: 250: -5", 2);
send_reliable(players[index].peer_id, "bunker B is at: 305: 250: -5", 2);
send_reliable(players[index].peer_id, "bunker C is at: 300: 10: -5", 2);
send_reliable(players[index].peer_id, "bunker D is at: 300: 490: -5", 2);
}
else if(parsed[0]=="/getmyshit" and players[index].dev)
{
move_items_to(players[index].x,players[index].y,players[index].z,players[index].map,items.length()-1);
}
else if(parsed[0]=="/start_admin")
{
if(string_contains(players[index].comp,adminlist,1)>-1)
{
players[index].admin=true;
send_reliable(0, players[index].name+" is an admin of Infinite Warfare", 2);
}
}
else if(parsed[0]=="/kick" and parsed.length()>1)
{
if(players[index].dev or players[index].admin==true)
{
int ind2=get_player_index_from(parsed[1]);
if(ind2>-1)
{
if(players[ind2].dev)
{
send_reliable(players[index].peer_id, "you can't kick a dev, sorry.", 0);
}
else
{
send_reliable(0, "offline "+players[ind2].x+" "+players[ind2].y+" "+players[ind2].z+" "+players[ind2].name+" "+players[ind2].map, 0);
players.remove_at(ind2);
}
}
}
}
else if(parsed[0]=="/reboot")
{
if(players[index].dev)
{
send_reliable(0, "server rebooting", 2);
send_reliable(0, "play_s notify.ogg", 0);
wait(4500);
for(int i=0; i<players.length(); i++)
{
send_reliable(0, "offline "+players[i].x+" "+players[i].y+" "+players[i].z+" "+players[i].name+" "+players[i].map,0);
}
wait(300);
run("iwserver.exe", "", false, false);
exit();
}
else send_reliable(players[index].peer_id, "you must be adev to perform this action", 0);
}
else if(parsed[0]=="/duomate" and parsed.length()>1)  
{
int index2=get_player_index_from(parsed[1]);
if (index2>=-1)
{
if(players[index2].mate!="") 
{
send_reliable(players[index].peer_id, players[index2].name+"s duo_mate is"+players[index2].mate, 2);
}
else 
send_reliable(players[index].peer_id, "this player don't have a duo mate", 2);
}
else 
send_reliable(e.peer_id,"Not found",2);
}
else if(parsed[0]=="/go")
{
if(players[index].dev or players[index].admin==true)  
{
if(parsed.length()>3)
{
if(parsed.length()==4)
{
players[index].x=string_to_number(parsed[1]);
players[index].y=string_to_number(parsed[2]);
players[index].z=string_to_number(parsed[3]);
send_reliable(players[index].peer_id, "setcoords "+players[index].x+" "+players[index].y+" "+players[index].z, 0);
play("moved"+random(1, 2), players[index].x, players[index].y, players[index].z, players[index].map, index);
}
else if(parsed.length()==5)
{
int index2=get_player_index_from(parsed[1]);
if(index2>-1)
{
players[index2].x=string_to_number(parsed[2]);
players[index2].y=string_to_number(parsed[3]);
players[index2].z=string_to_number(parsed[4]);
send_reliable(players[index2].peer_id, "setcoords "+players[index2].x+" "+players[index2].y+" "+players[index2].z, 0);
play("moved"+random(1, 2), players[index].x, players[index].y, players[index].z, players[index].map, index);
}
else send_reliable(players[index].peer_id, "player not found", 0);
}
}
}
else send_reliable(players[index].peer_id, "you must be a dev to perform this command", 0);
}
else if(parsed[0]=="/leave" and players[index].battleroyale==true and players[index].map=="battle_royale_waiting")
{
players[index].battleroyale=false;
players[index].x=random(0,500);
players[index].y=random(0,500);
players[index].z=0;
players[index].map="main";
send_reliable(players[index].peer_id, "setcoords "+players[index].x+" "+players[index].y+" "+players[index].z, 0);
file f;
f.open("map/main.map", "rb");
send_reliable(players[index].peer_id, "mapdata "+f.read(), 0);
f.close();
send_reliable(players[index].peer_id, "done!", 0); 
}
else if(parsed[0]=="/br" and players[index].battleroyale==false)
{
players[index].battleroyale=true;
players[index].x=0;
players[index].y=0;
players[index].z=0;
players[index].map="battle_royale_waiting";
send_reliable(players[index].peer_id, "setcoords "+players[index].x+" "+players[index].y+" "+players[index].z, 0);
file f;
f.open("map/battle_royale_waiting.map", "rb");
send_reliable(players[index].peer_id, "mapdata "+f.read(), 0);
f.close();
send_reliable(players[index].peer_id, "reset_ammo", 0);
send_reliable(players[index].peer_id, "resetinv", 0);
send_reliable(players[index].peer_id, "done!", 0);
}
else if(parsed[0]=="/leave" and players[index].habitat_alpha==true and players[index].map=="habitat_alpha_waiting")
{
players[index].habitat_alpha=false;
players[index].x=random(0,500);
players[index].y=random(0,500);
players[index].z=0;
players[index].map="main";
send_reliable(players[index].peer_id, "setcoords "+players[index].x+" "+players[index].y+" "+players[index].z, 0);
file f;
f.open("map/main.map", "rb");
send_reliable(players[index].peer_id, "mapdata "+f.read(), 0);
f.close();
send_reliable(players[index].peer_id, "done!", 0);
}
else if(parsed[0]=="/ha" and players[index].habitat_alpha==false)
{
players[index].habitat_alpha=true;
players[index].x=0;
players[index].y=0;
players[index].z=0;
players[index].map="habitat_alpha_waiting";
send_reliable(players[index].peer_id, "setcoords "+players[index].x+" "+players[index].y+" "+players[index].z, 0);
file f;
f.open("map/habitat_alpha_waiting.map", "rb");
send_reliable(players[index].peer_id, "mapdata "+f.read(), 0);
f.close();
send_reliable(players[index].peer_id, "reset_ammo", 0);
send_reliable(players[index].peer_id, "resetinv", 0);
send_reliable(players[index].peer_id, "done!", 0);
}
else if(parsed[0]=="/d" and parsed.length()>1)
{
string message=string_replace(get_event_message(), "/d ", "", false);
int index=get_player_index(e.peer_id);
if(index>-1)
{
int index2=get_player_index_from(players[index].mate);
if(index2>-1)
{
if(players[index2].mate==players[index].name)
{
send_reliable(players[index2].peer_id, "play_s dc.ogg", 0);
send_reliable(players[index2].peer_id, players[index].name+ " says in the duo chat: "+message, 2);
send_reliable(players[index].peer_id, "your duo message has been send!", 0);
}
}
}
}
if(parsed[0]=="/removeitems")
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
if(players[index].dev)
{
items.resize(0);
send_reliable(players[index].peer_id,"done" , 2);
}
else
send_reliable(players[index].peer_id,"sorry, you can't do this." , 2);
}
}
if(parsed[0]=="/getfeedback")
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
if(players[index].dev)
{
file pr;
pr.open("feedback.txt","rb");
string message=pr.read();
pr.close();
send_reliable(players[index].peer_id,message , 2);
}
else
  send_reliable(players[index].peer_id, "you don't need the feedback , because you are not a dev.", 2);
}
}
if(parsed[0]=="/feedback")
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
string message=string_replace(get_event_message(),"/feedback ", "", true);
file pr;
pr.open("feedback.txt","rb");
string oldtext=pr.read();
pr.close();
pr.open("feedback.txt","wb");
pr.write(oldtext+"\n");
pr.write(players[index].name+ ": "+ message);
pr.close();
send_reliable(players[index].peer_id, "feedback sent successfully!", 2);
}
}
else if(parsed[0]=="/ban" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
if(players[index].dev or players[index].admin==true)
{
int index2=get_player_index_from(parsed[1]);
if(index2>-1)
{
if(!players[index2].dev or players[index].name==players[index2].name)
{
file pr;
pr.open("banned.txt","rb");
string oldtext=pr.read();
pr.close();
pr.open("banned.txt","wb");
pr.write(oldtext+"\n");
pr.write(players[index].name+ ": "+players[index2].comp);
pr.close();
send_reliable(0, "offline "+players[index2].x+" "+players[index2].y+" "+players[index2].z+" "+players[index2].name+" "+players[index2].map, 0);
players.remove_at(index2);
send_reliable(0, "play_s ban.ogg", 0);
send_reliable(0, parsed[1]+"was just banned by the ban fist.", 0);
send_reliable(players[index].peer_id, players[index2].name+" banned.", 2);
}
else send_reliable(players[index].peer_id, "player can't be banned.", 2);
}
else send_reliable(players[index].peer_id, "player not found.", 2);
}
}
}
else if(parsed[0]=="/newadmin" and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
if(players[index].dev==true)
{
int index2=get_player_index_from(parsed[1]);
if(index2>-1)
{
file pr;
pr.open("admins.txt","rb");
string oldtext=pr.read();
pr.close();
pr.open("admins.txt","wb");
pr.write(oldtext+"\n");
pr.write(players[index2].name+ ": "+players[index2].comp);
pr.close();
send_reliable(0, players[index2].name+" is now a part of the admin team.", 2);
send_reliable(0, "play_s notify.ogg", 0);
}
}
else
send_reliable(players[index].peer_id, "you are not a dev", 2);
}
}
else if(parsed[0]=="/notify"and parsed.length()>1)
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
string message=string_replace(get_event_message(),"/notify ", "", true);
if(players[index].dev or players[index].admin==true)
{
send_reliable(0, message, 2);
send_reliable(0, "play_s notify.ogg", 0);
}
}
}
else if(parsed[0]=="/pm")
{
int index=get_player_index(e.peer_id);
if(index>-1)
{
int index2=get_player_index_from(parsed[1]);
if(index2>-1)
{
string message=string_replace(get_event_message(),"/pm "+parsed[1]+" ", "", true);
send_reliable(players[index2].peer_id, "play_s pm.ogg", 0);
send_reliable(players[index2].peer_id, "pm from "+players[index].name+": "+message, 2);
send_reliable(players[index].peer_id, "pm sent successfully", 2);
}
else send_reliable(players[index].peer_id, "player not found.", 2);
}
}
else if(parsed[0]=="/give" and parsed.length()>3)
{
if(players[index].dev or players[index].admin==true)
{
int i2=get_player_index_from(parsed[1]);
if(i2>-1)
send_reliable(players[i2].peer_id, "give "+parsed[2]+" "+parsed[3], 0);
}
}
else if(parsed[0]=="/givemyself" and parsed.length()>2)
{
if(players[index].admin==true or players[index].dev)
{
send_reliable(e.peer_id, "give "+parsed[1]+" "+parsed[2], 0);
}
else send_reliable(0, "you must be atleast an admin to perform this action", 0);
}
else if(parsed[0]=="/changes")
{
send_reliable(e.peer_id,"this are the new changes :"+changes ,2);
}
else if(parsed[0]=="/motd")
{
if(players[index].dev or players[index].admin==true)
{
motd=string_replace(get_event_message(), "/motd ", "", true);
file f;
f.open("motd.svr", "wb");
f.write(motd);
f.close();
send_reliable(0, "play_s newmotd.ogg", 0);
send_reliable(0, "server message has been set to "+motd, 0);
}
else
send_reliable(players[index].peer_id, "you must be a dev to perform this action", 0);
}
if (string_contains(parsed[0],"/",1)==-1)
{
string pn;
if(players[index].admin==true)
{
pn+="admin ";
}
if(players[index].dev==true)
{
pn+="developer ";
}
pn+=players[index].name;
send_reliable(0,pn+": "+get_event_message(),1);
}
}
}
if (e.channel==0)
{
string[] parsed=string_split(get_event_message(), " ", true);
if(parsed[0]=="connect_me" and parsed.length() > 3)
{
login(parsed[1], e.peer_id, string_to_number(parsed[2]),parsed[3]);
}
else if(parsed[0]=="lobby_players")
{
// Pre-spawn request: returns in-game player list. No player index check needed.
string s;
if(players.length()==0)
s="lobby_info No players are currently in-game.";
else
{
s="lobby_info "+players.length()+(players.length()==1?" player":" players")+" in-game: ";
for(uint i=0; i<players.length(); i++)
{
if(i<players.length()-1)
s+=players[i].name+", ";
else
s+=players[i].name+".";
}
}
send_reliable(e.peer_id, s, 0);
}
else if(parsed[0]=="enter_lobby" and parsed.length()>2)
{
// Client entered the lobby. Track them.
string lname=parsed[1];
string lcomp=parsed[2];
// Remove any stale entry first
remove_lobby_client(e.peer_id);
lobby_client lc(e.peer_id, lname, lcomp);
if(string_contains(adminlist, lcomp, 1)>-1)
lc.admin=true;
lobby_clients.insert_last(lc);
send_reliable(0, lname+" has entered the lobby", 2);
}
else if(parsed[0]=="lobby_is_dev")
{
int li=get_lobby_client_index(e.peer_id);
if(li>-1)
lobby_clients[li].dev=true;
}
else if(parsed[0]=="leave_lobby")
{
int li=get_lobby_client_index(e.peer_id);
if(li>-1)
{
send_reliable(0, lobby_clients[li].name+" has left the lobby", 2);
lobby_clients.remove_at(li);
}
}
else if(parsed[0]=="enter_mode" and parsed.length()>1)
{
int li=get_lobby_client_index(e.peer_id);
if(li>-1)
{
send_reliable(0, lobby_clients[li].name+" has entered "+parsed[1], 2);
lobby_clients.remove_at(li);
}
}
else if(parsed[0]=="lobby_playerlist")
{
// Returns structured list of all connected clients for the F1 player menu.
// Format: lobby_plist name|flags|status,name|flags|status,...
// flags: d=dev, a=admin
// status: lobby or mode name
string s="lobby_plist ";
bool first=true;
for(uint i=0; i<lobby_clients.length(); i++)
{
if(!first) s+=",";
s+=lobby_clients[i].name+"|";
if(lobby_clients[i].dev) s+="d";
if(lobby_clients[i].admin) s+="a";
s+="|lobby";
first=false;
}
for(uint i=0; i<players.length(); i++)
{
if(!first) s+=",";
s+=players[i].name+"|";
if(players[i].dev) s+="d";
if(players[i].admin) s+="a";
s+="|"+players[i].map;
first=false;
}
send_reliable(e.peer_id, s, 0);
}
else if(parsed[0]=="admin_panel" and parsed.length()>1)
{
// Accept both admins (by comp) and devs (by "dev" flag)
string acomp=parsed[1];
bool is_admin=(string_contains(adminlist, acomp, 1)>-1);
bool is_dev=(parsed.length()>2 and parsed[2]=="dev");
if(is_admin or is_dev)
send_reliable(e.peer_id, "admin_panel_ok "+(auth_mode ? "1" : "0"), 0);
else
send_reliable(e.peer_id, "admin_panel_denied", 0);
}
else if(parsed[0]=="admin_set_authmode" and parsed.length()>2)
{
string acomp=parsed[2];
bool is_adm=(string_contains(adminlist, acomp, 1)>-1);
bool is_dv=(parsed.length()>3 and parsed[3]=="dev");
if(is_adm or is_dv)
{
auth_mode=(parsed[1]=="1");
file af;
af.open("authmode.svr", "wb");
af.write(auth_mode ? "1" : "0");
af.close();
send_reliable(e.peer_id, "admin_authmode_saved", 0);
}
}
else if(parsed[0]=="admin_get_unauth" and parsed.length()>1)
{
string acomp=parsed[1];
bool is_admu=(string_contains(adminlist, acomp, 1)>-1);
bool is_dvu=(parsed.length()>2 and parsed[2]=="dev");
if(is_admu or is_dvu)
{
string result="admin_unauth_list ";
string[] files=find_files("accounts/*.dat");
bool first2=true;
for(uint i=0; i<files.length(); i++)
{
savedata acct("accounts/"+files[i], ACCOUNT_SECRET);
acct.load();
if(!acct.d.exists("authenticated"))
continue;
if(acct.readn("authenticated")<1.0)
{
if(!first2) result+=",";
result+=acct.read("username")+"|"+acct.read("authcode");
first2=false;
}
}
send_reliable(e.peer_id, result, 0);
}
}
else if(parsed[0]=="check_authmode")
{
send_reliable(e.peer_id, "authmode_status "+(auth_mode ? "1" : "0"), 0);
}
else if(parsed[0]=="request_password_reset" and parsed.length()>1)
{
// Client requests a password reset. Generate a code and store it on the account.
string ruser=parsed[1];
string rpath="accounts/"+string_to_lower_case(ruser)+".dat";
if(file_exists(rpath))
{
savedata acct(rpath, ACCOUNT_SECRET);
acct.load();
// Generate a 6-char reset code
string chars="ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
string rcode="";
for(int i=0; i<6; i++)
rcode+=chars[random(0, chars.length()-1)];
acct.add("resetcode", rcode);
acct.save();
send_reliable(e.peer_id, "reset_requested", 0);
}
else
send_reliable(e.peer_id, "reset_no_account", 0);
}
else if(parsed[0]=="submit_reset_code" and parsed.length()>2)
{
string ruser=parsed[1];
string rcode=parsed[2];
string rpath="accounts/"+string_to_lower_case(ruser)+".dat";
if(file_exists(rpath))
{
savedata acct(rpath, ACCOUNT_SECRET);
acct.load();
string stored=acct.read("resetcode");
if(stored!="" and stored==rcode)
send_reliable(e.peer_id, "reset_code_ok", 0);
else
send_reliable(e.peer_id, "reset_code_bad", 0);
}
else
send_reliable(e.peer_id, "reset_code_bad", 0);
}
else if(parsed[0]=="reset_password" and parsed.length()>2)
{
string ruser=parsed[1];
string rnewpass=parsed[2];
string rpath="accounts/"+string_to_lower_case(ruser)+".dat";
if(file_exists(rpath))
{
savedata acct(rpath, ACCOUNT_SECRET);
acct.load();
// Re-hash with new password
acct.add("password", string_encrypt(rnewpass, ACCOUNT_SECRET+"_"+string_to_lower_case(ruser)));
acct.add("resetcode", "");
acct.save();
send_reliable(e.peer_id, "reset_done", 0);
}
}
