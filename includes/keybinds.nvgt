bool kb_validate_config()
{
for (uint i=0; i<_kb_act_binds.length(); i++)
{
if (_kb_act_binds[i]<0) return false;
}
return true;
}

void kb_show_restore_message()
{
audio_form f;
f.create_window("Key Configuration Restored", false, true);
f.create_input_box("Notice", "Your key configuration file could not be found or was corrupted. The game has restored all key bindings to their default values and created a new configuration file. You can rebind keys at any time from the options menu.", "", 0, false, true, false);
int f_continue=f.create_button("&Continue", true);
f.focus(0);
while(true)
{
wait(5);
f.monitor();
if (f.is_pressed(f_continue))
break;
}
}

void kb_load()
{
file f;
if (!f.open("keyconfig.json","rb")) return;
string content=f.read();
f.close();
if (content=="") return;
content=string_replace(content,"\r\n","\n",true);
content=string_replace(content,"\r","\n",true);
string[] lines=string_split(content,"\n",true);
for (uint i=0; i<lines.length(); i++)
{
string line=lines[i];
line=string_replace(line,"\"","",true);
line=string_replace(line,",","",true);
line=string_replace(line," ","",true);
line=string_replace(line,"\t","",true);
int cp=string_contains(line,":",1);
if (cp<0) continue;
string act=string_left(line,cp);
string kn=string_mid(line,cp+2,line.length()-cp-1);
int code=kb_name_to_key(kn);
if (code<0) continue;
for (uint j=0; j<_kb_act_names.length(); j++)
{
if (_kb_act_names[j]==act)
{
_kb_act_binds[j]=code;
break;
}
}
}
}

void kb_save()
{
file f;
if (!f.open("keyconfig.json","wb")) return;
string json_str="{\n";
for (uint i=0; i<_kb_act_names.length(); i++)
{
json_str+="  \""+_kb_act_names[i]+"\": \""+kb_key_to_name(_kb_act_binds[i])+"\"";
if (i<_kb_act_names.length()-1) json_str+=",";
json_str+="\n";
}
json_str+="}\n";
f.write(json_str);
f.close();
}

void kb_reset()
{
for (uint i=0; i<_kb_act_names.length(); i++)
_kb_act_binds[i]=_kb_act_defaults[i];
kb_save();
}

int kb_wait_for_key()
{
while(true)
{
wait(5);
bool any_held=false;
for (int k=1; k<=211; k++)
{
if (key_down(k)){any_held=true; break;}
}
if (!any_held) break;
}
while(true)
{
wait(5);
for (int k=1; k<=211; k++)
{
if (key_pressed(k))
{
if (k==KEY_LSHIFT or k==KEY_RSHIFT or k==KEY_LMENU or k==KEY_RMENU) continue;
return k;
}
}
}
return -1;
}

void kb_update_holds()
{
kleft.key_code=kb("move_left");
kright.key_code=kb("move_right");
kup.key_code=kb("move_forward");
kdown.key_code=kb("move_backward");
kpgdn.key_code=kb("move_down");
kpgup.key_code=kb("move_up");
kQ.key_code=kb("turn_left");
kE.key_code=kb("turn_right");
kS.key_code=kb("aim_up");
kX.key_code=kb("aim_down");
}

void options_keybinds()
{
while(true)
{
audio_form f;
f.create_window("Key Bindings",false,true);
int f_list=f.create_list("Actions. Press Enter to rebind the selected action.",0,false);
for (uint i=0; i<_kb_act_names.length(); i++)
f.add_list_item(f_list,_kb_act_labels[i]+": "+kb_key_label(_kb_act_binds[i]));
int f_rebind=f.create_button("&Rebind selected",true);
int f_reset=f.create_button("R&eset all to defaults",false);
int f_back=f.create_button("Go &back",false,true);
f.focus(f_list);
bool refresh=false;
while(!refresh)
{
wait(5);
f.monitor();
if (connected==true) netloop();
if (f.is_pressed(f_back)) return;
if (f.is_pressed(f_reset))
{
kb_reset();
kb_update_holds();
speak("All key bindings reset to defaults.");
refresh=true;
}
if (f.is_pressed(f_rebind))
{
int sel=f.get_list_position(f_list);
if (sel>=0 and uint(sel)<_kb_act_names.length())
{
speak("Press the new key for "+_kb_act_labels[sel]+". Press Escape to cancel.");
int new_key=kb_wait_for_key();
if (new_key==KEY_ESCAPE and _kb_act_binds[sel]!=KEY_ESCAPE)
{
speak("Cancelled.");
}
else
{
int conflict=-1;
for (uint j=0; j<_kb_act_names.length(); j++)
{
if (int(j)!=sel and _kb_act_binds[j]==new_key)
{
conflict=j;
break;
}
}
if (conflict>=0)
{
int old_key=_kb_act_binds[sel];
_kb_act_binds[conflict]=old_key;
speak(_kb_act_labels[conflict]+" moved to "+kb_key_label(old_key)+".");
}
_kb_act_binds[sel]=new_key;
kb_save();
kb_update_holds();
speak(_kb_act_labels[sel]+" bound to "+kb_key_label(new_key)+".");
}
refresh=true;
}
}
}
}
}
