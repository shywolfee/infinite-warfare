send_reliable_id(lobby_clients[i].peer_id, "Your ticket #"+tid+" ("+t_subject+") was closed by "+closer+". Reason: "+reason, 2);
else
send_reliable_id(lobby_clients[i].peer_id, "Your ticket #"+tid+" ("+t_subject+") has been closed.", 2);
}
}
}
}
}
else if(parsed[0]=="ticket_admin_list_all" and parsed.length()>1)
{
