bunkerbomb@[] bunkerbombs(0);
class bunkerbomb
{
timer bombtimer;
int x;
int y;
int z;
string map;
string  owner;
bunkerbomb(int bx,int by,int bz,string bmap,string bowner)
{
x=bx;
y=by;
z=bz;
map=bmap;
owner=bowner;
}
}
void bunkerbombloop()
{
for (uint i=0; i<bunkerbombs.length(); i++)
{
if (bunkerbombs[i].bombtimer.elapsed>=14000)
{
play("bunkerbombexplode",bunkerbombs[i].x,bunkerbombs[i].y,bunkerbombs[i].z,bunkerbombs[i].map);
send_reliable(0,"distsound bunkerbombdist.ogg "+bunkerbombs[i].x+" "+bunkerbombs[i].y+" "+bunkerbombs[i].z+" "+bunkerbombs[i].map,0);
for (uint i2=0; i2<players.length(); i2++)
{
if (get_3d_distance(bunkerbombs[i].x,bunkerbombs[i].y,bunkerbombs[i].z,players[i2].x,players[i2].y,players[i2].z)<=150 and players[i2].map==bunkerbombs[i].map and players[i2].death==false and players[i2].in_plane==false and !players[i2].is_spawn_protected())

{
int index=get_player_index_from(bunkerbombs[i].owner);
if(index>-1)
{
send_reliable(players[index].peer_id, "play_s weaponping.ogg", 0);
}

players[i2].hitby=bunkerbombs[i].owner+"'s bunkerbomb";
players[i2].health-=2000;
play("bunkerbombhit",players[i2].x,players[i2].y,players[i2].z,players[i2].map);
}
for (uint i2=0; i2<planes.length(); i2++)
{
if (get_3d_distance(bunkerbombs[i].x,bunkerbombs[i].y,bunkerbombs[i].z,planes[i2].x,planes[i2].y,planes[i2].z)<=20 and planes[i2].map==bunkerbombs[i].map)
{
planes[i2].health-=2000;
play("duoplanebombhit",planes[i2].x,planes[i2].y,planes[i2].z,planes[i2].map);
}
}
}

bunkerbombs.remove_at(i);
return;
}
}
}
void spawn_bunkerbomb(int x,int y, int z, string map,string owner)
{
bunkerbomb bomb1(x,y,z,map,owner);
bunkerbombs.insert_last(bomb1);
}
