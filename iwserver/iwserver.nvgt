y=players[ind].y;
z=players[ind].z;
string[] playernames;
int current_dist=-1;
for(uint i=0; i<players.length(); i++)
{
int player_dist=get_3d_distance(x, y, z, players[i].x, players[i].y, players[i].z);
if(players[i].name!=players[ind].name  and players[i].map==players[ind].map)
{
if(player_dist>=current_dist) playernames.insert_last(players[i].name);
else
playernames.insert_at(0, players[i].name);
current_dist=player_dist;
}
}
finaltext+=linear(playernames);
if(finaltext=="playermenu ")
{
finaltext="Just you online";
}
send_reliable(e.peer_id, finaltext, 0);
}
