void smokebombloop()
{
for (uint i=0; i<smokebombs.length(); i++)
{
if (smokebombs[i].bombtimer.elapsed>=1500)
{
play("smokebombexplode",smokebombs[i].x,smokebombs[i].y,smokebombs[i].z,smokebombs[i].map);
