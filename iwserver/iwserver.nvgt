{
string path=tickets_dir+"/"+tid+".dat";
if(file_exists(path))
{
savedata t(path, TICKET_SECRET);
t.load();
string result="ticket_admin_data "+t.read("id")+"~"+t.read("owner")+"~"+t.read("subject")+"~"+t.read("status")+"~"+t.read("close_reason")+"~"+t.read("body");
int rc=int(t.readn("reply_count"));
for(int r=0; r<rc; r++)
result+="~"+t.read("reply_"+r);
send_reliable(e.peer_id, result, 0);
}
else
send_reliable(e.peer_id, "ticket_admin_data not_found", 0);
}
}
