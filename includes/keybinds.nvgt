string[] _kb_key_names;
int[] _kb_key_codes;
string[] _kb_key_labels;
string[] _kb_act_names;
string[] _kb_act_labels;
int[] _kb_act_defaults;
int[] _kb_act_binds;

void _kb_reg_key(string name, int code, string label)
{
_kb_key_names.insert_last(name);
_kb_key_codes.insert_last(code);
_kb_key_labels.insert_last(label);
}

void _kb_reg_action(string name, string label, int default_key)
{
_kb_act_names.insert_last(name);
_kb_act_labels.insert_last(label);
_kb_act_defaults.insert_last(default_key);
_kb_act_binds.insert_last(default_key);
}

int kb(string action)
{
for (uint i=0; i<_kb_act_names.length(); i++)
{
if (_kb_act_names[i]==action) return _kb_act_binds[i];
}
return -1;
}

string kb_key_to_name(int code)
{
for (uint i=0; i<_kb_key_codes.length(); i++)
{
if (_kb_key_codes[i]==code) return _kb_key_names[i];
}
return "unknown";
}

int kb_name_to_key(string name)
{
for (uint i=0; i<_kb_key_names.length(); i++)
{
if (_kb_key_names[i]==name) return _kb_key_codes[i];
}
return -1;
}

string kb_key_label(int code)
{
for (uint i=0; i<_kb_key_codes.length(); i++)
{
if (_kb_key_codes[i]==code) return _kb_key_labels[i];
}
return "Unknown";
}

